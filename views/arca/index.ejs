<% var pageCss = '/css/pages/arca.css' %>
<!DOCTYPE html>
<html lang="es">
<%- include('../layouts/head.ejs') %>
<link rel="stylesheet" href="/css/pages/arca.css?v=1" />
<body class="arca-page">
  <%- include('../layouts/header') %>

  <main class="arca-main">
    <div class="arca-wrap">

      <!-- PAGE HEADER -->
      <div class="arca-page-header">
        <div class="arca-page-header__left">
          <span class="arca-page-header__eyebrow">Facturación Electrónica</span>
          <h1 class="arca-page-header__title">ARCA</h1>
          <p class="arca-page-header__sub">Emisión desde facturas del mostrador · módulo paralelo (no toca stock)</p>
        </div>
        <div class="arca-controls" style="flex-wrap:wrap;gap:8px;">
          <!-- Filtro de día -->
          <div style="display:flex;align-items:center;gap:6px;">
            <label for="arcaFechaFiltro" class="arca-muted" style="font-size:13px;white-space:nowrap">Día:</label>
            <input type="date" id="arcaFechaFiltro" class="arca-input" style="width:150px" />
            <button id="arcaVerTodo" class="arca-btn arca-btn--outline" title="Ver todos los días">Todos</button>
          </div>
          <input id="arcaSearch" class="arca-input" placeholder="Buscar por ID o vendedor…" />
          <button id="arcaReload" class="arca-btn arca-btn--outline">
            <i class="fa-solid fa-rotate-right"></i> Recargar
          </button>
        </div>
      </div>

      <!-- GRID PRINCIPAL -->
      <div class="arca-grid">

        <!-- LISTA -->
        <section class="arca-panel">
          <div class="arca-panel__hd">
            <strong id="arcaListTitle">Facturas del día</strong>
            <div class="arca-controls">
              <button id="arcaPrev" class="arca-btn arca-btn--icon">‹</button>
              <span id="arcaPage" class="arca-muted">0–0</span>
              <button id="arcaNext" class="arca-btn arca-btn--icon">›</button>
            </div>
          </div>
          <div class="arca-table-wrap">
            <table class="arca-tabla">
              <thead>
                <tr>
                  <th style="width:80px">ID</th>
                  <th style="width:108px">Fecha</th>
                  <th>Vendedor</th>
                  <th>Cliente</th>
                  <th style="width:65px">Tipo</th>
                  <th style="width:110px">Total</th>
                  <th style="width:110px">Pago</th>
                  <th style="width:160px">ARCA</th>
                </tr>
              </thead>
              <tbody id="arcaTbody">
                <tr><td colspan="8" class="arca-muted">Cargando…</td></tr>
              </tbody>
            </table>
          </div>
        </section>

        <!-- DETALLE -->
        <aside class="arca-panel">
          <div class="arca-panel__hd">
            <strong>Detalle</strong>
            <div class="arca-controls">
              <a id="btnPDF" class="arca-btn arca-btn--outline" href="#" target="_blank" style="display:none">
                <i class="fa-solid fa-file-pdf"></i> PDF
              </a>
              <button id="btnAnular" class="arca-btn arca-btn--danger" disabled>Anular (NC)</button>
              <button id="btnEmitir" class="arca-btn arca-btn--primary" disabled>Emitir ARCA</button>
            </div>
          </div>
          <div class="arca-panel__bd">
            <div id="arcaEmpty" class="arca-empty">
              <i class="fa-solid fa-file-invoice arca-empty__icon"></i>
              <p>Seleccioná una factura del listado.</p>
            </div>

            <div id="arcaDetail" style="display:none">
              <div class="arca-kv">
                <div class="arca-k">Factura ID</div><div class="arca-v" id="dId">-</div>
                <div class="arca-k">Fecha</div><div class="arca-v" id="dFecha">-</div>
                <div class="arca-k">Vendedor</div><div class="arca-v" id="dVend">-</div>
                <div class="arca-k">Pago</div><div class="arca-v" id="dPago">-</div>
                <div class="arca-k">Total</div><div class="arca-v" id="dTotal">-</div>
              </div>

              <div class="arca-hr"></div>

              <div class="arca-section-row">
                <strong class="arca-section-label">Auditoría WSFE</strong>
                <div class="arca-controls">
                  <span id="wsfeBadge" class="arca-badge" style="display:none">—</span>
                  <button id="btnAuditarWsfe" class="arca-btn arca-btn--outline arca-btn--sm" disabled>Auditar WSFE</button>
                </div>
              </div>
              <div id="wsfeHist" class="arca-hist" style="margin-top:8px"></div>

              <div class="arca-hr"></div>

              <strong class="arca-section-label">Items</strong>
              <table class="arca-tabla arca-tabla--items" style="margin-top:8px">
                <thead>
                  <tr>
                    <th>Descripción</th>
                    <th style="width:80px;text-align:right">Cant</th>
                    <th style="width:120px;text-align:right">Unitario</th>
                    <th style="width:120px;text-align:right">Subtotal</th>
                  </tr>
                </thead>
                <tbody id="itemsTbody"></tbody>
              </table>

              <div class="arca-hr"></div>

              <strong class="arca-section-label">Historial ARCA</strong>
              <div id="arcaHist" class="arca-hist" style="margin-top:8px"></div>
            </div>
          </div>
        </aside>
      </div>

      <!-- REPORTES Y CIERRES -->
      <div class="arca-panel" style="margin-top:16px">
        <div class="arca-panel__hd">
          <div>
            <span class="arca-eyebrow">Control</span>
            <strong style="display:block;font-size:15px;margin-top:2px">Reportes y cierres</strong>
          </div>
        </div>

        <!-- Reportes -->
        <div class="arca-rep-row">
          <div class="arca-field">
            <label class="arca-label">Desde</label>
            <input type="date" id="repDesde" class="arca-input">
          </div>
          <div class="arca-field">
            <label class="arca-label">Hasta</label>
            <input type="date" id="repHasta" class="arca-input">
          </div>
          <div class="arca-field">
            <label class="arca-label">Tipo</label>
            <select id="repTipo" class="arca-input">
              <option value="">Todos</option>
              <option value="1">Factura A</option>
              <option value="6">Factura B</option>
              <option value="3">Nota de Crédito A</option>
              <option value="8">Nota de Crédito B</option>
            </select>
          </div>
          <div class="arca-field">
            <label class="arca-label">Estado</label>
            <select id="repEstado" class="arca-input">
              <option value="">Todos</option>
              <option value="EMITIDO">EMITIDO</option>
              <option value="RECHAZADO">RECHAZADO</option>
              <option value="PENDIENTE">PENDIENTE</option>
            </select>
          </div>
          <div class="arca-rep-actions">
            <button class="arca-btn arca-btn--outline" id="btnRepResumen">Ver resumen</button>
            <button class="arca-btn arca-btn--primary" id="btnRepListar">Listar comprobantes</button>
            <button class="arca-btn arca-btn--outline" id="btnRepPdf">
              <i class="fa-solid fa-file-pdf"></i> PDF del período
            </button>
          </div>
        </div>

        <!-- Cierre diario -->
        <div class="arca-rep-row arca-rep-row--danger">
          <div class="arca-field">
            <label class="arca-label">Fecha de cierre</label>
            <input type="date" id="cierreFecha" class="arca-input">
          </div>
          <div class="arca-rep-actions">
            <button class="arca-btn arca-btn--danger" id="btnCierre">
              <i class="fa-solid fa-lock"></i> Crear cierre diario
            </button>
            <button type="button" id="btnInformePdf" class="arca-btn arca-btn--outline">
              <i class="fa-solid fa-file-pdf"></i> Informe PDF del día
            </button>
          </div>
        </div>

        <p class="arca-hint">El cierre diario guarda un snapshot interno (no se informa a ARCA). Sirve para control y conciliación.</p>

        <div class="arca-gtable" id="tblResumen"></div>
        <div class="arca-gtable" id="tblComprobantes" style="margin-top:10px"></div>
      </div>

    </div>
  </main>

  <%- include('../layouts/footer') %>
  <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
  <script src="/js/arca/index.js?v=20260221_1"></script>
</body>
</html>
