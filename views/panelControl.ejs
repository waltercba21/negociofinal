<% var pageCss = '/css/pages/panelControl.css' %>
<!DOCTYPE html>
<html lang="es">
<%- include('./layouts/head.ejs') %>
<link rel="stylesheet" href="/css/pages/panelControl.css?v=1" />
<style>
/* ── Tabla modo proveedor ── */
.prov-table-wrap {
  width: 100%;
  overflow-x: auto;
  border-radius: 10px;
  border: 1px solid var(--border, #e2e8f0);
}
.prov-table {
  width: 100%;
  border-collapse: collapse;
  font-size: 0.82rem;
  min-width: 780px;
}
.prov-th {
  background: var(--bg-panel-hd, #f8fafc);
  color: var(--text-muted, #64748b);
  font-weight: 600;
  text-transform: uppercase;
  font-size: 0.72rem;
  letter-spacing: 0.04em;
  padding: 10px 12px;
  border-bottom: 2px solid var(--border, #e2e8f0);
  white-space: nowrap;
}
.prov-th--num  { text-align: right; }
.prov-th--chk  { width: 36px; text-align: center; }
.prov-th--acc  { text-align: center; width: 90px; }
.prov-th--highlight { color: var(--color-warning, #d97706); }
.prov-th--venta     { color: var(--color-success, #16a34a); }

.prov-row {
  border-bottom: 1px solid var(--border-light, #f1f5f9);
  transition: background 0.12s;
}
.prov-row:last-child { border-bottom: none; }
.prov-row:hover { background: var(--bg-hover, #f8fafc); }

.prov-td {
  padding: 9px 12px;
  vertical-align: middle;
  color: var(--text-main, #1e293b);
}
.prov-td--num    { text-align: right; font-variant-numeric: tabular-nums; white-space: nowrap; }
.prov-td--chk    { text-align: center; }
.prov-td--acc    { text-align: center; }
.prov-td--nombre { font-weight: 500; max-width: 260px; }
.prov-td--cat    { max-width: 130px; }

.prov-td--highlight {
  font-weight: 700;
  color: var(--color-warning, #b45309);
  background: rgba(251,191,36,0.06);
}
.prov-td--venta {
  font-weight: 700;
  color: var(--color-success, #15803d);
  background: rgba(22,163,74,0.06);
}

.prov-badge-cat {
  display: inline-block;
  background: var(--bg-badge, #e0e7ef);
  color: var(--text-muted, #475569);
  border-radius: 4px;
  padding: 2px 7px;
  font-size: 0.72rem;
  font-weight: 600;
  white-space: nowrap;
  max-width: 120px;
  overflow: hidden;
  text-overflow: ellipsis;
}
.prov-desc { color: #dc2626; font-weight: 600; }
.prov-iva  { color: #7c3aed; font-weight: 600; }
.prov-util { color: #2563eb; font-weight: 600; }
.prov-nd   { color: #cbd5e1; }

.btn-edit--sm { font-size: 0.78rem; padding: 4px 10px; }
</style>
<body>
<%- include('./layouts/header.ejs') %>

<main class="pc-main">
  <div class="pc-wrap">

    <!-- PAGE HEADER -->
    <div class="pc-page-header">
      <div>
        <span class="pc-eyebrow">Administración</span>
        <h1 class="pc-title">Panel de Control</h1>
      </div>
      <a href="/productos/crear" class="pc-btn pc-btn--primary">
        <i class="fas fa-plus"></i> Nuevo producto
      </a>
    </div>

    <!-- TOP GRID: acciones + reportes -->
    <div class="pc-top-grid">

      <!-- ── ACCIONES ── -->
      <div class="pc-panel pc-panel--acciones">
        <div class="pc-panel__hd">
          <i class="fa-solid fa-bolt"></i>
          <strong>Acciones rápidas</strong>
        </div>
        <div class="pc-panel__bd">

          <details class="pc-accion">
            <summary class="pc-accion__summary pc-accion__summary--blue">
              <div class="pc-accion__left">
                <i class="fa-solid fa-cart-flatbed"></i>
                <div>
                  <span class="pc-accion__title">Pedido a proveedor</span>
                  <span class="pc-accion__sub">Nuevo pedido / Historial</span>
                </div>
              </div>
              <i class="fa-solid fa-chevron-down pc-accion__caret"></i>
            </summary>
            <div class="pc-accion__body">
              <a href="/productos/generarPedidoManual" class="pc-btn pc-btn--outline pc-btn--sm pc-btn--full">
                <i class="fa-solid fa-plus"></i> Realizar pedido
              </a>
              <a href="/productos/historialPedidos" class="pc-btn pc-btn--ghost pc-btn--sm pc-btn--full">
                <i class="fa-solid fa-clock-rotate-left"></i> Historial de pedidos
              </a>
            </div>
          </details>

          <details class="pc-accion">
            <summary class="pc-accion__summary pc-accion__summary--green">
              <div class="pc-accion__left">
                <i class="fa-solid fa-chart-line"></i>
                <div>
                  <span class="pc-accion__title">Ventas</span>
                  <span class="pc-accion__sub">Más vendidos / Recomendación</span>
                </div>
              </div>
              <i class="fa-solid fa-chevron-down pc-accion__caret"></i>
            </summary>
            <div class="pc-accion__body">
              <a href="/productos/masVendidos" class="pc-btn pc-btn--outline pc-btn--sm pc-btn--full">
                <i class="fa-solid fa-trophy"></i> Productos más vendidos
              </a>
              <a href="/productos/recomendacionesProveedor" class="pc-btn pc-btn--ghost pc-btn--sm pc-btn--full">
                <i class="fa-solid fa-star"></i> Recomendación de pedido
              </a>
            </div>
          </details>

        </div>
      </div>

      <!-- ── REPORTES / IMPORTACIÓN ── -->
      <div class="pc-panel pc-panel--reportes">
        <div class="pc-panel__hd">
          <i class="fa-solid fa-file-chart-column"></i>
          <strong>Reportes e importación</strong>
          <span class="pc-panel__hd-sub">Los filtros impactan en: Lista de precios, Stock proveedor y Actualización por Excel.</span>
        </div>
        <div class="pc-panel__bd">

          <!-- Filtros globales -->
          <div class="pc-filtros">
            <div class="pc-field">
              <label class="pc-label" for="filtroProveedor">Proveedor</label>
              <select id="filtroProveedor" class="pc-select">
                <option value="TODOS" <%= (!proveedorSeleccionado || String(proveedorSeleccionado) === 'TODOS') ? 'selected' : '' %>>
                  Todos los proveedores
                </option>
                <% proveedores.forEach(proveedor => { %>
                  <option value="<%= proveedor.id %>" <%= String(proveedor.id) === String(proveedorSeleccionado) ? 'selected' : '' %>>
                    <%= proveedor.nombre %>
                  </option>
                <% }); %>
              </select>
            </div>
            <div class="pc-field">
              <label class="pc-label" for="filtroCategoria">Categoría</label>
              <select id="filtroCategoria" class="pc-select">
                <option value="" <%= (!categoriaSeleccionada || String(categoriaSeleccionada) === '' || String(categoriaSeleccionada) === 'TODAS') ? 'selected' : '' %>>
                  Todas las categorías
                </option>
                <% categorias.forEach(categoria => { %>
                  <option value="<%= categoria.id %>" <%= String(categoria.id) === String(categoriaSeleccionada) ? 'selected' : '' %>>
                    <%= categoria.nombre %>
                  </option>
                <% }); %>
              </select>
            </div>
          </div>

          <!-- Cards de reportes -->
          <div class="pc-rep-grid">

            <div class="pc-rep-card">
              <div class="pc-rep-card__icon"><i class="fa-solid fa-file-pdf"></i></div>
              <div class="pc-rep-card__info">
                <strong>Lista de precios</strong>
                <span>PDF por proveedor/categoría</span>
              </div>
              <form method="get" action="/productos/generarPDF" id="form-lista-precios" class="pc-rep-card__action">
                <input type="hidden" name="proveedor" class="inp-proveedor-global">
                <input type="hidden" name="categoria" class="inp-categoria-global">
                <button type="submit" class="pc-btn pc-btn--outline pc-btn--sm">Generar</button>
              </form>
            </div>

            <div class="pc-rep-card">
              <div class="pc-rep-card__icon pc-rep-card__icon--green"><i class="fa-solid fa-file-excel"></i></div>
              <div class="pc-rep-card__info">
                <strong>Actualizar precios</strong>
                <span>Subir lista Excel</span>
              </div>
              <form method="post" action="/productos/actualizarPreciosExcel" enctype="multipart/form-data" id="form-actualizar-excel" class="pc-rep-card__action">
                <input type="hidden" name="proveedor" class="inp-proveedor-global">
                <label class="pc-file-label">
                  <i class="fa-solid fa-upload"></i>
                  <input type="file" id="archivo" name="archivos[]" accept=".xlsx,.xls" class="pc-file-input">
                  <span id="pc-file-name">Elegir archivo</span>
                </label>
                <button type="submit" class="pc-btn pc-btn--outline pc-btn--sm">Actualizar</button>
              </form>
            </div>

            <div class="pc-rep-card pc-rep-card--full">
              <div class="pc-rep-card__icon pc-rep-card__icon--yellow"><i class="fa-solid fa-warehouse"></i></div>
              <div class="pc-rep-card__info">
                <strong>Stock proveedor</strong>
                <span>PDF con opciones de reporte</span>
              </div>
              <form method="get" action="/productos/generarPDFProveedor" id="form-pdf-stock-proveedor" class="pc-rep-card__form">
                <input type="hidden" name="proveedor" class="inp-proveedor-global">
                <input type="hidden" name="categoria" class="inp-categoria-global">
                <div class="pc-radio-grid">
                  <label class="pc-radio"><input type="radio" name="tipo" value="stock" checked> Stock completo</label>
                  <label class="pc-radio"><input type="radio" name="tipo" value="asignadoCompleto"> Asignados al proveedor (con categoría)</label>
                  <label class="pc-radio"><input type="radio" name="tipo" value="asignado"> Faltantes del proveedor asignado</label>
                  <label class="pc-radio"><input type="radio" name="tipo" value="pedido"> Faltantes del proveedor más barato</label>
                  <label class="pc-radio"><input type="radio" name="tipo" value="porCategoria"> Listado por categoría</label>
                  <label class="pc-radio"><input type="radio" name="tipo" value="categoriaProveedorMasBarato"> Proveedor más barato por categoría</label>
                </div>
                <button type="submit" class="pc-btn pc-btn--outline pc-btn--sm">Generar PDF</button>
              </form>
            </div>

            <div class="pc-rep-card">
              <div class="pc-rep-card__icon pc-rep-card__icon--purple"><i class="fa-solid fa-pen-to-square"></i></div>
              <div class="pc-rep-card__info">
                <strong>Edición por proveedor</strong>
                <span>Ajustes manuales sin Excel</span>
              </div>
              <div class="pc-rep-card__action">
                <a href="/productos/modificarPorProveedor" class="pc-btn pc-btn--outline pc-btn--sm">Abrir</a>
              </div>
            </div>

          </div>
        </div>
      </div>
    </div>

    <!-- ── BUSCADOR + PAGINACIÓN + LISTADO ── -->
    <div class="pc-panel pc-panel--listado">
      <div class="pc-panel__hd">
        <i class="fa-solid fa-boxes-stacked"></i>
        <strong>Productos</strong>
      </div>
      <div class="pc-panel__bd">

        <!-- Buscador -->
        <div class="pc-search-row">
          <div class="pc-search-wrap">
            <i class="fa-solid fa-magnifying-glass pc-search-icon"></i>
            <input
              type="text"
              id="entradaBusqueda"
              autocomplete="off"
              placeholder="Buscar producto... Ej: Escort, Óptica, Faro, Agile"
              class="pc-search-input"
            />
          </div>
        </div>

        <!-- Paginación -->
        <%
          const qs = [];
          if (proveedorSeleccionado && String(proveedorSeleccionado) !== 'TODOS') qs.push('proveedor=' + encodeURIComponent(String(proveedorSeleccionado)));
          if (categoriaSeleccionada && String(categoriaSeleccionada) !== '' && String(categoriaSeleccionada) !== 'TODAS') qs.push('categoria=' + encodeURIComponent(String(categoriaSeleccionada)));
          if (busquedaActual) qs.push('busqueda=' + encodeURIComponent(String(busquedaActual)));
          const extraQuery = qs.length ? '&' + qs.join('&') : '';
        %>
        <div class="pc-paginacion">
          <% if (paginaActual > 1) { %>
            <a href="?pagina=<%= paginaActual - 1 %><%= extraQuery %>" class="pc-page-btn">‹</a>
          <% } %>
          <% if (paginaActual > 10) { %>
            <a href="?pagina=1<%= extraQuery %>" class="pc-page-btn">1</a>
            <span class="pc-page-dots">…</span>
          <% } %>
          <% for (let i = Math.max(1, paginaActual - 1); i <= Math.min(paginaActual + 10, numeroDePaginas); i++) { %>
            <% if (paginaActual === i) { %>
              <span class="pc-page-btn pc-page-btn--active"><%= i %></span>
            <% } else { %>
              <a href="?pagina=<%= i %><%= extraQuery %>" class="pc-page-btn"><%= i %></a>
            <% } %>
          <% } %>
          <% if (paginaActual < numeroDePaginas - 1) { %>
            <span class="pc-page-dots">…</span>
            <a href="?pagina=<%= numeroDePaginas %><%= extraQuery %>" class="pc-page-btn"><%= numeroDePaginas %></a>
          <% } %>
          <% if (paginaActual < numeroDePaginas) { %>
            <a href="?pagina=<%= paginaActual + 1 %><%= extraQuery %>" class="pc-page-btn">›</a>
          <% } %>
        </div>

        <!-- Listado -->
        <div class="panel-container">
          <% if (productos && productos.length > 0) { %>
            <% const modoProveedor = !!(proveedorSeleccionado && String(proveedorSeleccionado) !== 'TODOS'); %>

            <% if (modoProveedor) { %>
            <!-- ── Tabla modo proveedor ── -->
            <div class="prov-table-wrap">
              <table class="prov-table">
                <thead>
                  <tr>
                    <th class="prov-th prov-th--chk"><input type="checkbox" id="check-all" title="Seleccionar todos"/></th>
                    <th class="prov-th">Categoría</th>
                    <th class="prov-th">Producto</th>
                    <th class="prov-th prov-th--num">Precio lista</th>
                    <th class="prov-th prov-th--num">Desc. %</th>
                    <th class="prov-th prov-th--num">IVA %</th>
                    <th class="prov-th prov-th--num prov-th--highlight">Costo c/IVA</th>
                    <th class="prov-th prov-th--num">Utilidad %</th>
                    <th class="prov-th prov-th--num prov-th--venta">Precio venta</th>
                    <th class="prov-th prov-th--acc">Acciones</th>
                  </tr>
                </thead>
                <tbody>
                  <% productos.forEach(producto => {
                    const lista   = Number(producto.prov_precio_lista || 0);
                    const desc    = Number(producto.prov_descuento || 0);
                    const iva     = Number(producto.prov_iva || 21);
                    const costoIva = Number(producto.prov_costo_iva || 0);
                    const util    = Number(producto.utilidad || 0);
                    const pv      = Number(producto.precio_venta || 0);
                    const editUrl = '/productos/editar/' + producto.id
                      + '?pagina=' + paginaActual
                      + (busquedaActual ? '&busqueda=' + encodeURIComponent(String(busquedaActual)) : '')
                      + (proveedorSeleccionado ? '&proveedor=' + encodeURIComponent(String(proveedorSeleccionado)) : '')
                      + (categoriaSeleccionada ? '&categoria=' + encodeURIComponent(String(categoriaSeleccionada)) : '');
                  %>
                  <tr class="prov-row">
                    <td class="prov-td prov-td--chk">
                      <input type="checkbox" class="product-check" value="<%= producto.id %>" />
                    </td>
                    <td class="prov-td prov-td--cat"><span class="prov-badge-cat"><%= producto.categoria %></span></td>
                    <td class="prov-td prov-td--nombre"><%= producto.nombre %></td>
                    <td class="prov-td prov-td--num">
                      <% if (lista > 0) { %>$<%= lista.toLocaleString('es-AR') %><% } else { %><span class="prov-nd">—</span><% } %>
                    </td>
                    <td class="prov-td prov-td--num">
                      <% if (desc > 0) { %><span class="prov-desc"><%= desc %>%</span><% } else { %><span class="prov-nd">—</span><% } %>
                    </td>
                    <td class="prov-td prov-td--num"><span class="prov-iva"><%= iva %>%</span></td>
                    <td class="prov-td prov-td--num prov-td--highlight">
                      <% if (costoIva > 0) { %>$<%= costoIva.toLocaleString('es-AR') %><% } else { %><span class="prov-nd">—</span><% } %>
                    </td>
                    <td class="prov-td prov-td--num">
                      <% if (util > 0) { %><span class="prov-util"><%= util %>%</span><% } else { %><span class="prov-nd">—</span><% } %>
                    </td>
                    <td class="prov-td prov-td--num prov-td--venta">
                      <% if (pv > 0) { %>$<%= Math.round(pv).toLocaleString('es-AR') %><% } else { %><span class="prov-nd">—</span><% } %>
                    </td>
                    <td class="prov-td prov-td--acc">
                      <a class="btn-edit btn-edit--sm" href="<%= editUrl %>"><i class="fas fa-edit"></i> Editar</a>
                    </td>
                  </tr>
                  <% }); %>
                </tbody>
              </table>
            </div>

            <% } else { %>
            <!-- ── Listado general (sin filtro de proveedor) ── -->
            <div class="panel-header">
              <div class="panel-col panel-col-small">✔</div>
              <div class="panel-col">Categoría</div>
              <div class="panel-col">Nombre</div>
              <div class="panel-col">Imagen</div>
              <div class="panel-col">Precio venta</div>
              <div class="panel-col">Acciones</div>
            </div>
            <% productos.forEach(producto => { %>
              <div class="panel-row">
                <div class="panel-col panel-col-small">
                  <input type="checkbox" class="product-check" value="<%= producto.id %>" />
                </div>
                <div class="panel-text-small-bold"><%= producto.categoria %></div>
                <div class="panel-text-small-bold"><%= producto.nombre %></div>
                <div class="panel-col">
                  <% if (producto.imagenes && producto.imagenes.length > 0) { %>
                    <div class="panel-image-container">
                      <img src="/uploads/productos/<%= producto.imagenes[0] %>" alt="<%= producto.nombre %>" class="product-image" />
                    </div>
                  <% } else { %>
                    <div class="panel-image-container">
                      <span class="no-image"><i class="fa-solid fa-image-slash"></i></span>
                    </div>
                  <% } %>
                </div>
                <div class="panel-col panel-price">
                  $<%= parseInt(producto.precio_venta).toLocaleString('es-AR') %>
                </div>
                <div class="panel-col">
                  <a class="btn-edit" href="/productos/editar/<%= producto.id %>?pagina=<%= paginaActual %><%= busquedaActual ? '&busqueda=' + encodeURIComponent(String(busquedaActual)) : '' %><%= (proveedorSeleccionado && String(proveedorSeleccionado) !== 'TODOS') ? '&proveedor=' + encodeURIComponent(String(proveedorSeleccionado)) : '' %><%= (categoriaSeleccionada && String(categoriaSeleccionada) !== '' && String(categoriaSeleccionada) !== 'TODAS') ? '&categoria=' + encodeURIComponent(String(categoriaSeleccionada)) : '' %>">
                    <i class="fas fa-edit"></i> Editar
                  </a>
                </div>
              </div>
            <% }); %>
            <% } %>
          <% } else { %>
            <div class="panel-alert">
              <i class="fa-solid fa-circle-info"></i> No hay productos para mostrar.
            </div>
          <% } %>
          <div class="panel-actions">
            <button id="delete-selected" class="pc-btn pc-btn--danger pc-btn--sm" type="button">
              <i class="fa-solid fa-trash"></i> Eliminar seleccionados
            </button>
          </div>
        </div>

      </div>
    </div>

  </div>
</main>

<%- include('./layouts/footer.ejs') %>
<script src="/js/pages/panelControl.js?v=2"></script>
<script id="productos-data" type="application/json"><%- JSON.stringify(productos) %></script>
<script>
// Modo proveedor: true cuando hay un proveedor seleccionado
window.PANEL_MODO_PROVEEDOR = <%- JSON.stringify(!!(proveedorSeleccionado && String(proveedorSeleccionado) !== 'TODOS')) %>;

// File input label
document.getElementById('archivo')?.addEventListener('change', function() {
  const name = this.files[0]?.name || 'Elegir archivo';
  document.getElementById('pc-file-name').textContent = name;
});
</script>
</body>
</html>
