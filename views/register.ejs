<% var pageCss = '/css/pages/auth.css' %>
<!DOCTYPE html>
<html lang="es">
<%- include('./layouts/head.ejs') %>
<link rel="stylesheet" href="/css/pages/auth.css?v=1" />
<body class="auth-body">

  <main class="auth-main">

    <div class="auth-card auth-card--wide">

      <!-- LOGO / BRAND -->
      <div class="auth-brand">
        <a href="/" class="auth-brand__logo">
          <img src="/img/logo.png" alt="AutoFaros" onerror="this.style.display='none'" />
          <span class="auth-brand__name">Auto<span class="auth-brand__accent">Faros</span></span>
        </a>
        <p class="auth-brand__tagline">Iluminación automotriz · Córdoba</p>
      </div>

      <div class="auth-divider"></div>

      <h1 class="auth-title">Crear cuenta</h1>
      <p class="auth-sub">Completá tus datos para registrarte</p>

      <form action="./register" method="post" class="auth-form auth-form--grid" autocomplete="off" onsubmit="return validarFormulario()">

        <div class="auth-field">
          <label class="auth-label" for="nombre">Nombre</label>
          <div class="auth-input-wrap">
            <i class="fa-solid fa-user auth-input-icon"></i>
            <input type="text" name="nombre" id="nombre" placeholder="Tu nombre" class="auth-input"
              value="<%= locals.oldData ? oldData.nombre : '' %>">
          </div>
        </div>

        <div class="auth-field">
          <label class="auth-label" for="apellido">Apellido</label>
          <div class="auth-input-wrap">
            <i class="fa-solid fa-user auth-input-icon"></i>
            <input type="text" name="apellido" id="apellido" placeholder="Tu apellido" class="auth-input"
              value="<%= locals.oldData ? oldData.apellido : '' %>">
          </div>
        </div>

        <div class="auth-field auth-field--full">
          <label class="auth-label" for="email">Email</label>
          <div class="auth-input-wrap">
            <i class="fa-solid fa-envelope auth-input-icon"></i>
            <input type="text" name="email" id="email" placeholder="tu@email.com" class="auth-input"
              value="<%= locals.oldData ? oldData.email : '' %>">
          </div>
        </div>

        <div class="auth-field">
          <label class="auth-label" for="provincia">Provincia</label>
          <div class="auth-input-wrap">
            <i class="fa-solid fa-map-location-dot auth-input-icon"></i>
            <select id="provincia" name="provincia" required class="auth-input auth-select">
              <option value="">Seleccioná una provincia</option>
            </select>
          </div>
        </div>

        <div class="auth-field">
          <label class="auth-label" for="localidad">Localidad</label>
          <div class="auth-input-wrap">
            <i class="fa-solid fa-location-dot auth-input-icon"></i>
            <select id="localidad" name="localidad" required class="auth-input auth-select">
              <option value="">Seleccioná una localidad</option>
            </select>
          </div>
        </div>

        <div class="auth-field">
          <label class="auth-label" for="password-input">Contraseña</label>
          <div class="auth-input-wrap">
            <i class="fa-solid fa-lock auth-input-icon"></i>
            <input type="password" name="password" id="password-input" placeholder="••••••••" class="auth-input" required>
            <button type="button" id="eye-icon" class="auth-eye-btn" tabindex="-1">
              <i class="fas fa-eye"></i>
            </button>
          </div>
          <small id="password-tooltip" class="auth-hint" style="display:none;">
            Mínimo 8 caracteres, 1 mayúscula y 1 número.
          </small>
        </div>

        <div class="auth-field">
          <label class="auth-label" for="confirmar_password">Confirmar contraseña</label>
          <div class="auth-input-wrap">
            <i class="fa-solid fa-lock auth-input-icon"></i>
            <input type="password" name="confirmar_password" id="confirmar_password" placeholder="••••••••" class="auth-input" required>
          </div>
        </div>

        <div class="auth-field">
          <label class="auth-label" for="celular">Teléfono</label>
          <div class="auth-input-wrap">
            <i class="fa-solid fa-phone auth-input-icon"></i>
            <input type="text" name="celular" id="celular" placeholder="Ej: 351 123 4567" class="auth-input"
              value="<%= locals.oldData ? oldData.celular : '' %>">
          </div>
        </div>

        <div class="auth-field">
          <label class="auth-label" for="fecha_nacimiento">Fecha de nacimiento</label>
          <div class="auth-input-wrap">
            <i class="fa-solid fa-calendar auth-input-icon"></i>
            <input type="date" name="fecha_nacimiento" id="fecha_nacimiento" class="auth-input"
              value="<%= locals.oldData ? oldData.fecha_nacimiento : '' %>">
          </div>
        </div>

        <div class="auth-field auth-field--full">
          <label class="auth-label" for="direccion">Dirección</label>
          <div class="auth-input-wrap">
            <i class="fa-solid fa-house auth-input-icon"></i>
            <input type="text" name="direccion" id="direccion" placeholder="Calle y número" class="auth-input"
              value="<%= locals.oldData ? oldData.direccion : '' %>">
          </div>
        </div>

        <div class="auth-field auth-field--full">
          <label class="auth-check">
            <input type="checkbox" name="acepto_terminos"
              <%= locals.oldData && oldData.acepto_terminos ? 'checked' : '' %> required>
            <span>Acepto los <a href="/terminos" target="_blank" class="auth-link">términos y condiciones</a></span>
          </label>
        </div>

        <div class="auth-field auth-field--full auth-actions">
  <button type="submit" class="auth-btn auth-btn--primary">
    <i class="fa-solid fa-user-plus"></i> Crear cuenta
  </button>
  <a href="/" class="auth-btn auth-btn--outline">Cancelar</a>
</div>

        <p class="auth-footer-text auth-field--full">
          ¿Ya tenés cuenta? <a href="login" class="auth-link">Iniciá sesión</a>
        </p>

      </form>
    </div>

    <div class="auth-bg-orb auth-bg-orb--1"></div>
    <div class="auth-bg-orb auth-bg-orb--2"></div>
  </main>

  <%- include('./layouts/footer.ejs') %>
  <script src="/js/register.js"></script>
</body>
</html>
