<% var pageCss = '/css/pages/index.css' %>
<% var pageJs  = '/js/pages/index.js' %>
<!DOCTYPE html>
<html lang="es">
<%- include('./layouts/head.ejs') %>
<link rel="stylesheet" href="/css/pages/index.css" />

<body class="body-index">
  <%- include('./layouts/header.ejs') %>

  <main class="index-main" id="main-content">

    <!-- ═══════════════════════════════
         1. HERO
    ════════════════════════════════ -->
    <section class="hero-band">
      <div class="hero-band__grid">
        <div>
          <div class="hero-band__badge">
            <i class="fa-solid fa-bolt"></i> Iluminación Automotriz Premium
          </div>
          <h1 class="hero-band__title">Faros y Ópticas<br><em>para tu vehículo</em></h1>
          <p class="hero-band__sub">El mayor catálogo de iluminación automotriz en Córdoba.<br>LED, Xenón, Halógenas y más — con stock inmediato.</p>
          <div class="hero-band__actions">
            <a href="/productos" class="hero-btn hero-btn--primary"><i class="fa-solid fa-bolt"></i> Ver Productos</a>
            <a href="/productos/ofertas" class="hero-btn hero-btn--ghost"><i class="fa-solid fa-tag"></i> Ofertas del día</a>
          </div>
        </div>
        <div class="hero-stats">
          <div class="hero-stat"><span class="hero-stat__num">500<em>+</em></span><span class="hero-stat__label">Productos</span></div>
          <div class="hero-stat"><span class="hero-stat__num">10<em>+</em></span><span class="hero-stat__label">Años</span></div>
          <div class="hero-stat"><span class="hero-stat__num">CBA</span><span class="hero-stat__label">Argentina</span></div>
        </div>
      </div>
    </section>

    <!-- ═══════════════════════════════
         2. CATEGORÍAS — va PRIMERO
    ════════════════════════════════ -->
    <section class="cat-section">
      <div class="cat-section__header">
        <h2 class="cat-section__title"><span class="cat-section__title-accent">Explorá</span> nuestras categorías</h2>
        <a href="/productos" class="cat-section__ver-todo">Ver todo <i class="fa-solid fa-arrow-right"></i></a>
      </div>

      <!-- Wrapper relativo para que las flechas absolutas queden DENTRO -->
      <div class="cat-carousel-wrap">
        <button class="af-arrow af-arrow--prev" id="catArrowPrev" type="button" aria-label="Anterior">
          <i class="fa-solid fa-chevron-left"></i>
        </button>

        <div class="cat-track-outer">
          <div class="cat-track" id="catTrack">

            <a class="cat-card" href="/productos?categoria=31">
              <div class="cat-card__img-wrap"><img src="/uploads/productos/faros-led1.webp" alt="Faros Aux LED" loading="lazy"></div>
              <div class="cat-card__label">Faros Aux LED</div>
            </a>
            <a class="cat-card" href="/productos?categoria=30">
              <div class="cat-card__img-wrap"><img src="/uploads/productos/faro-trasero-led1.webp" alt="Faros Traseros LED" loading="lazy"></div>
              <div class="cat-card__label">Faros Traseros LED</div>
            </a>
            <a class="cat-card" href="/productos?categoria=25">
              <div class="cat-card__img-wrap"><img src="/uploads/productos/opticas-led1.webp" alt="Ópticas LED" loading="lazy"></div>
              <div class="cat-card__label">Ópticas LED</div>
            </a>
            <a class="cat-card" href="/productos?categoria=28">
              <div class="cat-card__img-wrap"><img src="/uploads/productos/lamparas-led1.webp" alt="Lámparas LED" loading="lazy"></div>
              <div class="cat-card__label">Lámparas LED</div>
            </a>
            <a class="cat-card" href="/productos?categoria=2">
              <div class="cat-card__img-wrap"><img src="/uploads/productos/lamparas1.webp" alt="Halógenas" loading="lazy"></div>
              <div class="cat-card__label">Halógenas</div>
            </a>
            <a class="cat-card" href="/productos?categoria=15">
              <div class="cat-card__img-wrap"><img src="/uploads/productos/16.webp" alt="Faros Auxiliares" loading="lazy"></div>
              <div class="cat-card__label">Faros Auxiliares</div>
            </a>
            <a class="cat-card" href="/productos?categoria=16">
              <div class="cat-card__img-wrap"><img src="/uploads/productos/14.webp" alt="Barras LED" loading="lazy"></div>
              <div class="cat-card__label">Barras LED</div>
            </a>
            <a class="cat-card" href="/productos?categoria=5">
              <div class="cat-card__img-wrap"><img src="/uploads/productos/10.webp" alt="Faros LED" loading="lazy"></div>
              <div class="cat-card__label">Faros LED</div>
            </a>
            <a class="cat-card" href="/productos?categoria=12">
              <div class="cat-card__img-wrap"><img src="/uploads/productos/3.webp" alt="Línea Universal" loading="lazy"></div>
              <div class="cat-card__label">Línea Universal</div>
            </a>
            <a class="cat-card" href="/productos?categoria=13">
              <div class="cat-card__img-wrap"><img src="/uploads/productos/2.webp" alt="Xenon" loading="lazy"></div>
              <div class="cat-card__label">Xenon</div>
            </a>
            <a class="cat-card" href="/productos?categoria=9">
              <div class="cat-card__img-wrap"><img src="/uploads/productos/5.webp" alt="Espejos Univ." loading="lazy"></div>
              <div class="cat-card__label">Espejos Univ.</div>
            </a>
            <a class="cat-card" href="/productos?categoria=14">
              <div class="cat-card__img-wrap"><img src="/uploads/productos/6.webp" alt="Vidrios Espejos" loading="lazy"></div>
              <div class="cat-card__label">Vidrios Espejos</div>
            </a>
            <a class="cat-card" href="/productos?categoria=11">
              <div class="cat-card__img-wrap"><img src="/uploads/productos/4.webp" alt="Vidrios Ópticas" loading="lazy"></div>
              <div class="cat-card__label">Vidrios Ópticas</div>
            </a>

          </div>
        </div>

        <button class="af-arrow af-arrow--next" id="catArrowNext" type="button" aria-label="Siguiente">
          <i class="fa-solid fa-chevron-right"></i>
        </button>
      </div>
    </section>

    <!-- ═══════════════════════════════
         3. GRID: ÚLTIMOS + OFERTAS
    ════════════════════════════════ -->
    <div class="products-grid-layout">

      <!-- Últimos Agregados -->
      <section class="products-panel">
        <div class="products-panel__head">
          <span class="products-panel__badge products-panel__badge--nuevo"><i class="fa-solid fa-bolt"></i></span>
          <h2 class="products-panel__title">Últimos Agregados</h2>
          <a href="/productos" class="products-panel__link">Ver todos <i class="fa-solid fa-arrow-right"></i></a>
        </div>
        <div class="product-list">
          <% if (productos && productos.length > 0) { %>
            <% productos.forEach(function(p) { %>
              <a class="product-card" href="/productos/<%= p.id %>">
                <div class="product-card__img-wrap">
                  <% if (p.imagen && p.imagen.length > 0) { %>
                    <img class="product-card__img" src="/uploads/productos/<%= p.imagen[0] %>" alt="<%= p.nombre %>" loading="lazy">
                  <% } else { %>
                    <div class="product-card__img product-card__img--placeholder"><i class="fa-solid fa-image"></i></div>
                  <% } %>
                </div>
                <div class="product-card__body">
                  <span class="product-card__categoria"><%= p.categoria_nombre %></span>
                  <h3 class="product-card__nombre"><%= p.nombre %></h3>
                  <p class="product-card__precio"><%= new Intl.NumberFormat('es-AR',{style:'currency',currency:'ARS',maximumFractionDigits:0}).format(p.precio_venta) %></p>
                </div>
              </a>
            <% }) %>
          <% } else { %>
            <div class="products-panel__empty"><i class="fa-solid fa-box-open"></i><p>No hay productos recientes.</p></div>
          <% } %>
        </div>
      </section>

      <!-- Ofertas -->
      <section class="products-panel products-panel--ofertas">
        <div class="products-panel__head">
          <span class="products-panel__badge products-panel__badge--oferta"><i class="fa-solid fa-tag"></i></span>
          <h2 class="products-panel__title">Ofertas</h2>
          <a href="/productos/ofertas" class="products-panel__link">Ver todas <i class="fa-solid fa-arrow-right"></i></a>
        </div>

        <%
          /* Solo mostrar el slider si hay ofertas */
          const hayOfertas = productosOferta && productosOferta.length > 0;
        %>

        <% if (hayOfertas) { %>
          <!-- Slider: viewport fijo + track que se traslada -->
          <div class="oferta-viewport" id="ofertasViewport">
            <div class="oferta-track" id="ofertasList">
              <% productosOferta.forEach(function(o) { %>
                <a class="oferta-card" href="/productos/<%= o.id %>">
                  <div class="oferta-card__img-wrap">
                    <span class="oferta-badge">OFERTA</span>
                    <% if (o.imagenes && o.imagenes.length > 0) { %>
                      <img src="/uploads/productos/<%= o.imagenes[0] %>" alt="<%= o.nombre %>" loading="lazy">
                    <% } else { %>
                      <div class="oferta-card__placeholder"><i class="fa-solid fa-image"></i></div>
                    <% } %>
                  </div>
                  <div class="oferta-card__body">
                    <span class="oferta-card__cat"><%= o.categoria_nombre %></span>
                    <h3 class="oferta-card__nombre"><%= o.nombre %></h3>
                    <p class="oferta-card__precio"><%= new Intl.NumberFormat('es-AR',{style:'currency',currency:'ARS',maximumFractionDigits:0}).format(o.precio_venta) %></p>
                  </div>
                </a>
              <% }) %>
            </div>
          </div>
          <!-- Controles: flechas + dots en línea horizontal -->
          <div class="oferta-nav">
            <button class="af-arrow af-arrow--sm" id="ofertaArrowPrev" type="button" aria-label="Anterior"><i class="fa-solid fa-chevron-left"></i></button>
            <div class="oferta-dots" id="ofertasDots"></div>
            <button class="af-arrow af-arrow--sm" id="ofertaArrowNext" type="button" aria-label="Siguiente"><i class="fa-solid fa-chevron-right"></i></button>
          </div>
        <% } else { %>
          <div class="products-panel__empty"><i class="fa-solid fa-tag"></i><p>Sin ofertas activas por ahora.</p></div>
        <% } %>

      </section>

    </div>

  </main>

  <script src="/js/pages/index.js" defer></script>
  <%- include('./layouts/footer.ejs') %>
</body>
</html>
