                    <label class="form-label">Tipo de documento</label>
                    <select id="cartaTipoDocumento" class="form-select" style="min-width:180px;">
                      <option value="factura">Facturas</option>
                      <option value="presupuesto">Presupuestos</option>
                    </select>
                  </div>
                  <button id="btnCargarDocumentos" class="btn btn-primary" style="height:40px;">
                    <i class="fa-solid fa-rotate"></i> Cargar documentos
                  </button>
                  <small class="text-muted ms-1" style="align-self:center;">Solo muestra documentos pendientes no asignados a otra carta.</small>
                </div>

                <div id="contenedorDocumentosDisponibles" class="cp-docs-grid mb-4">
                  <p class="cp-hint">Seleccioná un proveedor y hacé clic en <strong>Cargar documentos</strong>.</p>
                </div>

                <div class="cp-tabla-wrap">
                  <div class="cp-tabla-header">
                    <span>Documentos seleccionados para esta carta</span>
                    <span id="cartaTotalDocumentos" class="cp-tabla-total">$ 0,00</span>
                  </div>
                  <div class="table-responsive">
                    <table class="table table-sm align-middle" id="tablaDocumentosSeleccionados">
                      <thead>
                        <tr>
                          <th>Tipo</th>
                          <th>N° Documento</th>
                          <th>Fecha</th>
                          <th>Vencimiento</th>
