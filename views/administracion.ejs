              </div>
            </div>

            <div class="table-responsive">
              <table class="table table-sm align-middle" id="tablaHistorialCartas">
                <thead>
                  <tr>
                    <th>N° Carta</th>
                    <th>Fecha</th>
                    <th>Proveedor</th>
                    <th>Total Docs.</th>
                    <th>Total Pagado</th>
                    <th>Estado</th>
                    <th class="text-center">Acciones</th>
                  </tr>
                </thead>
                <tbody>
                  <tr>
                    <td colspan="7" class="text-center text-muted py-3">Aplicá un filtro para ver resultados.</td>
                  </tr>
                </tbody>
              </table>
            </div>
          </div>

          <div class="modal-footer">
            <button type="button" class="btn btn-outline-secondary" data-bs-dismiss="modal">Cerrar</button>
          </div>

        </div>
      </div>
    </div>

