                    </div>
                  </div>
                  <div id="alertaDiferencia" class="cp-alerta d-none"></div>
                </div>

              </div>
            </div>

          </div><!-- /modal-body -->

          <div class="modal-footer">
            <button type="button" class="btn btn-outline-secondary" data-bs-dismiss="modal">Cancelar</button>
            <button type="button" id="btnGuardarCartaPago" class="btn btn-success">
              <i class="fa-solid fa-floppy-disk"></i> Guardar Carta
