                          <th class="text-center">Quitar</th>
                        </tr>
                      </thead>
                      <tbody>
                        <tr id="tablaDocumentosPlaceholder">
                          <td colspan="6" class="text-center text-muted py-3">
                            <i class="fa-solid fa-inbox me-2"></i>Sin documentos seleccionados
                          </td>
                        </tr>
                      </tbody>
                    </table>
                  </div>
                </div>
              </div>
            </div>

            <!-- SECCIÓN 3: FORMA DE PAGO -->
            <div class="cp-section">
              <div class="cp-section__title">
                <span class="cp-section__num">3</span>
                Forma de pago
              </div>
              <div class="row g-3 p-3">

                <div class="col-md-4">
                  <label class="form-label"><i class="fa-solid fa-money-bill-wave me-1 text-success"></i> Efectivo</label>
