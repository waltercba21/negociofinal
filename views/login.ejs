<% var pageCss = '/css/pages/auth.css' %>
<!DOCTYPE html>
<html lang="es">
<%- include('./layouts/head.ejs') %>
<link rel="stylesheet" href="/css/pages/auth.css?v=1" />
<body class="auth-body">

  <main class="auth-main">

    <div class="auth-card">

      <!-- LOGO / BRAND -->
      <div class="auth-brand">
        <a href="/" class="auth-brand__logo">
          <img src="/img/logo.png" alt="AutoFaros" onerror="this.style.display='none'" />
          <span class="auth-brand__name">Auto<span class="auth-brand__accent">Faros</span></span>
        </a>
        <p class="auth-brand__tagline">Iluminación automotriz · Córdoba</p>
      </div>

      <div class="auth-divider"></div>

      <!-- FORM -->
      <h1 class="auth-title">Iniciar sesión</h1>
      <p class="auth-sub">Ingresá con tu cuenta para continuar</p>

      <form action="./login" method="post" class="auth-form">

        <div class="auth-field">
          <label class="auth-label" for="email">Email</label>
          <div class="auth-input-wrap">
            <i class="fa-solid fa-envelope auth-input-icon"></i>
            <input type="text" name="email" id="email" placeholder="tu@email.com" class="auth-input" autocomplete="email">
          </div>
          <% if (locals.errors && locals.errors.email) { %>
            <span class="auth-error"><i class="fa-solid fa-circle-exclamation"></i> <%= locals.errors.email.msg %></span>
          <% } %>
        </div>

        <div class="auth-field">
          <label class="auth-label" for="password">Contraseña</label>
          <div class="auth-input-wrap">
            <i class="fa-solid fa-lock auth-input-icon"></i>
            <input type="password" name="password" id="password" placeholder="••••••••" class="auth-input" autocomplete="current-password">
          </div>
          <% if (locals.errors && locals.errors.password) { %>
            <span class="auth-error"><i class="fa-solid fa-circle-exclamation"></i> <%= locals.errors.password.msg %></span>
          <% } %>
          <% if (locals.error) { %>
            <span class="auth-error"><i class="fa-solid fa-circle-exclamation"></i> <%= locals.error %></span>
          <% } %>
        </div>

        <button type="submit" class="auth-btn auth-btn--primary">
          <i class="fa-solid fa-arrow-right-to-bracket"></i> Ingresar
        </button>

        <p class="auth-footer-text">
          ¿No tenés cuenta? <a href="register" class="auth-link">Registrate</a>
        </p>

      </form>
    </div>

    <!-- Decoración de fondo -->
    <div class="auth-bg-orb auth-bg-orb--1"></div>
    <div class="auth-bg-orb auth-bg-orb--2"></div>
  </main>

  <%- include('./layouts/footer.ejs') %>
</body>
</html>
