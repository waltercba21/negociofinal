<% var pageCss = '/css/pages/lista.css' %>
<!DOCTYPE html>
<html lang="es">
<%- include('./layouts/head.ejs') %>
<link rel="stylesheet" href="/css/pages/lista.css" />
<body data-is-admin-user="<%= isAdminUser %>" data-is-user-logged-in="<%= isUserLoggedIn %>">

  <%- include('./layouts/header.ejs') %>

  <main class="lista-main">

    <!-- ══════════════════════════════════════
         HERO BUSCADOR
    ══════════════════════════════════════ -->
    <section class="busqueda-hero">
      <div class="busqueda-hero__inner">
        <div class="busqueda-hero__copy">
          <span class="busqueda-hero__eyebrow">
            <i class="fa-solid fa-magnifying-glass"></i> Catálogo de productos
          </span>
          <h1 class="busqueda-hero__title">Encontrá el repuesto<br><em>que necesitás</em></h1>
        </div>

        <!-- Buscador texto -->
        <div class="buscador-wrap">
          <div class="buscador-field">
            <i class="fa-solid fa-search buscador-field__icon"></i>
            <% const q = (typeof req !== 'undefined' && req.query && req.query.q) ? String(req.query.q) : ''; %>
            <input
              type="text"
              id="entradaBusqueda"
              autocomplete="off"
              placeholder="Ej: Escort, Óptica, Faro, Agile…"
              value="<%= q %>"
              class="buscador-field__input"
            />
            <button type="button" id="botonLimpiar" class="buscador-field__clear" aria-label="Limpiar búsqueda">
              <i class="fas fa-times"></i>
            </button>
          </div>
        </div>

        <!-- Selectores -->
        <form id="formulario-filtros" class="filtros-grid">
          <div class="filtro-item">
            <label class="filtro-label" for="categoria_id">
              <i class="fa-solid fa-tag"></i> Categoría
            </label>
            <div class="select-wrap">
              <select name="categoria" id="categoria_id" class="filtro-select">
                <option value="">Todas las categorías</option>
                <% categorias.forEach(function(categoria) { %>
                  <option value="<%= categoria.id %>" <%= categoriaSeleccionada === categoria.nombre ? 'selected' : '' %>>
                    <%= categoria.nombre %>
                  </option>
                <% }); %>
              </select>
              <i class="fa-solid fa-chevron-down select-arrow"></i>
            </div>
          </div>

          <div class="filtro-item">
            <label class="filtro-label" for="marca_id">
              <i class="fa-solid fa-car"></i> Marca
            </label>
            <div class="select-wrap">
              <select name="marca" id="marca_id" class="filtro-select">
                <option value="">Todas las marcas</option>
                <% marcas.forEach(function(marca) { %>
                  <option value="<%= marca.id %>" <%= modelo && modelo.marca_id === marca.id ? 'selected' : '' %>>
                    <%= marca.nombre %>
                  </option>
                <% }); %>
              </select>
              <i class="fa-solid fa-chevron-down select-arrow"></i>
            </div>
          </div>

          <div class="filtro-item">
            <label class="filtro-label" for="modelo_id">
              <i class="fa-solid fa-calendar-days"></i> Modelo / Año
            </label>
            <div class="select-wrap">
              <select name="modelo" id="modelo_id" class="filtro-select">
                <option value="">Todos los modelos</option>
                <% modelosPorMarca.forEach(function(modeloItem) { %>
                  <option value="<%= modeloItem.id %>" <%= modelo && modelo.id === modeloItem.id ? 'selected' : '' %>>
                    <%= modeloItem.nombre %>
                  </option>
                <% }); %>
              </select>
              <i class="fa-solid fa-chevron-down select-arrow"></i>
            </div>
          </div>
        </form>
      </div>
    </section>

    <!-- ══════════════════════════════════════
         GRID PRODUCTOS
    ══════════════════════════════════════ -->
    <section class="productos-section">
      <div id="contenedor-productos" class="productos-grid">

        <% if (productos && productos.length > 0) { %>
          <% productos.forEach(function(producto, index) { %>

            <%
              const esOferta = producto.oferta == 1;

              // Normalizar calidades: solo una puede ser activa (jerarquía: premium > mm > vic > fitam)
              const _fitam   = producto.calidad_original         == 1;
              const _vic     = producto.calidad_vic              == 1;
              const _mm      = producto.calidad_mm               == 1;
              const _premium = producto.calidad_original_premium == 1;
              const esPremium = _premium;
              const esMM      = !_premium && _mm;
              const esVic     = !_premium && !_mm && _vic;
              const esFitam   = !_premium && !_mm && !_vic && _fitam;

              const badges = [];
              if (esOferta)  badges.push({ label: 'OFERTA',           cls: 'badge--oferta'  });
              if (esFitam)   badges.push({ label: 'FITAM',            cls: 'badge--fitam'   });
              if (esVic)     badges.push({ label: 'VIC',              cls: 'badge--vic'     });
              if (esMM)      badges.push({ label: 'MAGNETTI MARELLI', cls: 'badge--mm'      });
              if (esPremium) badges.push({ label: '★ ORIGINAL',       cls: 'badge--premium' });

              const puedeComprar = (producto.stock_actual >= producto.stock_minimo) && (producto.stock_actual > 0);
              const descAplicSSR = (producto.descripcion || '').trim();
              const esEscobillaSSR = /escobill/i.test(producto.categoria_nombre || '') || /escobill/i.test(producto.nombre || '');
              const tieneAplicSSR  = esEscobillaSSR && descAplicSSR.length > 0;
            %>

            <article class="pcard
              <%= esOferta  ? 'pcard--oferta'  : '' %>
              <%= esFitam   ? 'pcard--fitam'   : '' %>
              <%= esVic     ? 'pcard--vic'     : '' %>
              <%= esMM      ? 'pcard--mm'      : '' %>
              <%= esPremium ? 'pcard--premium' : '' %>">

              <!-- Badges (múltiples) -->
              <% if (badges.length) { %>
                <div class="pcard__badges">
                  <% badges.forEach(function(b) { %>
                    <span class="pcard__badge <%= b.cls %>"><%= b.label %></span>
                  <% }); %>
                </div>
              <% } %>

              <!-- Imagen / Carousel -->
              <div class="pcard__media">
                <% if (producto.imagenes && producto.imagenes.length > 0) { %>
                  <div class="pcard__carousel" id="carousel-<%= index %>">
                    <% producto.imagenes.forEach(function(imagen, i) { %>
                      <img
                        class="pcard__img <%= i !== 0 ? 'hidden' : '' %>"
                        src="/uploads/productos/<%= imagen.imagen %>"
                        alt="<%= producto.nombre %>"
                        loading="lazy"
                      />
                    <% }); %>
                  </div>
                  <% if (producto.imagenes.length > 1) { %>
                    <button class="pcard__carousel-btn pcard__carousel-btn--prev" onclick="moverCarrusel('<%= index %>', -1)" aria-label="Imagen anterior">
                      <i class="fas fa-chevron-left"></i>
                    </button>
                    <button class="pcard__carousel-btn pcard__carousel-btn--next" onclick="moverCarrusel('<%= index %>', 1)" aria-label="Siguiente imagen">
                      <i class="fas fa-chevron-right"></i>
                    </button>
                    <div class="pcard__dots" id="dots-<%= index %>">
                      <% producto.imagenes.forEach(function(_, i) { %>
                        <span class="pcard__dot <%= i === 0 ? 'pcard__dot--active' : '' %>"></span>
                      <% }); %>
                    </div>
                  <% } %>
                <% } else { %>
                  <div class="pcard__carousel">
                    <img class="pcard__img" src="/images/noEncontrado.png" alt="<%= producto.nombre %>" />
                  </div>
                <% } %>
              </div>

              <!-- Info -->
              <div class="pcard__body">
                <span class="pcard__categoria"><%= producto.categoria_nombre || 'Sin categoría' %></span>
                <h3 class="pcard__nombre"><%= producto.nombre %></h3>

                <div class="pcard__precio-row">
                  <span class="pcard__precio">
                    $<%= new Intl.NumberFormat('es-AR').format(Math.floor(producto.precio_venta || 0)) %>
                  </span>
                  <% if (esOferta) { %>
                    <span class="pcard__precio-tag">
                      <i class="fa-solid fa-bolt"></i> Oferta
                    </span>
                  <% } %>
                </div>

                <!-- Aplicaciones (escobillas) -->
                <% if (tieneAplicSSR) { %>
                  <button type="button"
                    class="btn-aplicaciones"
                    data-titulo="<%= producto.nombre %>"
                    data-aplicaciones='<%- JSON.stringify(descAplicSSR) %>'>
                    <i class="fa-solid fa-car"></i>
                    <span>Ver aplicaciones</span>
                  </button>
                <% } %>

                <!-- Admin: Proveedor -->
                <% if (isAdminUser) { %>
                  <div class="pcard__admin">
                    <div class="pcard__admin-row">
                      <span class="pcard__admin-label">Proveedor</span>
                      <span class="prov-nombre pcard__admin-val" data-producto-id="<%= producto.id %>"><%= producto.proveedor_nombre || '—' %></span>
                    </div>
                    <div class="pcard__admin-row">
                      <span class="pcard__admin-label">Código</span>
                      <span class="prov-codigo pcard__admin-val" data-producto-id="<%= producto.id %>"><%= producto.codigo_proveedor || '—' %></span>
                    </div>
                    <div class="pcard__admin-row">
                      <span class="pcard__admin-label">Stock</span>
                      <span class="pcard__admin-val <%= producto.stock_actual < producto.stock_minimo ? 'stock--bajo' : 'stock--ok' %>">
                        <%= producto.stock_actual %>
                        <% if (producto.stock_actual < producto.stock_minimo) { %>
                          <i class="fa-solid fa-triangle-exclamation"></i>
                        <% } %>
                      </span>
                    </div>
                    <div class="prov-actions">
                      <button type="button" class="btn-ver-proveedores" data-producto-id="<%= producto.id %>">
                        <i class="fas fa-store"></i> Ver proveedores
                      </button>
                      <small class="prov-idx" data-producto-id="<%= producto.id %>"></small>
                    </div>
                  </div>
                <% } %>

                <!-- Stock semáforo (usuarios normales logueados) -->
                <% if (isUserLoggedIn && !isAdminUser) { %>
                  <div class="pcard__stock <%= puedeComprar ? 'pcard__stock--ok' : 'pcard__stock--bajo' %>">
                    <i class="fa-solid fa-circle pcard__stock-dot"></i>
                    <span class="pcard__stock-txt">
                      <%= puedeComprar ? 'Disponible para entrega inmediata' : 'A pedido / pendiente de ingreso' %>
                    </span>
                  </div>
                <% } %>

                <!-- Acciones -->
                <div class="pcard__actions">
                  <% if (isUserLoggedIn && !isAdminUser) { %>
                    <div class="pcard__qty-row">
                      <button type="button" class="qty-btn qty-btn--minus" aria-label="Restar">
                        <i class="fa-solid fa-minus"></i>
                      </button>
                      <input
                        type="number"
                        class="cantidad-input"
                        value="<%= puedeComprar ? 1 : 0 %>"
                        min="<%= puedeComprar ? 1 : 0 %>"
                        max="<%= producto.stock_actual %>"
                        step="1"
                        <%= puedeComprar ? '' : 'disabled' %>
                        aria-label="Cantidad"
                      />
                      <button type="button" class="qty-btn qty-btn--plus" aria-label="Sumar">
                        <i class="fa-solid fa-plus"></i>
                      </button>
                    </div>

                    <button
                      class="btn-agregar agregar-carrito"
                      <%= puedeComprar ? '' : 'disabled' %>
                      data-id="<%= producto.id %>"
                      data-nombre="<%= producto.nombre %>"
                      data-precio="<%= producto.precio_venta %>"
                      data-stock="<%= producto.stock_actual %>"
                      data-stockmin="<%= producto.stock_minimo %>">
                      <i class="fa-solid fa-cart-plus"></i>
                      <span><%= puedeComprar ? 'Agregar al carrito' : 'Sin stock' %></span>
                    </button>
                  <% } %>

                  <a href="/productos/<%= producto.id %>" class="btn-detalle card-link">
                    <i class="fa-solid fa-eye"></i>
                    <span>Ver detalles</span>
                  </a>
                </div>

                <!-- Social share -->
                <div class="pcard__share">
                  <a href="https://wa.me/543513820440?text=¡Hola! QUIERO CONSULTAR POR ESTE PRODUCTO: <%= producto.nombre %> 👉 https://www.autofaros.com.ar/productos/<%= producto.id %>"
                     title="Consultar por WhatsApp" target="_blank" class="pcard__share-btn pcard__share-btn--wa">
                    <i class="fab fa-whatsapp"></i>
                  </a>
                  <a href="https://www.facebook.com/profile.php?id=100063665395970"
                     title="Facebook" target="_blank" class="pcard__share-btn pcard__share-btn--fb">
                    <i class="fab fa-facebook-f"></i>
                  </a>
                  <a href="https://www.instagram.com/autofaros_cordoba"
                     title="Instagram" target="_blank" class="pcard__share-btn pcard__share-btn--ig">
                    <i class="fab fa-instagram"></i>
                  </a>
                </div>

              </div><!-- /pcard__body -->
            </article>

          <% }); %>

        <% } else if (seHizoBusqueda) { %>
          <div class="no-result">
            <img src="/images/noEncontrado.png" alt="Sin resultados" class="no-result__img" />
            <h3 class="no-result__title">Sin resultados</h3>
            <p class="no-result__text">No encontramos productos con esos filtros.<br>Probá con otras palabras clave o categorías.</p>
          </div>
        <% } %>

      </div><!-- /productos-grid -->

      <!-- ══════ PAGINACIÓN ══════ -->
      <% if (numeroDePaginas > 1) { %>
        <%
          const baseUrl = req.originalUrl.replace(/([?&])pagina=\d+/,'$1').replace(/[?&]$/, '');
          const joiner  = baseUrl.includes('?') ? '&' : '?';
        %>
        <nav class="paginacion" aria-label="Paginación de productos">
          <a
            class="paginacion__btn <%= pagina === 1 ? 'paginacion__btn--disabled' : '' %>"
            href="<%= pagina === 1 ? '#' : baseUrl + joiner + 'pagina=' + (pagina - 1) %>"
            aria-label="Anterior"
          >
            <i class="fa-solid fa-chevron-left"></i>
          </a>

          <div class="paginacion__pages">
            <% for (let i = 1; i <= numeroDePaginas; i++) { %>
              <a
                class="paginacion__page <%= i === pagina ? 'paginacion__page--active' : '' %>"
                href="<%= baseUrl + joiner + 'pagina=' + i %>"
              ><%= i %></a>
            <% } %>
          </div>

          <a
            class="paginacion__btn <%= pagina === numeroDePaginas ? 'paginacion__btn--disabled' : '' %>"
            href="<%= pagina === numeroDePaginas ? '#' : baseUrl + joiner + 'pagina=' + (pagina + 1) %>"
            aria-label="Siguiente"
          >
            <i class="fa-solid fa-chevron-right"></i>
          </a>
        </nav>
      <% } %>

    </section>
  </main>

  <!-- SweetAlert2 -->
  <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>

  <!-- Scripts de la vista -->
  <script src="/js/pages/buscador.js?v=20260309" defer></script>
  <script src="/js/pages/selectores.js?v=20260309" defer></script>
  <script src="/js/pages/agregarAlCarrito.js?v=20260309" defer></script>
  <script src="/js/pages/lista.js?v=20260318" defer></script>

  <%- include('./layouts/footer.ejs') %>
</body>
</html>
