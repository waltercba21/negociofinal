<header class="site-header <%= isLogged ? 'is-logged' : 'is-guest' %> <%= isAdminUser ? 'is-admin' : '' %>"
        data-usuario-id="<%= (userLogged && userLogged.id) ? userLogged.id : '' %>"
        data-is-admin="<%= isAdminUser ? 'true' : 'false' %>"
        role="banner">

  <!-- ── LOGO ──────────────────────────── -->
  <a href="<%= isAdminUser ? '/administracion' : '/' %>" class="site-header__logo" aria-label="AUTOFAROS — Inicio">
    <img src="/uploads/productos/logo.png?v=2" alt="AUTOFAROS" width="140" height="auto" loading="eager" />
  </a>

  <!-- ── BUSCADOR (solo usuarios comunes) ── -->
  <% if (!isAdminUser) { %>
  <% const qHeader = (typeof req !== 'undefined' && req.query && req.query.q) ? String(req.query.q) : ''; %>
  <form class="site-header__search"
        action="/productos"
        method="GET"
        role="search"
        autocomplete="off"
        aria-label="Buscar productos">
    <div class="search-wrapper">
      <span class="search-wrapper__icon" aria-hidden="true">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round">
          <circle cx="11" cy="11" r="7"></circle>
          <path d="M20 20l-3.5-3.5"></path>
        </svg>
      </span>
      <input
        class="search-wrapper__input"
        type="text"
        name="q"
        id="headerEntradaBusqueda"
        placeholder="Buscá por modelo, marca o pieza…"
        value="<%= qHeader %>"
        aria-label="Buscar productos" />
      <button
        type="button"
        id="headerBotonLimpiar"
        class="search-wrapper__clear"
        aria-label="Limpiar búsqueda"
        hidden>
        <i class="fa-solid fa-xmark" aria-hidden="true"></i>
      </button>
    </div>
  </form>
  <% } else { %>
    <!-- Espaciador para admin -->
    <div class="site-header__spacer"></div>
  <% } %>

  <!-- ── ACCIONES USUARIO + HAMBURGER (mobile) ──────────────── -->
  <%#
    ESTRUCTURA MOBILE:
    El hamburger vive DENTRO de .site-header__actions como ultimo hijo.
    Asi el grid de 3 columnas (logo | search | actions) lo contiene
    correctamente sin necesitar un grid-area propio.
  %>
  <div class="site-header__actions">
    <% if (isLogged) { %>
      <a href="/users/profile" class="user-greeting" aria-label="Mi perfil">
        <span class="user-greeting__avatar" aria-hidden="true">
          <%= userLogged.nombre.charAt(0).toUpperCase() %>
        </span>
        <span class="user-greeting__name">Hola, <strong><%= userLogged.nombre.split(' ')[0] %></strong></span>
      </a>

      <% if (!isAdminUser) { %>
        <a href="/carrito" class="action-btn action-btn--carrito" aria-label="Ver carrito">
          <i class="fa-solid fa-cart-shopping" aria-hidden="true"></i>
          <span id="carrito-notificacion"
                class="action-btn__badge"
                aria-live="polite"
                <% if (!cantidadCarrito || cantidadCarrito <= 0) { %>hidden<% } %>>
            <%= cantidadCarrito %>
          </span>
        </a>
      <% } %>

      <a href="/users/logout" class="action-btn action-btn--logout" aria-label="Cerrar sesión">
        <i class="fa-solid fa-right-from-bracket" aria-hidden="true"></i>
        <span class="action-btn__label">Salir</span>
      </a>

    <% } else { %>
      <div class="auth-buttons">
        <a href="/users/login" class="btn-auth btn-auth--login">
          <i class="fa-solid fa-right-to-bracket" aria-hidden="true"></i>
          <span>Iniciar Sesión</span>
        </a>
        <a href="/users/register" class="btn-auth btn-auth--register">
          <i class="fa-solid fa-user-plus" aria-hidden="true"></i>
          <span>Registrarme</span>
        </a>
      </div>
    <% } %>

    <!-- Hamburger como ultimo hijo de actions (mobile) -->
    <button class="site-header__hamburger"
            id="hamburgerBtn"
            type="button"
            aria-label="Abrir menú de navegación"
            aria-expanded="false"
            aria-controls="mainNav">
      <span class="hamburger__bar"></span>
      <span class="hamburger__bar"></span>
      <span class="hamburger__bar"></span>
    </button>
  </div>

  <!-- ── NAVEGACIÓN ───────────────────── -->
  <nav class="site-header__nav" id="mainNav" aria-label="Navegación principal">

    <% if (!isAdminUser) { %>
      <!-- Nav usuario común -->
      <a class="nav-link" href="/">
        <i class="fa-solid fa-house" aria-hidden="true"></i>
        <span>Inicio</span>
      </a>
      <a class="nav-link" href="/productos">
        <i class="fa-solid fa-bolt" aria-hidden="true"></i>
        <span>Productos</span>
      </a>
      <a class="nav-link nav-link--ofertas" href="/productos/ofertas">
        <i class="fa-solid fa-tag" aria-hidden="true"></i>
        <span>Ofertas</span>
      </a>
      <a class="nav-link nav-link--whatsapp" href="https://wa.me/+543513820440/" target="_blank" rel="noopener noreferrer" aria-label="Contacto WhatsApp">
        <i class="fa-brands fa-whatsapp" aria-hidden="true"></i>
        <span>WhatsApp</span>
      </a>
      <button class="nav-link nav-link--mapa" type="button" onclick="abrirMapa()" aria-label="Ver ubicación">
        <i class="fa-solid fa-location-dot" aria-hidden="true"></i>
        <span>Ubicación</span>
      </button>

    <% } else { %>
      <!-- Nav administrador — pills con color -->
      
      <a class="admin-pill admin-pill--blue" href="/productos" aria-label="Productos">
        <i class="fa-solid fa-bolt"></i>
        <span>Productos</span>
      </a>
      <a class="admin-pill admin-pill--blue" href="/productos/panelControl" aria-label="Panel de control">
        <i class="fa-solid fa-gauge-high"></i>
        <span>Panel</span>
      </a>
      <a class="admin-pill admin-pill--violet" href="/productos/presupuestoMostrador" aria-label="Presupuesto mostrador">
  <i class="fa-solid fa-file-invoice-dollar"></i>
  <span>Presupuesto</span>
</a>

<a class="admin-pill admin-pill--blue" href="/productos/cotizaciones" aria-label="Cotizaciones">
  <i class="fa-solid fa-file-signature"></i>
  <span>Cotizaciones</span>
</a>

<a class="admin-pill admin-pill--yellow" href="/productos/facturasMostrador" aria-label="Facturas mostrador">
  <i class="fa-solid fa-receipt"></i>
  <span>Facturas</span>
</a>
      <a class="admin-pill admin-pill--slate" href="/arca" aria-label="ARCA / AFIP">
        <i class="fa-solid fa-landmark"></i>
        <span>ARCA</span>
      </a>
      <a class="admin-pill admin-pill--slate" href="/administracion" aria-label="Administración">
        <i class="fa-solid fa-screwdriver-wrench"></i>
        <span>Administración</span>
      </a>
      <a class="admin-pill admin-pill--red admin-pill--pedidos" href="/pedidos" aria-label="Pedidos pendientes">
        <i class="fa-solid fa-boxes-stacked"></i>
        <span>Pedidos</span>
        <span id="badge-pedidos" class="badge-pedidos" aria-live="polite" hidden>0</span>
      </a>
    <% } %>

    <!-- Auth links mobile (no logueado) -->
    <% if (!isLogged) { %>
      <div class="nav-auth-mobile">
        <a class="nav-link" href="/users/login">
          <i class="fa-solid fa-right-to-bracket" aria-hidden="true"></i>
          <span>Iniciar Sesión</span>
        </a>
        <a class="nav-link" href="/users/register">
          <i class="fa-solid fa-user-plus" aria-hidden="true"></i>
          <span>Registrarme</span>
        </a>
      </div>
    <% } %>

  </nav>

</header>

<!-- Overlay oscuro para el drawer (fuera del header) -->
<div class="site-header__nav-overlay" id="navOverlay" aria-hidden="true"></div>

<!-- Bottom Navigation Bar (solo usuarios comunes, mobile) -->
<% if (!isAdminUser) { %>
<%
  const currentPath = (typeof req !== 'undefined' && req.path) ? req.path : '';
  const isHome     = currentPath === '/';
  const isProducts = currentPath.startsWith('/productos') && !currentPath.includes('/ofertas');
  const isOfertas  = currentPath.includes('/ofertas');
%>
<nav class="m-bottom-nav" aria-label="Navegación móvil principal" role="navigation">

  <a href="/"
     class="m-bottom-nav__item <%= isHome ? 'm-bottom-nav__item--active' : '' %>"
     aria-label="Inicio">
    <i class="fa-solid fa-house" aria-hidden="true"></i>
    <span>Inicio</span>
  </a>

  <a href="/productos"
     class="m-bottom-nav__item <%= isProducts ? 'm-bottom-nav__item--active' : '' %>"
     aria-label="Productos">
    <i class="fa-solid fa-bolt" aria-hidden="true"></i>
    <span>Productos</span>
  </a>

  <a href="/productos/ofertas"
     class="m-bottom-nav__item m-bottom-nav__item--ofertas <%= isOfertas ? 'm-bottom-nav__item--active' : '' %>"
     aria-label="Ofertas">
    <i class="fa-solid fa-tag" aria-hidden="true"></i>
    <span>Ofertas</span>
  </a>

  <a href="https://wa.me/+543513820440/"
     class="m-bottom-nav__item m-bottom-nav__item--whatsapp"
     target="_blank" rel="noopener noreferrer"
     aria-label="WhatsApp">
    <i class="fa-brands fa-whatsapp" aria-hidden="true"></i>
    <span>WhatsApp</span>
  </a>

  <button type="button"
          class="m-bottom-nav__item"
          onclick="abrirMapa()"
          aria-label="Ver ubicación">
    <i class="fa-solid fa-location-dot" aria-hidden="true"></i>
    <span>Ubicación</span>
  </button>

</nav>
<% } %>
<script src="/socket.io/socket.io.js"></script>
<script src="/js/layout/header.js" defer></script>
