<header class="site-header <%= isLogged ? 'is-logged' : 'is-guest' %> <%= isAdminUser ? 'is-admin' : '' %>"
        data-usuario-id="<%= (userLogged && userLogged.id) ? userLogged.id : '' %>"
        data-is-admin="<%= isAdminUser ? 'true' : 'false' %>"
        role="banner">

  <!-- ── MARCA / LOGO ──────────────────────────── -->
  <a href="/" class="site-header__logo" aria-label="AUTOFAROS — Inicio">
    <img src="/uploads/productos/logo.png?v=2" alt="AUTOFAROS" width="140" height="auto" loading="eager" />
  </a>

  <!-- ── BUSCADOR ──────────────────────────────── -->
  <% const qHeader = (typeof req !== 'undefined' && req.query && req.query.q) ? String(req.query.q) : ''; %>

  <form class="site-header__search"
        action="/productos"
        method="GET"
        role="search"
        autocomplete="off"
        aria-label="Buscar productos">

    <div class="search-wrapper">
      <span class="search-wrapper__icon" aria-hidden="true">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round">
          <circle cx="11" cy="11" r="7"></circle>
          <path d="M20 20l-3.5-3.5"></path>
        </svg>
      </span>

      <input
        class="search-wrapper__input"
        type="text"
        name="q"
        id="headerEntradaBusqueda"
        placeholder="Buscá por modelo, marca o pieza…"
        value="<%= qHeader %>"
        aria-label="Buscar productos" />

      <button
        type="button"
        id="headerBotonLimpiar"
        class="search-wrapper__clear"
        aria-label="Limpiar búsqueda"
        hidden>
        <i class="fa-solid fa-xmark" aria-hidden="true"></i>
      </button>
    </div>
  </form>

  <!-- ── NAVEGACIÓN PRINCIPAL ───────────────────── -->
  <nav class="site-header__nav" id="mainNav" aria-label="Navegación principal">

    <a class="nav-link" href="/">
      <i class="fa-solid fa-house" aria-hidden="true"></i>
      <span>Inicio</span>
    </a>

    <a class="nav-link" href="/productos">
      <i class="fa-solid fa-bolt" aria-hidden="true"></i>
      <span>Productos</span>
    </a>

    <% if (!isAdminUser) { %>
      <a class="nav-link nav-link--ofertas" href="/productos/ofertas">
        <i class="fa-solid fa-tag" aria-hidden="true"></i>
        <span>Ofertas</span>
      </a>

      <a class="nav-link nav-link--whatsapp" href="https://wa.me/+543513820440/" target="_blank" rel="noopener noreferrer" aria-label="Contacto WhatsApp (abre en nueva pestaña)">
        <i class="fa-brands fa-whatsapp" aria-hidden="true"></i>
        <span>WhatsApp</span>
      </a>

      <button class="nav-link nav-link--mapa" type="button" onclick="abrirMapa()" aria-label="Ver ubicación en mapa">
        <i class="fa-solid fa-location-dot" aria-hidden="true"></i>
        <span>Ubicación</span>
      </button>
    <% } %>

    <!-- ── ENLACES SOLO ADMIN ─────────────── -->
    <% if (isAdminUser) { %>
      <a class="nav-link nav-link--admin" href="/productos/panelControl">
        <i class="fa-solid fa-gauge-high" aria-hidden="true"></i>
        <span>Panel</span>
      </a>

      <a class="nav-link nav-link--admin" href="/productos/presupuestoMostrador">
        <i class="fa-solid fa-file-invoice-dollar" aria-hidden="true"></i>
        <span>Presupuesto</span>
      </a>

      <a class="nav-link nav-link--admin nav-link--factura" href="/productos/facturasMostrador">
        <i class="fa-solid fa-receipt" aria-hidden="true"></i>
        <span>Facturas</span>
      </a>

      <a class="nav-link nav-link--admin" href="/arca">
        <i class="fa-solid fa-landmark" aria-hidden="true"></i>
        <span>ARCA</span>
      </a>

      <a class="nav-link nav-link--admin" href="/administracion/gastos" id="gastos-btn">
        <i class="fa-solid fa-coins" aria-hidden="true"></i>
        <span>Gastos</span>
      </a>

      <a class="nav-link nav-link--admin" href="/administracion" id="admin-btn">
        <i class="fa-solid fa-screwdriver-wrench" aria-hidden="true"></i>
        <span>Admin</span>
      </a>

      <a class="nav-link nav-link--admin nav-link--pedidos" href="/pedidos" aria-label="Pedidos pendientes">
        <i class="fa-solid fa-boxes-stacked" aria-hidden="true"></i>
        <span>Pedidos</span>
        <span id="badge-pedidos" class="badge-pedidos" aria-live="polite" aria-label="Pedidos pendientes" hidden>0</span>
      </a>
    <% } %>

    <!-- ── AUTH LINKS (solo mobile dentro del menú) ── -->
    <% if (!isLogged) { %>
      <div class="nav-auth-mobile">
        <a class="nav-link" href="/users/login">
          <i class="fa-solid fa-right-to-bracket" aria-hidden="true"></i>
          <span>Iniciar Sesión</span>
        </a>
        <a class="nav-link nav-link--register" href="/users/register">
          <i class="fa-solid fa-user-plus" aria-hidden="true"></i>
          <span>Registrarme</span>
        </a>
      </div>
    <% } %>

  </nav>

  <!-- ── ACCIONES DE USUARIO (iconos derecha) ────── -->
  <div class="site-header__actions">

    <% if (isLogged) { %>

      <a href="/users/profile" class="user-greeting" aria-label="Ir a mi perfil">
        <span class="user-greeting__avatar" aria-hidden="true">
          <%= userLogged.nombre.charAt(0).toUpperCase() %>
        </span>
        <span class="user-greeting__name">Hola, <strong><%= userLogged.nombre.split(' ')[0] %></strong></span>
      </a>

      <% if (!isAdminUser) { %>
        <a href="/carrito" class="action-btn action-btn--carrito" aria-label="Ver carrito de compras">
          <i class="fa-solid fa-cart-shopping" aria-hidden="true"></i>
          <span id="carrito-notificacion"
                class="action-btn__badge"
                aria-live="polite"
                aria-label="<%= cantidadCarrito %> productos en el carrito"
                <% if (!cantidadCarrito || cantidadCarrito <= 0) { %>hidden<% } %>>
            <%= cantidadCarrito %>
          </span>
        </a>
      <% } %>

      <a href="/users/logout" class="action-btn action-btn--logout" aria-label="Cerrar sesión">
        <i class="fa-solid fa-right-from-bracket" aria-hidden="true"></i>
        <span class="action-btn__label">Salir</span>
      </a>

    <% } else { %>

      <div class="auth-buttons">
        <a href="/users/login" class="btn-auth btn-auth--login">
          <i class="fa-solid fa-right-to-bracket" aria-hidden="true"></i>
          <span>Iniciar Sesión</span>
        </a>
        <a href="/users/register" class="btn-auth btn-auth--register">
          <i class="fa-solid fa-user-plus" aria-hidden="true"></i>
          <span>Registrarme</span>
        </a>
      </div>

    <% } %>

  </div>

  <!-- ── HAMBURGER (mobile) ──────────────────────── -->
  <button class="site-header__hamburger"
          id="hamburgerBtn"
          type="button"
          aria-label="Abrir menú de navegación"
          aria-expanded="false"
          aria-controls="mainNav">
    <span class="hamburger__bar"></span>
    <span class="hamburger__bar"></span>
    <span class="hamburger__bar"></span>
  </button>

</header>

<!-- Socket.io — cargado una única vez aquí (se elimina del head) -->
<script src="/socket.io/socket.io.js"></script>
<!-- Lógica del header: búsqueda, hamburger, socket, badges -->
<script src="/js/layout/header.js" defer></script>
