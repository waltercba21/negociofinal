<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <meta name="theme-color" content="#0A1628">
  <title><%= typeof pageTitle !== 'undefined' ? pageTitle : 'AUTOFAROS — Iluminación Automotriz Córdoba' %></title>
  <meta name="description" content="<%= typeof pageDescription !== 'undefined' ? pageDescription : 'Faros, ópticas y lámparas automotrices en Córdoba. LED, Xenón, Halógenas y accesorios. Envíos a todo el país.' %>">

  <!-- Preconnect fonts -->
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>

  <!-- Rajdhani (display/títulos) + Outfit (body) -->
  <link href="https://fonts.googleapis.com/css2?family=Rajdhani:wght@600;700&family=Outfit:wght@300;400;500;600;700;800&display=swap" rel="stylesheet">

  <!-- Font Awesome 6 -->
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css" crossorigin="anonymous" referrerpolicy="no-referrer">

  <!-- CSS Global -->
  <link rel="stylesheet" href="/css/autofaros.css">

  <!-- CSS por vista (inyectado desde cada ruta) -->
  <% if (typeof pageCss !== 'undefined' && pageCss) { %>
    <link rel="stylesheet" href="<%= pageCss %>">
  <% } %>

  <!-- Favicon -->
  <link rel="icon" type="image/png" href="/uploads/productos/logo.png">
</head>
