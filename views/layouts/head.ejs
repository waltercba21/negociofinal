<head>
  <meta charset="UTF-8" />
  <meta http-equiv="X-UA-Compatible" content="IE=edge" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />

  <!-- ═══════════════════════════════════════
       TÍTULO DINÁMICO
  ════════════════════════════════════════ -->
  <title>
    <%= (typeof producto !== 'undefined' && producto && producto.nombre)
        ? producto.nombre + ' — AUTOFAROS'
        : (typeof pageTitle !== 'undefined' && pageTitle)
          ? pageTitle + ' — AUTOFAROS'
          : 'AUTOFAROS · Iluminación Automotriz' %>
  </title>

  <!-- ═══════════════════════════════════════
       SEO / OPEN GRAPH / TWITTER CARD
  ════════════════════════════════════════ -->
  <meta name="description" content="<%= (typeof producto !== 'undefined' && producto && producto.descripcion) ? producto.descripcion : 'AUTOFAROS — Faros, ópticas y repuestos de iluminación automotriz en Córdoba.' %>" />

  <meta property="og:type"        content="<%= (typeof producto !== 'undefined' && producto) ? 'product' : 'website' %>" />
  <meta property="og:site_name"   content="AUTOFAROS" />
  <meta property="og:title"       content="<%= (typeof producto !== 'undefined' && producto) ? producto.nombre : 'AUTOFAROS · Iluminación Automotriz' %>" />
  <meta property="og:description" content="<%= (typeof producto !== 'undefined' && producto && producto.descripcion) ? producto.descripcion : 'Repuestos de iluminación para tu auto al mejor precio' %>" />
  <meta property="og:image"       content="<%= (typeof producto !== 'undefined' && producto && producto.imagenes && producto.imagenes.length > 0) ? 'https://www.autofaros.com.ar/uploads/productos/' + producto.imagenes[0].imagen : 'https://www.autofaros.com.ar/images/default-share.jpg' %>" />
  <meta property="og:url"         content="<%= (typeof producto !== 'undefined' && producto) ? 'https://www.autofaros.com.ar/productos/' + producto.id : 'https://www.autofaros.com.ar' %>" />

  <meta name="twitter:card"        content="summary_large_image" />
  <meta name="twitter:title"       content="<%= (typeof producto !== 'undefined' && producto) ? producto.nombre : 'AUTOFAROS · Iluminación Automotriz' %>" />
  <meta name="twitter:description" content="<%= (typeof producto !== 'undefined' && producto && producto.descripcion) ? producto.descripcion : 'Repuestos de iluminación para tu auto al mejor precio' %>" />
  <meta name="twitter:image"       content="<%= (typeof producto !== 'undefined' && producto && producto.imagenes && producto.imagenes.length > 0) ? 'https://www.autofaros.com.ar/uploads/productos/' + producto.imagenes[0].imagen : 'https://www.autofaros.com.ar/images/default-share.jpg' %>" />

  <!-- ═══════════════════════════════════════
       FAVICON
  ════════════════════════════════════════ -->
  <link rel="icon" type="image/x-icon" href="/images/favicon.ico" sizes="any" />

  <!-- ═══════════════════════════════════════
       TIPOGRAFÍAS (preconnect primero)
  ════════════════════════════════════════ -->
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <!--
    - Barlow Condensed: display / headings → impacto sin ser genérico
    - DM Sans: body → legible, moderno, espaciado perfecto
  -->
  <link href="https://fonts.googleapis.com/css2?family=Barlow+Condensed:ital,wght@0,400;0,600;0,700;0,800;1,700&family=DM+Sans:ital,opsz,wght@0,9..40,300;0,9..40,400;0,9..40,500;0,9..40,600;1,9..40,400&display=swap" rel="stylesheet" />

  <!-- ═══════════════════════════════════════
       LIBRERÍAS CSS EXTERNAS
  ════════════════════════════════════════ -->
  <!-- Bootstrap 5 -->
  <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.2.2/dist/css/bootstrap.min.css" integrity="sha384-Zenh87qX5JnK2Jl0vWa8Ck2rdkQ2Bzep5IDxbcnCeuOxjzrPF/et3URy9Bv1WTRi" crossorigin="anonymous" />
  <!-- Font Awesome 6 Free (reemplaza v5 kit) -->
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css" crossorigin="anonymous" />
  <!-- Leaflet (mapa) -->
  <link rel="stylesheet" href="https://unpkg.com/leaflet@1.9.4/dist/leaflet.css" />

  <!-- ═══════════════════════════════════════
       CSS GLOBAL DEL PROYECTO
  ════════════════════════════════════════ -->
  <link rel="stylesheet" href="/css/globals/variables.css" />
  <link rel="stylesheet" href="/css/globals/reset.css" />
  <link rel="stylesheet" href="/css/globals/typography.css" />
  <link rel="stylesheet" href="/css/globals/utilities.css" />
  <link rel="stylesheet" href="/css/layout/header.css" />
  <link rel="stylesheet" href="/css/layout/footer.css" />

  <!-- ═══════════════════════════════════════
       CSS POR VISTA (inyectado desde cada ruta)
       Uso: res.locals.pageCss = '/css/productos/lista.css'
  ════════════════════════════════════════ -->
  <% if (typeof pageCss !== 'undefined' && pageCss) { %>
    <link rel="stylesheet" href="<%= pageCss %>" />
  <% } %>

  <!-- ═══════════════════════════════════════
       SCRIPTS EXTERNOS — solo los que deben ir en <head>
       (blocking mínimo: solo Bootstrap bundle)
  ════════════════════════════════════════ -->
  <!-- Bootstrap JS Bundle (incluye Popper) -->
  <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.2.2/dist/js/bootstrap.bundle.min.js" integrity="sha384-OERcA2EqjJCMA+/3y+gxIOqMEjwtxJY7qPCqsdltbNJuaOe923+mo//f6V8Qbsw3" crossorigin="anonymous" defer></script>
  <!-- SweetAlert2 -->
  <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11" defer></script>
  <!-- Leaflet JS -->
  <script src="https://unpkg.com/leaflet@1.9.4/dist/leaflet.js" defer></script>
  <!-- Mercado Pago SDK (solo cargará cuando se use, defer) -->
  <script src="https://sdk.mercadopago.com/js/v2" defer></script>

  <!-- ═══════════════════════════════════════
       GOOGLE ANALYTICS (non-blocking)
  ════════════════════════════════════════ -->
  <script async src="https://www.googletagmanager.com/gtag/js?id=G-7CZ53J6STJ"></script>
  <script>
    window.dataLayer = window.dataLayer || [];
    function gtag(){dataLayer.push(arguments);}
    gtag('js', new Date());
    gtag('config', 'G-7CZ53J6STJ');
  </script>

</head>
