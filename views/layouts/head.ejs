<head>
  <meta charset="UTF-8" />
  <meta http-equiv="X-UA-Compatible" content="IE=edge" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />

  <title>
    <%= (typeof producto !== 'undefined' && producto && producto.nombre)
        ? producto.nombre + ' — AUTOFAROS'
        : (typeof pageTitle !== 'undefined' && pageTitle)
          ? pageTitle + ' — AUTOFAROS'
          : 'AUTOFAROS · Iluminación Automotriz' %>
  </title>

  <meta name="description" content="<%= (typeof producto !== 'undefined' && producto && producto.descripcion) ? producto.descripcion : 'AUTOFAROS — Faros, ópticas y repuestos de iluminación automotriz en Córdoba.' %>" />
  <meta property="og:type"        content="<%= (typeof producto !== 'undefined' && producto) ? 'product' : 'website' %>" />
  <meta property="og:site_name"   content="AUTOFAROS" />
  <meta property="og:title"       content="<%= (typeof producto !== 'undefined' && producto) ? producto.nombre : 'AUTOFAROS · Iluminación Automotriz' %>" />
  <meta property="og:description" content="<%= (typeof producto !== 'undefined' && producto && producto.descripcion) ? producto.descripcion : 'Repuestos de iluminación para tu auto al mejor precio' %>" />
  <meta property="og:image"       content="<%= (typeof producto !== 'undefined' && producto && producto.imagenes && producto.imagenes.length > 0) ? 'https://www.autofaros.com.ar/uploads/productos/' + producto.imagenes[0].imagen : 'https://www.autofaros.com.ar/images/default-share.jpg' %>" />
  <meta property="og:url"         content="<%= (typeof producto !== 'undefined' && producto) ? 'https://www.autofaros.com.ar/productos/' + producto.id : 'https://www.autofaros.com.ar' %>" />
  <meta name="twitter:card"        content="summary_large_image" />
  <meta name="twitter:title"       content="<%= (typeof producto !== 'undefined' && producto) ? producto.nombre : 'AUTOFAROS · Iluminación Automotriz' %>" />
  <meta name="twitter:description" content="<%= (typeof producto !== 'undefined' && producto && producto.descripcion) ? producto.descripcion : 'Repuestos de iluminación para tu auto al mejor precio' %>" />
  <meta name="twitter:image"       content="<%= (typeof producto !== 'undefined' && producto && producto.imagenes && producto.imagenes.length > 0) ? 'https://www.autofaros.com.ar/uploads/productos/' + producto.imagenes[0].imagen : 'https://www.autofaros.com.ar/images/default-share.jpg' %>" />

  <link rel="icon" type="image/x-icon" href="/images/favicon.ico" />

  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Barlow+Condensed:wght@400;600;700;800&family=DM+Sans:opsz,wght@9..40,300;9..40,400;9..40,500;9..40,600&display=swap" rel="stylesheet" />

  
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css" crossorigin="anonymous" />
  <link rel="stylesheet" href="https://unpkg.com/leaflet@1.9.4/dist/leaflet.css" />

  <!-- CSS GLOBAL: variables + reset + header + footer en un solo archivo -->
  <link rel="stylesheet" href="/css/autofaros.css" />

  <% if (typeof pageCss !== 'undefined' && pageCss) { %>
    <link rel="stylesheet" href="<%= pageCss %>" />
  <% } %>

  <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.2.2/dist/js/bootstrap.bundle.min.js" crossorigin="anonymous"></script>
  <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
  <script src="https://unpkg.com/leaflet@1.9.4/dist/leaflet.js" defer></script>
  <script src="https://sdk.mercadopago.com/js/v2" defer></script>

  <script async src="https://www.googletagmanager.com/gtag/js?id=G-7CZ53J6STJ"></script>
  <script>
    window.dataLayer = window.dataLayer || [];
    function gtag(){dataLayer.push(arguments);}
    gtag('js', new Date());
    gtag('config', 'G-7CZ53J6STJ');
  </script>
</head>
