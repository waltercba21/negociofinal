<%- include('./layouts/head.ejs') %>
<link rel="preconnect" href="https://fonts.googleapis.com">
<link href="https://fonts.googleapis.com/css2?family=Roboto:wght@300;400;500;700;900&family=Roboto+Mono:wght@400;500&display=swap" rel="stylesheet">

<style>
/* ═══════════════════════════════════════════════
   ESTADÍSTICAS — AutoFaros (Roboto)
   Sin solapamientos, números con overflow seguro
═══════════════════════════════════════════════ */
:root {
  --bg:        #080c14;
  --bg-card:   #0e1520;
  --bg-card2:  #111927;
  --border:    rgba(255,255,255,0.07);
  --border-hi: rgba(245,200,66,0.22);
  --gold:      #f5c842;
  --gold-dim:  rgba(245,200,66,0.10);
  --blue:      #3b82f6;
  --green:     #34d399;
  --red:       #f87171;
  --purple:    #a78bfa;
  --orange:    #fb923c;
  --txt-hi:    #f0f4ff;
  --txt-mid:   rgba(240,244,255,0.58);
  --txt-lo:    rgba(240,244,255,0.30);
  --r:         12px;
  --r-sm:      8px;
}

/* RESET selectivo para no pisar el sistema */
.est-dash *, .est-dash *::before, .est-dash *::after {
  box-sizing: border-box;
}
.est-dash {
  font-family: 'Roboto', sans-serif;
  background: var(--bg);
  color: var(--txt-hi);
  min-height: calc(100vh - 60px);
}

/* ── PAGE ── */
.est-pg {
  max-width: 1400px;
  margin: 0 auto;
  padding: 24px 20px 60px;
}

/* ── TOPBAR ── */
.est-topbar {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  flex-wrap: wrap;
  gap: 14px;
  margin-bottom: 22px;
}
.est-eyebrow {
  font-family: 'Roboto Mono', monospace;
  font-size: 10px;
  letter-spacing: 2px;
  text-transform: uppercase;
  color: var(--gold);
  margin-bottom: 5px;
  display: flex;
  align-items: center;
  gap: 7px;
}
.est-eyebrow::before {
  content: '';
  width: 16px;
  height: 1px;
  background: var(--gold);
}
.est-h1 {
  font-family: 'Roboto', sans-serif;
  font-size: 28px;
  font-weight: 900;
  letter-spacing: -.3px;
  color: var(--txt-hi);
  margin: 0;
}
.est-sub {
  font-size: 12px;
  color: var(--txt-mid);
  margin-top: 3px;
}
.est-btn-back {
  display: inline-flex;
  align-items: center;
  gap: 6px;
  font-family: 'Roboto', sans-serif;
  font-size: 12px;
  font-weight: 500;
  color: var(--txt-mid);
  background: var(--bg-card);
  border: 1px solid var(--border);
  border-radius: 8px;
  padding: 8px 16px;
  text-decoration: none;
  transition: all .2s;
  white-space: nowrap;
}
.est-btn-back:hover {
  color: var(--txt-hi);
  border-color: rgba(255,255,255,.14);
}

/* ── PERIOD ── */
.est-period-row {
  display: flex;
  align-items: center;
  gap: 10px;
  flex-wrap: wrap;
  margin-bottom: 18px;
}
.est-tabs-periodo {
  display: flex;
  background: var(--bg-card);
  border: 1px solid var(--border);
  border-radius: 30px;
  padding: 3px;
  gap: 2px;
}
.est-tab-p {
  font-family: 'Roboto', sans-serif;
  font-size: 12px;
  font-weight: 500;
  color: var(--txt-mid);
  background: none;
  border: none;
  border-radius: 24px;
  padding: 6px 16px;
  cursor: pointer;
  transition: all .2s;
  white-space: nowrap;
}
.est-tab-p:hover { color: var(--txt-hi); }
.est-tab-p.active {
  background: var(--gold);
  color: #080c14;
  font-weight: 700;
}
.est-sub-filters {
  display: flex;
  align-items: center;
  gap: 6px;
  flex-wrap: wrap;
}
.est-sub-filters select {
  font-family: 'Roboto Mono', monospace;
  font-size: 11px;
  color: var(--txt-hi);
  background: var(--bg-card2);
  border: 1px solid var(--border);
  border-radius: 6px;
  padding: 6px 10px;
  outline: none;
  cursor: pointer;
}
.est-sub-filters select:focus { border-color: var(--border-hi); }
.est-btn-run {
  display: inline-flex;
  align-items: center;
  gap: 7px;
  font-family: 'Roboto', sans-serif;
  font-size: 12px;
  font-weight: 700;
  background: var(--gold);
  color: #080c14;
  border: none;
  border-radius: 24px;
  padding: 8px 22px;
  cursor: pointer;
  transition: all .2s;
  white-space: nowrap;
}
.est-btn-run:hover { opacity: .88; transform: translateY(-1px); }

/* loading */
.est-loading {
  display: none;
  align-items: center;
  gap: 8px;
  font-family: 'Roboto Mono', monospace;
  font-size: 11px;
  color: var(--gold);
  background: var(--gold-dim);
  border: 1px solid var(--border-hi);
  border-radius: 7px;
  padding: 6px 14px;
}
.est-loading.on { display: flex; }
.est-spin {
  width: 13px; height: 13px;
  border: 2px solid rgba(245,200,66,.25);
  border-top-color: var(--gold);
  border-radius: 50%;
  animation: estSpin .7s linear infinite;
}
@keyframes estSpin { to { transform: rotate(360deg); } }

/* rango / error */
.est-rango {
  display: none;
  font-family: 'Roboto Mono', monospace;
  font-size: 11px;
  color: var(--txt-lo);
  padding: 7px 14px;
  background: var(--bg-card);
  border-left: 2px solid var(--gold);
  border-radius: 0 6px 6px 0;
  margin-bottom: 18px;
}
.est-rango.on { display: block; }
.est-rango span { color: var(--txt-mid); }
.est-err {
  display: none;
  padding: 11px 16px;
  background: rgba(248,113,113,.08);
  border: 1px solid rgba(248,113,113,.22);
  border-radius: 8px;
  font-size: 12px;
  color: var(--red);
  margin-bottom: 16px;
}
.est-err.on { display: block; }

/* ── BALANCE ── */
.est-balance {
  background: linear-gradient(135deg, #0c1829 0%, var(--bg-card) 100%);
  border: 1px solid var(--border-hi);
  border-radius: var(--r);
  padding: 22px 26px;
  margin-bottom: 20px;
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 20px;
  flex-wrap: wrap;
  position: relative;
  overflow: hidden;
}
.est-balance::before {
  content: 'BALANCE';
  position: absolute;
  right: -6px; top: -4px;
  font-weight: 900;
  font-size: 52px;
  color: rgba(245,200,66,.03);
  pointer-events: none;
  white-space: nowrap;
  font-family: 'Roboto', sans-serif;
}
.estbal-ey {
  font-family: 'Roboto Mono', monospace;
  font-size: 9px; letter-spacing: 2.5px;
  text-transform: uppercase;
  color: var(--gold);
  margin-bottom: 8px;
}
.estbal-val {
  font-family: 'Roboto', sans-serif;
  font-size: clamp(22px, 3.5vw, 40px);
  font-weight: 900;
  line-height: 1;
  transition: color .5s;
}
.estbal-val.pos { color: var(--green); }
.estbal-val.neg { color: var(--red); }
.estbal-val.neu { color: var(--txt-hi); }
.estbal-verdict {
  font-size: 12px;
  color: var(--txt-mid);
  margin-top: 8px;
  display: flex;
  align-items: center;
  gap: 6px;
}
.estbal-cols {
  display: flex;
  gap: 14px;
  flex-wrap: wrap;
}
.estbal-col { text-align: center; min-width: 90px; }
.estbal-col-lbl {
  font-family: 'Roboto Mono', monospace;
  font-size: 9px; letter-spacing: 1.5px;
  text-transform: uppercase; color: var(--txt-lo);
  margin-bottom: 4px;
}
.estbal-col-val {
  font-family: 'Roboto', sans-serif;
  font-size: clamp(12px, 1.6vw, 16px);
  font-weight: 700;
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
}
.estbal-col-val.ing  { color: var(--blue); }
.estbal-col-val.comp { color: var(--red); }
.estbal-col-val.gast { color: rgba(248,113,113,.75); }
.estbal-col-val.marg { color: var(--green); }
.estbal-bar { height: 3px; background: rgba(255,255,255,.07); border-radius: 2px; margin-top: 6px; overflow: hidden; }
.estbal-bar-f { height: 100%; border-radius: 2px; transition: width .8s cubic-bezier(.4,0,.2,1); }

/* ── SECTION LABEL ── */
.est-sec {
  font-family: 'Roboto', sans-serif;
  font-size: 11px;
  font-weight: 700;
  color: var(--txt-lo);
  letter-spacing: 1.8px;
  text-transform: uppercase;
  margin: 20px 0 12px;
  display: flex;
  align-items: center;
  gap: 8px;
}
.est-sec::after {
  content: '';
  flex: 1;
  height: 1px;
  background: var(--border);
}
.est-sec i { font-size: 11px; }

/* ── KPI STRIP ──
   IMPORTANTE: usa padding-top para que el ::before no tape el contenido */
.est-kpi-row {
  display: grid;
  grid-template-columns: repeat(auto-fit, minmax(155px, 1fr));
  gap: 11px;
  margin-bottom: 20px;
}
.est-kpi {
  background: var(--bg-card);
  border: 1px solid var(--border);
  border-radius: var(--r);
  /* padding-top: 18px reserva espacio para la línea de color superior */
  padding: 18px 16px 14px;
  position: relative;
  overflow: hidden;
  transition: border-color .25s, transform .2s;
}
.est-kpi:hover {
  transform: translateY(-2px);
  border-color: rgba(255,255,255,.12);
}
/* línea de color en el tope — 2px, no interfiere con texto */
.est-kpi::before {
  content: '';
  position: absolute;
  top: 0; left: 0; right: 0;
  height: 2px;
  background: var(--kac, var(--gold));
  border-radius: var(--r) var(--r) 0 0;
}
.est-kpi--gold   { --kac: var(--gold); }
.est-kpi--blue   { --kac: var(--blue); }
.est-kpi--green  { --kac: var(--green); }
.est-kpi--red    { --kac: var(--red); }
.est-kpi--purple { --kac: var(--purple); }

.est-kpi-lbl {
  font-family: 'Roboto Mono', monospace;
  font-size: 9px;
  letter-spacing: 1.5px;
  text-transform: uppercase;
  color: var(--txt-lo);
  margin-bottom: 8px;
  display: flex;
  align-items: center;
  gap: 5px;
}
.est-kpi-lbl i { color: var(--kac); font-size: 10px; }
.est-kpi-val {
  font-family: 'Roboto', sans-serif;
  font-size: clamp(13px, 1.8vw, 20px);
  font-weight: 700;
  color: var(--txt-hi);
  line-height: 1.1;
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
}
.est-kpi-sub {
  font-size: 10px;
  color: var(--txt-lo);
  margin-top: 4px;
}

/* ── RATIO STRIP ──
   Separado completamente de los KPIs, propio margin-top */
.est-ratio-row {
  display: grid;
  grid-template-columns: repeat(auto-fit, minmax(130px, 1fr));
  gap: 10px;
  margin-bottom: 20px;
  /* No position:absolute, flujo normal */
}
.est-ratio {
  background: var(--bg-card2);
  border: 1px solid var(--border);
  border-radius: var(--r-sm);
  padding: 12px 14px;
  text-align: center;
}
.est-ratio-num {
  font-family: 'Roboto', sans-serif;
  font-size: clamp(16px, 2vw, 24px);
  font-weight: 700;
  margin-bottom: 3px;
  line-height: 1;
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
}
.est-ratio-lbl {
  font-family: 'Roboto Mono', monospace;
  font-size: 9px;
  letter-spacing: 1px;
  text-transform: uppercase;
  color: var(--txt-lo);
}
.est-ratio-desc {
  font-size: 10px;
  color: var(--txt-mid);
  margin-top: 4px;
}

/* ── CARDS ── */
.est-card {
  background: var(--bg-card);
  border: 1px solid var(--border);
  border-radius: var(--r);
  overflow: hidden;
}
.est-card-hdr {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 13px 17px 10px;
  border-bottom: 1px solid var(--border);
}
.est-card-title {
  font-family: 'Roboto', sans-serif;
  font-size: 13px;
  font-weight: 700;
  color: var(--txt-hi);
  display: flex;
  align-items: center;
  gap: 7px;
}
.est-card-title i { color: var(--cac, var(--gold)); font-size: 12px; }
.est-card-badge {
  font-family: 'Roboto Mono', monospace;
  font-size: 9px; letter-spacing: 1px;
  text-transform: uppercase; color: var(--txt-lo);
  background: rgba(255,255,255,.04);
  border: 1px solid var(--border);
  border-radius: 20px;
  padding: 3px 9px;
}
.est-card-body { padding: 14px 17px; }

/* chart heights */
.est-ch-md { position: relative; height: 230px; }

/* ── GRIDS ── */
.est-g2 {
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: 14px;
  margin-bottom: 20px;
}
.est-g-4060 {
  display: grid;
  grid-template-columns: 1fr 1.5fr;
  gap: 14px;
  margin-bottom: 20px;
}
.est-g-6040 {
  display: grid;
  grid-template-columns: 1.5fr 1fr;
  gap: 14px;
  margin-bottom: 20px;
}
@media (max-width: 900px) {
  .est-g2, .est-g-4060, .est-g-6040 { grid-template-columns: 1fr; }
}

/* ── PIE ── */
.est-pie-wrap {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 12px;
  align-items: center;
}
.est-pie-cw { position: relative; height: 170px; }
.est-legend  { display: flex; flex-direction: column; gap: 7px; }
.est-leg-row { display: flex; align-items: center; gap: 7px; }
.est-leg-dot { width: 8px; height: 8px; border-radius: 2px; flex-shrink: 0; }
.est-leg-name {
  font-family: 'Roboto', sans-serif;
  font-size: 11px; color: var(--txt-mid); flex: 1;
}
.est-leg-pct {
  font-family: 'Roboto Mono', monospace;
  font-size: 10px; color: var(--txt-hi);
}
.est-leg-sub {
  font-family: 'Roboto Mono', monospace;
  font-size: 9px; color: var(--txt-lo);
  margin-left: 15px; margin-top: -3px;
}

/* ── RANKING ── */
.est-ranking { display: flex; flex-direction: column; gap: 6px; }
.est-rk-row {
  display: flex;
  align-items: center;
  gap: 9px;
  padding: 7px 10px;
  border-radius: 7px;
  background: rgba(255,255,255,.02);
  border: 1px solid transparent;
  transition: all .18s;
}
.est-rk-row:hover { background: rgba(255,255,255,.04); border-color: var(--border); }
.est-rk-row.top   { background: var(--gold-dim); border-color: var(--border-hi); }
.est-rk-pos {
  font-family: 'Roboto Mono', monospace;
  font-size: 11px; color: var(--txt-lo);
  width: 22px; flex-shrink: 0; text-align: center;
}
.est-rk-row.top .est-rk-pos { color: var(--gold); }
.est-rk-name {
  font-family: 'Roboto', sans-serif;
  font-size: 12px; font-weight: 500; color: var(--txt-hi);
  flex: 1; white-space: nowrap; overflow: hidden; text-overflow: ellipsis;
}
.est-rk-bar-w { width: 55px; height: 3px; background: rgba(255,255,255,.06); border-radius: 2px; overflow: hidden; }
.est-rk-bar-f { height: 100%; border-radius: 2px; transition: width .7s ease; }
.est-rk-val {
  font-family: 'Roboto Mono', monospace;
  font-size: 10px; color: var(--txt-mid);
  white-space: nowrap; min-width: 70px; text-align: right;
}

/* ── GASTOS LIST ── */
.est-gastos { display: flex; flex-direction: column; gap: 5px; }
.est-gasto-row {
  display: flex; align-items: center; gap: 8px;
  padding: 6px 7px; border-radius: 6px; transition: background .15s;
}
.est-gasto-row:hover { background: rgba(255,255,255,.03); }
.est-gasto-ico {
  width: 26px; height: 26px; border-radius: 5px; flex-shrink: 0;
  display: flex; align-items: center; justify-content: center; font-size: 11px;
}
.est-gasto-name {
  font-family: 'Roboto', sans-serif;
  font-size: 11px; color: var(--txt-mid); flex: 1; text-transform: capitalize;
}
.est-gasto-bw { width: 52px; height: 3px; background: rgba(255,255,255,.05); border-radius: 2px; overflow: hidden; }
.est-gasto-bf { height: 100%; border-radius: 2px; transition: width .6s ease; }
.est-gasto-val {
  font-family: 'Roboto Mono', monospace;
  font-size: 10px; color: var(--txt-hi);
  white-space: nowrap; min-width: 80px; text-align: right;
}

/* ── TABS ── */
.est-tabs { display: flex; gap: 3px; background: rgba(255,255,255,.04); border-radius: 7px; padding: 3px; }
.est-tab {
  font-family: 'Roboto', sans-serif;
  font-size: 11px; font-weight: 500; color: var(--txt-lo);
  background: none; border: none; border-radius: 5px;
  padding: 4px 11px; cursor: pointer; transition: all .18s;
}
.est-tab:hover { color: var(--txt-hi); }
.est-tab.active { background: var(--bg-card); color: var(--txt-hi); box-shadow: 0 1px 4px rgba(0,0,0,.3); }

/* ── DIAGNÓSTICO ── */
.est-diag-item {
  display: flex; align-items: flex-start; gap: 12px;
  padding: 12px 14px; border-radius: 9px; margin-bottom: 8px;
}
.est-diag-item:last-child { margin-bottom: 0; }
.est-diag-item i { font-size: 14px; margin-top: 1px; flex-shrink: 0; }
.est-diag-item p {
  font-family: 'Roboto', sans-serif;
  font-size: 12px; color: rgba(240,244,255,.8); line-height: 1.55; margin: 0;
}

/* ── EMPTY ── */
.est-empty {
  display: flex; flex-direction: column; align-items: center;
  justify-content: center; padding: 28px; gap: 7px;
  color: var(--txt-lo); text-align: center;
}
.est-empty i  { font-size: 22px; opacity: .25; }
.est-empty p  { font-family: 'Roboto', sans-serif; font-size: 11px; }

/* ── ESTADO INICIAL ── */
.est-inicial {
  display: flex; flex-direction: column; align-items: center;
  justify-content: center; padding: 70px 20px; gap: 14px; text-align: center;
}
.est-inicial p:first-of-type {
  font-family: 'Roboto', sans-serif;
  font-size: 17px; font-weight: 700; color: var(--txt-mid);
}
.est-inicial p:last-of-type {
  font-family: 'Roboto', sans-serif;
  font-size: 12px; color: var(--txt-lo);
}

/* anim */
@keyframes estFadeUp {
  from { opacity: 0; transform: translateY(10px); }
  to   { opacity: 1; transform: translateY(0); }
}
.est-fadein { animation: estFadeUp .35s ease both; }

/* scrollbar */
.est-dash ::-webkit-scrollbar { width: 4px; height: 4px; }
.est-dash ::-webkit-scrollbar-thumb { background: rgba(255,255,255,.1); border-radius: 3px; }
</style>

<%- include('./layouts/header.ejs') %>

<body>
<div class="est-dash">
<div class="est-pg">

  <!-- TOPBAR -->
  <div class="est-topbar">
    <div>
      <div class="est-eyebrow"><i class="fa-solid fa-chart-mixed"></i>Panel Ejecutivo</div>
      <h1 class="est-h1">Estadísticas</h1>
      <p class="est-sub">Métricas operativas del negocio en tiempo real</p>
    </div>
    <a href="/administracion" class="est-btn-back">
      <i class="fa-solid fa-arrow-left"></i> Administración
    </a>
  </div>

  <!-- FILTROS PERIODO -->
  <div class="est-period-row">
    <div class="est-tabs-periodo">
      <button class="est-tab-p" data-p="semanal">Semana</button>
      <button class="est-tab-p active" data-p="mensual">Mes</button>
      <button class="est-tab-p" data-p="anual">Año</button>
    </div>

    <div id="sub-semanal" class="est-sub-filters" style="display:none">
      <select id="f-anSem"></select>
      <select id="f-mesSem"></select>
      <select id="f-semanaMes">
        <option value="1">Semana 1</option><option value="2">Semana 2</option>
        <option value="3">Semana 3</option><option value="4">Semana 4</option>
        <option value="5">Semana 5</option>
      </select>
    </div>
    <div id="sub-mensual" class="est-sub-filters">
      <select id="f-anMen"></select>
      <select id="f-mesMen"></select>
    </div>
    <div id="sub-anual" class="est-sub-filters" style="display:none">
      <select id="f-anAnu"></select>
    </div>

    <button class="est-btn-run" id="btnActualizar">
      <i class="fa-solid fa-rotate"></i> Actualizar
    </button>
    <div class="est-loading" id="estLoading">
      <div class="est-spin"></div>Cargando…
    </div>
  </div>

  <div class="est-rango" id="estRango">Período: <span id="estRangoTxt">—</span></div>
  <div class="est-err"  id="estErr"></div>

  <!-- ═══════ DASHBOARD ═══════ -->
  <div id="estDash" style="display:none">

    <!-- BALANCE -->
    <div class="est-balance est-fadein">
      <div>
        <div class="estbal-ey">Balance Operativo del Período</div>
        <div class="estbal-val neu" id="bVal">$0</div>
        <div class="estbal-verdict" id="bVerdict">
          <i class="fa-solid fa-circle-info"></i> Cargando análisis…
        </div>
      </div>
      <div class="estbal-cols">
        <div class="estbal-col">
          <div class="estbal-col-lbl">Ingresos</div>
          <div class="estbal-col-val ing" id="bIng">$0</div>
          <div class="estbal-bar"><div class="estbal-bar-f" id="bfIng" style="width:0%;background:var(--blue)"></div></div>
        </div>
        <div class="estbal-col">
          <div class="estbal-col-lbl">Compras</div>
          <div class="estbal-col-val comp" id="bComp">$0</div>
          <div class="estbal-bar"><div class="estbal-bar-f" id="bfComp" style="width:0%;background:var(--red)"></div></div>
        </div>
        <div class="estbal-col">
          <div class="estbal-col-lbl">Gastos</div>
          <div class="estbal-col-val gast" id="bGast">$0</div>
          <div class="estbal-bar"><div class="estbal-bar-f" id="bfGast" style="width:0%;background:rgba(248,113,113,.5)"></div></div>
        </div>
        <div class="estbal-col">
          <div class="estbal-col-lbl">Margen</div>
          <div class="estbal-col-val marg" id="bMarg">0%</div>
          <div class="estbal-bar"><div class="estbal-bar-f" id="bfMarg" style="width:0%;background:var(--green)"></div></div>
        </div>
      </div>
    </div>

    <!-- MÉTRICAS CLAVE -->
    <div class="est-sec"><i class="fa-solid fa-gauge-high" style="color:var(--gold)"></i>Métricas Clave</div>
    <div class="est-kpi-row">
      <div class="est-kpi est-kpi--blue">
        <div class="est-kpi-lbl"><i class="fa-solid fa-file-invoice-dollar"></i>Ventas A</div>
        <div class="est-kpi-val" id="kVA">—</div>
        <div class="est-kpi-sub">Ingresos facturados</div>
      </div>
      <div class="est-kpi est-kpi--purple">
        <div class="est-kpi-lbl"><i class="fa-solid fa-file-lines"></i>Ventas B</div>
        <div class="est-kpi-val" id="kVB">—</div>
        <div class="est-kpi-sub">Ingresos presupuestados</div>
      </div>
      <div class="est-kpi est-kpi--red">
        <div class="est-kpi-lbl"><i class="fa-solid fa-cart-shopping"></i>Compras</div>
        <div class="est-kpi-val" id="kComp">—</div>
        <div class="est-kpi-sub">Stock e insumos</div>
      </div>
      <div class="est-kpi est-kpi--gold">
        <div class="est-kpi-lbl"><i class="fa-solid fa-coins"></i>Gastos Op.</div>
        <div class="est-kpi-val" id="kGast">—</div>
        <div class="est-kpi-sub">Servicios, sueldos, otros</div>
      </div>
      <div class="est-kpi est-kpi--green">
        <div class="est-kpi-lbl"><i class="fa-solid fa-percent"></i>Margen Bruto</div>
        <div class="est-kpi-val" id="kMarg">—</div>
        <div class="est-kpi-sub">(Ventas − Compras) / Ventas</div>
      </div>
    </div>

    <!-- INDICADORES FINANCIEROS -->
    <div class="est-sec"><i class="fa-solid fa-sliders" style="color:var(--purple)"></i>Indicadores Financieros</div>
    <div class="est-ratio-row">
      <div class="est-ratio">
        <div class="est-ratio-num" id="rRent" style="color:var(--green)">—</div>
        <div class="est-ratio-lbl">Rentabilidad Neta</div>
        <div class="est-ratio-desc">Balance / Ingresos</div>
      </div>
      <div class="est-ratio">
        <div class="est-ratio-num" id="rCV"   style="color:var(--blue)">—</div>
        <div class="est-ratio-lbl">Compra / Venta</div>
        <div class="est-ratio-desc">% de ventas en compras</div>
      </div>
      <div class="est-ratio">
        <div class="est-ratio-num" id="rGV"   style="color:var(--gold)">—</div>
        <div class="est-ratio-lbl">Gastos / Ventas</div>
        <div class="est-ratio-desc">Peso gastos sobre ingresos</div>
      </div>
      <div class="est-ratio">
        <div class="est-ratio-num" id="rPA"   style="color:var(--purple)">—</div>
        <div class="est-ratio-lbl">Participación A</div>
        <div class="est-ratio-desc">Factura A / Total ventas</div>
      </div>
    </div>

    <!-- EVOLUCIÓN TEMPORAL -->
    <div class="est-sec"><i class="fa-solid fa-chart-line" style="color:var(--blue)"></i>Evolución Temporal</div>
    <div class="est-card" style="margin-bottom:20px">
      <div class="est-card-hdr">
        <div class="est-card-title" style="--cac:var(--blue)">
          <i class="fa-solid fa-chart-area"></i>Ventas · Compras · Gastos
        </div>
        <div class="est-tabs" id="evolTabs">
          <button class="est-tab active" data-t="linea">Línea</button>
          <button class="est-tab" data-t="barra">Barras</button>
        </div>
      </div>
      <div class="est-card-body">
        <div class="est-ch-md"><canvas id="cEvol"></canvas></div>
      </div>
    </div>

    <!-- DISTRIBUCIÓN VENTAS + TOP PROVEEDORES -->
    <div class="est-g-4060">
      <div class="est-card" style="--cac:var(--blue)">
        <div class="est-card-hdr">
          <div class="est-card-title"><i class="fa-solid fa-chart-pie"></i>Distribución Ventas</div>
          <span class="est-card-badge">A vs B</span>
        </div>
        <div class="est-card-body">
          <div class="est-pie-wrap">
            <div class="est-pie-cw"><canvas id="cVentasPie"></canvas></div>
            <div class="est-legend" id="legVentas">
              <div class="est-empty"><i class="fa-solid fa-chart-pie"></i><p>Sin datos</p></div>
            </div>
          </div>
        </div>
      </div>

      <div class="est-card" style="--cac:var(--red)">
        <div class="est-card-hdr">
          <div class="est-card-title"><i class="fa-solid fa-truck"></i>Top Proveedores</div>
          <span class="est-card-badge">Por compras del período</span>
        </div>
        <div class="est-card-body">
          <div class="est-ranking" id="rkProv">
            <div class="est-empty"><i class="fa-solid fa-truck"></i><p>Cargando…</p></div>
          </div>
        </div>
      </div>
    </div>

    <!-- PRODUCTOS MÁS VENDIDOS + COMPRAS PIE -->
    <div class="est-g-6040">
      <div class="est-card" style="--cac:var(--green)">
        <div class="est-card-hdr">
          <div class="est-card-title"><i class="fa-solid fa-trophy"></i>Productos más Vendidos</div>
          <span class="est-card-badge">Por cantidad vendida</span>
        </div>
        <div class="est-card-body">
          <div class="est-ranking" id="rkProd">
            <div class="est-empty"><i class="fa-solid fa-trophy"></i><p>Cargando…</p></div>
          </div>
        </div>
      </div>

      <div class="est-card" style="--cac:var(--red)">
        <div class="est-card-hdr">
          <div class="est-card-title"><i class="fa-solid fa-chart-donut"></i>Compras por Tipo</div>
          <span class="est-card-badge">A · B</span>
        </div>
        <div class="est-card-body">
          <div class="est-pie-wrap">
            <div class="est-pie-cw"><canvas id="cComprasPie"></canvas></div>
            <div class="est-legend" id="legCompras">
              <div class="est-empty"><i class="fa-solid fa-chart-pie"></i><p>Sin datos</p></div>
            </div>
          </div>
        </div>
      </div>
    </div>

    <!-- GASTOS OPERATIVOS -->
    <div class="est-sec"><i class="fa-solid fa-receipt" style="color:var(--gold)"></i>Gastos Operativos</div>
    <div class="est-g2">
      <div class="est-card" style="--cac:var(--gold)">
        <div class="est-card-hdr">
          <div class="est-card-title"><i class="fa-solid fa-list-ul"></i>Desglose por Categoría</div>
        </div>
        <div class="est-card-body">
          <div class="est-gastos" id="gastosLista">
            <div class="est-empty"><i class="fa-solid fa-receipt"></i><p>Sin gastos registrados</p></div>
          </div>
        </div>
      </div>

      <div class="est-card" style="--cac:var(--gold)">
        <div class="est-card-hdr">
          <div class="est-card-title"><i class="fa-solid fa-chart-pie"></i>Distribución Gastos</div>
        </div>
        <div class="est-card-body">
          <div class="est-pie-wrap">
            <div class="est-pie-cw"><canvas id="cGastosPie"></canvas></div>
            <div class="est-legend" id="legGastos">
              <div class="est-empty"><i class="fa-solid fa-chart-pie"></i><p>Sin datos</p></div>
            </div>
          </div>
        </div>
      </div>
    </div>

    <!-- DIAGNÓSTICO -->
    <div class="est-sec"><i class="fa-solid fa-magnifying-glass-chart" style="color:var(--green)"></i>Diagnóstico del Negocio</div>
    <div class="est-card" style="margin-bottom:24px">
      <div class="est-card-body" id="diagPanel">
        <div class="est-empty"><i class="fa-solid fa-magnifying-glass"></i><p>Cargando diagnóstico…</p></div>
      </div>
    </div>

  </div><!-- /estDash -->

  <!-- ESTADO INICIAL -->
  <div class="est-inicial" id="estInicial">
    <i class="fa-solid fa-chart-mixed" style="font-size:44px;color:var(--gold);opacity:.35"></i>
    <p>Seleccioná el período y presioná Actualizar</p>
    <p>El dashboard cargará ventas, compras, gastos, proveedores y balance operativo.</p>
  </div>

</div><!-- /est-pg -->
</div><!-- /est-dash -->

<script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
<script src="/js/estadisticas.js"></script>
<%- include('./layouts/footer.ejs') %>
</body>
