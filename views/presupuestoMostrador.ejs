<% var pageCss = '/css/pages/presupuestoMostrador.css' %>
<!DOCTYPE html>
<html lang="es">
<%- include('./layouts/head.ejs') %>
<link rel="stylesheet" href="/css/pages/presupuestoMostrador.css?v=1" />
<body>
  <%- include('./layouts/header.ejs') %>

  <main class="presupuesto-main">

    <!-- PAGE HEADER -->
    <div class="presupuesto-page-header">
      <div class="presupuesto-page-header__left">
        <span class="presupuesto-page-header__eyebrow">Mostrador</span>
        <h1 class="presupuesto-page-header__title">
          Nuevo Presupuesto <span class="presupuesto-page-header__id">#<%= idPresupuesto %></span>
        </h1>
      </div>
      <a href="/productos/listadoPresupuestos" class="presupuesto-btn presupuesto-btn--outline">
        <i class="fa-solid fa-list"></i> Listado de Presupuestos
      </a>
    </div>

    <form id="invoice-form">

      <!-- PANEL TOP: vendedor / fecha -->
      <div class="presupuesto-panel presupuesto-panel--top">
        <div class="presupuesto-top-grid">

          <div class="presupuesto-field">
            <label class="presupuesto-label" for="nombre-cliente">
              <i class="fa-solid fa-user"></i> Vendedor Responsable
            </label>
            <select id="nombre-cliente" name="nombreCliente" class="presupuesto-select" required>
              <option value="">Seleccionar vendedor</option>
              <option value="CHACHO">CHACHO</option>
              <option value="GERARDO">GERARDO</option>
              <option value="WALTER">WALTER</option>
            </select>
          </div>

          <div class="presupuesto-field">
            <label class="presupuesto-label" for="fecha-presupuesto">
              <i class="fa-solid fa-calendar"></i> Fecha
            </label>
            <input type="date" id="fecha-presupuesto" name="fechaPresupuesto" class="presupuesto-input" />
          </div>

        </div>
      </div>

      <!-- PANEL BUSCADOR -->
      <div class="presupuesto-panel presupuesto-panel--buscador">
        <div class="presupuesto-buscador-wrap">
          <i class="fa-solid fa-magnifying-glass presupuesto-buscador-icon"></i>
          <input
            type="text"
            id="entradaBusqueda"
            name="searchInput"
            placeholder="Buscar producto... Ej: Escort, Óptica, Faro, Agile"
            autocomplete="off"
            class="presupuesto-buscador-input"
          />
        </div>
        <div id="resultadosBusqueda" class="presupuesto-resultados"></div>
      </div>

      <!-- PANEL TABLA -->
      <div class="presupuesto-panel presupuesto-panel--tabla">
        <table id="tabla-factura" class="presupuesto-tabla">
          <thead>
            <tr>
              <th style="width:80px">Imagen</th>
              <th style="width:130px">Código</th>
              <th>Descripción</th>
              <th style="width:160px">Precio Unitario</th>
              <th style="width:160px">Cantidad</th>
              <th style="width:90px">Stock</th>
              <th style="width:150px">Subtotal</th>
              <th style="width:60px"></th>
            </tr>
          </thead>
          <tbody>
            <% for(let i = 0; i < 10; i++) { %>
              <tr>
                <td><img src="" class="miniatura-tabla" style="display:none;"></td>
                <td class="presupuesto-tabla__codigo"></td>
                <td class="presupuesto-tabla__desc"></td>
                <td><input type="text" class="presupuesto-tabla__input presupuesto-tabla__input--precio precio-editable" disabled></td>
                <td><input type="number" min="1" value="0" class="presupuesto-tabla__input presupuesto-tabla__input--qty" disabled></td>
                <td class="presupuesto-tabla__stock"></td>
                <td class="presupuesto-tabla__subtotal"></td>
                <td>
                  <button type="button" class="presupuesto-tabla__btn-eliminar" style="display:none;">
                    <i class="fas fa-trash"></i>
                  </button>
                </td>
              </tr>
            <% } %>
          </tbody>
        </table>
      </div>

      <!-- PANEL FOOTER -->
      <div class="presupuesto-panel presupuesto-panel--footer">
        <div class="presupuesto-footer-totales">
          <div class="presupuesto-total-row">
            <span class="presupuesto-total-label">Total</span>
            <input type="text" id="total-amount" name="totalPresupuesto" class="presupuesto-total-input" readonly>
          </div>
        </div>
        <div class="presupuesto-footer-acciones">
          <button type="submit" class="presupuesto-btn presupuesto-btn--primary presupuesto-btn--lg">
            <i class="fa-solid fa-floppy-disk"></i> Guardar Presupuesto
          </button>
        </div>
      </div>

    </form>
  </main>

  <%- include('./layouts/footer.ejs') %>
  <script src="/js/pages/buscadorPresupuesto.js?v=1"></script>
</body>
</html>
