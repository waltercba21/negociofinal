<!DOCTYPE html>
<html lang="es">
<head>
  <%- include('layouts/head') %>
  <meta charset="utf-8"/>
  <title>Gastos — Autofaros</title>
  <link rel="stylesheet" href="/css/pages/gastos.css">
  <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
</head>
<body>
  <%- include('layouts/header') %>

  <main class="gastos-main">
    <div class="gastos-wrap">

      <!-- PAGE HEADER -->
      <div class="gastos-page-header">
        <div>
          <span class="gastos-eyebrow">Administración</span>
          <h1 class="gastos-title">Gastos</h1>
        </div>
        <a href="/administracion" class="gastos-back">
          <i class="fa-solid fa-arrow-left"></i> Volver
        </a>
      </div>

      <!-- PANEL: REGISTRAR GASTO -->
      <div class="gastos-panel">
        <div class="gastos-panel__header">
          <div class="gastos-panel__icon">
            <i class="fa-solid fa-plus"></i>
          </div>
          <h2 class="gastos-panel__title">Registrar gasto</h2>
        </div>
        <div class="gastos-panel__body">

          <form class="gastos-form" action="/administracion/gastos" method="POST" id="form-gasto">

            <div class="gastos-field">
              <label class="gastos-label" for="categoria">Categoría</label>
              <select id="categoria" name="categoria" class="gastos-select" required>
                <% (categorias || []).forEach(c => { %>
                  <option value="<%= c %>"><%= c.toUpperCase() %></option>
                <% }) %>
              </select>
            </div>

            <div class="gastos-field">
              <label class="gastos-label" for="tipo">Tipo</label>
              <select id="tipo" name="tipo" class="gastos-select" required>
                <option value="" disabled selected>Seleccione tipo</option>
                <option value="A">A</option>
                <option value="B">B</option>
              </select>
            </div>

            <div class="gastos-field">
              <label class="gastos-label" for="fecha">Fecha</label>
              <input type="date" id="fecha" name="fecha" value="<%= hoy %>" class="gastos-input" required>
            </div>

            <div class="gastos-field">
              <label class="gastos-label" for="monto">Monto ($)</label>
              <input type="number" id="monto" name="monto" step="0.01" min="0" placeholder="0.00" class="gastos-input" required>
            </div>

            <div class="gastos-field gastos-field--full">
              <label class="gastos-label" for="descripcion">Descripción <span style="font-weight:400;opacity:.5;text-transform:none;letter-spacing:0;">(opcional)</span></label>
              <textarea id="descripcion" name="descripcion" class="gastos-textarea" rows="2" placeholder="Detalle breve del gasto..."></textarea>
            </div>

            <input type="hidden" name="administrador" value="<%= (typeof userLogged !== 'undefined' && userLogged?.nombre) ? userLogged.nombre : 'admin' %>">

            <div class="gastos-submit-row">
              <button type="submit" class="gastos-btn-submit">
                <i class="fa-solid fa-floppy-disk"></i> Guardar gasto
              </button>
            </div>

          </form>

          <!-- Totales -->
          <div class="gastos-totales" style="margin-top: 18px;">
            <span class="gastos-totales__label">Totales</span>
            <span class="gastos-totales__chip gastos-totales__chip--a">
              <span class="chip-key">A</span>
              <span id="g-totA">$ 0,00</span>
            </span>
            <span class="gastos-totales__chip gastos-totales__chip--b">
              <span class="chip-key">B</span>
              <span id="g-totB">$ 0,00</span>
            </span>
            <span class="gastos-totales__chip gastos-totales__chip--total">
              <span class="chip-key">Total</span>
              <span id="g-totTotal">$ 0,00</span>
            </span>
          </div>

        </div>
      </div>

      <!-- PANEL: TABLA ÚLTIMOS 30 DÍAS -->
      <div class="gastos-panel">
        <div class="gastos-panel__header">
          <div class="gastos-panel__icon">
            <i class="fa-solid fa-table-list"></i>
          </div>
          <h2 class="gastos-panel__title">Últimos 30 días</h2>
        </div>

        <div class="gastos-tabla-wrap">
          <% if ((gastos || []).length === 0) { %>
            <div class="gastos-empty">
              <i class="fa-solid fa-inbox gastos-empty__icon"></i>
              <p>Sin registros recientes.</p>
            </div>
          <% } else { %>
            <table class="gastos-tabla">
              <thead>
                <tr>
                  <th>Fecha</th>
                  <th>Categoría</th>
                  <th>Tipo</th>
                  <th>Descripción</th>
                  <th class="text-right">Monto</th>
                  <th></th>
                </tr>
              </thead>
              <tbody>
                <% gastos.forEach(g => { %>
                  <tr>
                    <td class="col-fecha">
                      <%= new Date(g.fecha).toLocaleDateString('es-AR') %>
                    </td>
                    <td class="col-categoria"><%= g.categoria %></td>
                    <td>
                      <span class="gastos-tipo-badge gastos-tipo-badge--<%= (g.tipo || '').toLowerCase() %>">
                        <%= g.tipo %>
                      </span>
                    </td>
                    <td class="col-descripcion" title="<%= g.descripcion || '' %>">
                      <%= g.descripcion || '—' %>
                    </td>
                    <td class="col-monto">
                      $ <%= Number(g.monto).toLocaleString('es-AR', { minimumFractionDigits: 2 }) %>
                    </td>
                    <td class="col-acciones">
                      <form action="/administracion/gastos/<%= g.id %>/eliminar" method="POST"
                            onsubmit="return confirmarEliminar(event)">
                        <button type="submit" class="gastos-btn-eliminar">
                          <i class="fa-solid fa-trash-can"></i> Eliminar
                        </button>
                      </form>
                    </td>
                  </tr>
                <% }) %>
              </tbody>
            </table>
          <% } %>
        </div>
      </div>

    </div><!-- /gastos-wrap -->
  </main>

  <script>
    // ── Confirmación eliminar con SweetAlert ──────────────────────
    function confirmarEliminar(e) {
      e.preventDefault();
      const form = e.target;
      if (window.Swal) {
        Swal.fire({
          title: '¿Eliminar gasto?',
          text: 'Esta acción no se puede deshacer.',
          icon: 'warning',
          showCancelButton: true,
          confirmButtonText: 'Sí, eliminar',
          cancelButtonText: 'Cancelar',
          reverseButtons: true,
          background: '#111c30',
          color: '#f0f4ff',
          confirmButtonColor: '#d90429',
          cancelButtonColor: 'rgba(31,72,126,0.4)'
        }).then(r => { if (r.isConfirmed) form.submit(); });
      } else {
        if (confirm('¿Estás seguro de eliminar este gasto?')) form.submit();
      }
      return false;
    }

    // ── Alerta al cambiar la fecha ────────────────────────────────
    (function () {
      const $fecha = document.getElementById('fecha');
      if (!$fecha) return;
      const valorInicial = $fecha.value;
      $fecha.addEventListener('change', async (e) => {
        const nuevo = e.target.value;
        if (nuevo === valorInicial) return;
        let ok = true;
        if (window.Swal) {
          const r = await Swal.fire({
            title: '⚠️ Cuidado',
            text: 'Estás por cambiar la fecha del gasto. ¿Confirmás?',
            icon: 'warning',
            showCancelButton: true,
            confirmButtonText: 'Sí, cambiar',
            cancelButtonText: 'No, volver',
            reverseButtons: true,
            background: '#111c30',
            color: '#f0f4ff',
            confirmButtonColor: '#1F487E',
            cancelButtonColor: 'rgba(31,72,126,0.3)'
          });
          ok = r.isConfirmed;
        } else {
          ok = confirm('Estás por cambiar la fecha del gasto. ¿Confirmás?');
        }
        if (!ok) e.target.value = valorInicial;
      });

      // ── Validación monto positivo ─────────────────────────────────
      const $monto = document.getElementById('monto');
      const $form  = document.getElementById('form-gasto');
      $form.addEventListener('submit', (ev) => {
        const v = parseFloat($monto.value || '0');
        if (isNaN(v) || v <= 0) {
          ev.preventDefault();
          if (window.Swal) {
            Swal.fire({
              title: 'Monto inválido',
              text: 'Ingresá un monto mayor a 0.',
              icon: 'error',
              background: '#111c30',
              color: '#f0f4ff',
              confirmButtonColor: '#1F487E'
            });
          } else {
            alert('Ingresá un monto mayor a 0');
          }
        }
      });
    })();
  </script>

  <%- include('layouts/footer') %>
</body>
</html>
