<% var pageCss = '/css/pages/crear.css' %>
<!DOCTYPE html>
<html lang="es">
<%- include('./layouts/head.ejs') %>
<link rel="stylesheet" href="/css/pages/crear.css?v=1" />
<body>
<%- include('./layouts/header.ejs') %>

<%
  const _escCod   = Array.isArray(escobillasCodigos) ? escobillasCodigos : [];
  const _escKit   = (escobillasKit && typeof escobillasKit === 'object') ? escobillasKit : null;
  const _tipoInit = _escKit ? 'kit' : 'unidad';
  const _uniTec   = (_escCod[0] && _escCod[0].tecnologia) ? String(_escCod[0].tecnologia) : 'FLEX';
  const _uniCod   = (_escCod[0] && _escCod[0].codigo)     ? String(_escCod[0].codigo)     : '';
  const _kitTec   = (_escKit && _escKit.tecnologia)  ? String(_escKit.tecnologia)  : 'FLEX';
  const _kitCon   = (_escKit && _escKit.conductor)   ? String(_escKit.conductor)   : '';
  const _kitAco   = (_escKit && _escKit.acompanante) ? String(_escKit.acompanante) : '';
  const _codJsonInit = JSON.stringify(_escCod || []);
  const _kitJsonInit = JSON.stringify(_escKit || {});
%>

<main class="cr-main">
  <div class="cr-wrap">

    <!-- PAGE HEADER -->
    <div class="cr-page-header">
      <div>
        <span class="cr-eyebrow">Productos</span>
        <h1 class="cr-title">Editar Producto <span style="color:#1F487E;font-size:0.65em;">#<%= producto.id %></span></h1>
      </div>
      <a href="/productos/panelControl?pagina=<%= producto.paginaActual %>&busqueda=<%= encodeURIComponent(producto.busqueda || '') %>" class="cr-btn cr-btn--outline">
        <i class="fa-solid fa-arrow-left"></i> Volver al panel
      </a>
    </div>

    <form class="cr-form" method="POST" action="/productos/actualizar/<%= producto.id %>" enctype="multipart/form-data" data-producto-id="<%= producto.id %>">

      <!-- Hiddens de navegación -->
      <input type="hidden" name="pagina"       value="<%= producto.paginaActual %>">
      <input type="hidden" name="busqueda"     value="<%= producto.busqueda || '' %>">
      <input type="hidden" name="id"           value="<%= producto.id %>">
      <input type="hidden" name="paginaActual" value="<%= producto.paginaActual %>">
      <input type="hidden" id="iva_producto"   name="IVA_producto" value="<%= producto.IVA || 21 %>">
      <input type="hidden" id="proveedor_designado" name="proveedor_designado" value="<%= producto.proveedor_id || '' %>">

      <div class="cr-grid">

        <!-- ══════════════════════════════
             COLUMNA 1: CARACTERÍSTICAS
        ══════════════════════════════ -->
        <div class="cr-panel">
          <div class="cr-panel__hd">
            <i class="fa-solid fa-tag"></i>
            <strong>Características</strong>
          </div>
          <div class="cr-panel__bd">

            <!-- Imágenes existentes -->
            <div class="cr-field">
              <label class="cr-label">Imágenes</label>
              <div id="preview" class="imagen-miniatura-contenedor">
                <% if (producto && producto.imagenes && producto.imagenes.length > 0) { %>
                  <% producto.imagenes.forEach((imagen) => { %>
                    <div data-imagen-id="<%= imagen.id %>"
                         data-id="<%= imagen.id %>"
                         data-type="existente"
                         class="preview-img thumb">
                      <img class="imagen-miniatura" src="<%= imagen.imagen %>" alt="Imagen del producto">
                    </div>
                  <% }); %>
                <% } %>
              </div>
              <label class="cr-file-zone" for="imagen" style="margin-top:8px">
                <i class="fa-solid fa-cloud-arrow-up cr-file-zone__icon"></i>
                <span class="cr-file-zone__text">Agregar más imágenes</span>
                <input id="imagen" type="file" name="archivos[]" multiple class="cr-file-input">
              </label>
              <p class="cr-hint">• Clic: marcar portada &nbsp;•&nbsp; Clic en ✕: eliminar &nbsp;•&nbsp; Arrastrar: reordenar</p>
            </div>

            <!-- Nombre -->
            <div class="cr-field">
              <label class="cr-label" for="nombre">Nombre</label>
              <input id="nombre" type="text" name="nombre" required class="cr-input"
                value="<%= producto ? producto.nombre : '' %>">
            </div>

            <!-- Descripción -->
            <div class="cr-field">
              <label class="cr-label" for="descripcion">Descripción</label>
              <textarea id="descripcion" name="descripcion" rows="5" class="cr-input cr-textarea"><%= producto ? producto.descripcion : '' %></textarea>
            </div>

            <!-- Categoría -->
            <div class="cr-field">
              <label class="cr-label" for="categoria">Categoría</label>
              <select id="categoria" name="categoria" class="cr-select">
                <option value="" <%= !producto || !producto.categoria_id ? 'selected' : '' %>>Seleccioná una categoría</option>
                <% categorias.forEach(function(categoria) { %>
                  <option value="<%= categoria.id %>" <%= producto && producto.categoria_id == categoria.id ? 'selected' : '' %>><%= categoria.nombre %></option>
                <% }); %>
              </select>
            </div>

            <!-- Escobillas (condicional) -->
            <div id="escobillasSection" class="cr-escobillas" style="display:none">
              <div class="cr-escobillas__hd">
                <i class="fa-solid fa-wiper"></i> Datos de Escobillas (TRICO)
              </div>
              <input type="hidden" id="escobillas_tipo"         name="escobillas_tipo"         value="<%= _tipoInit %>">
              <input type="hidden" id="escobillas_codigos_json" name="escobillas_codigos_json" value="<%= _codJsonInit %>">
              <input type="hidden" id="escobillas_kit_json"     name="escobillas_kit_json"     value="<%= _kitJsonInit %>">

              <div class="cr-field" style="padding:10px 14px 0">
                <label class="cr-label" for="esc_formato">Formato</label>
                <select id="esc_formato" name="esc_formato" class="cr-select">
                  <option value="unidad" <%= (!_tipoInit || _tipoInit === 'unidad') ? 'selected' : '' %>>Unidad</option>
                  <option value="kit"    <%= (_tipoInit === 'kit') ? 'selected' : '' %>>Kit (Conductor + Acompañante)</option>
                </select>
              </div>

              <div id="esc_unidad_block" style="padding:0 14px 10px">
                <div class="cr-field" style="margin-top:10px">
                  <label class="cr-label" for="esc_tecnologia">Tecnología</label>
                  <select id="esc_tecnologia" name="esc_tecnologia" class="cr-select">
                    <option value="FLEX"  <%= String(_uniTec).toUpperCase()==='FLEX'  ? 'selected' : '' %>>FLEX</option>
                    <option value="STEEL" <%= String(_uniTec).toUpperCase()==='STEEL' ? 'selected' : '' %>>STEEL</option>
                    <option value="REAR"  <%= String(_uniTec).toUpperCase()==='REAR'  ? 'selected' : '' %>>REAR (Trasera)</option>
                  </select>
                </div>
                <div class="cr-field" style="margin-top:10px">
                  <label class="cr-label" for="esc_codigo">Código TRICO</label>
                  <input type="text" id="esc_codigo" name="esc_codigo" placeholder="Ej: 10707" autocomplete="off" class="cr-input" value="<%= _uniCod %>">
                </div>
              </div>

              <div id="esc_kit_block" style="display:none;padding:0 14px 10px">
                <div class="cr-field" style="margin-top:10px">
                  <label class="cr-label" for="esc_kit_tecnologia">Tecnología del kit</label>
                  <select id="esc_kit_tecnologia" name="esc_kit_tecnologia" class="cr-select">
                    <option value="FLEX"  <%= String(_kitTec).toUpperCase()==='FLEX'  ? 'selected' : '' %>>FLEX</option>
                    <option value="STEEL" <%= String(_kitTec).toUpperCase()==='STEEL' ? 'selected' : '' %>>STEEL</option>
                  </select>
                </div>
                <div class="cr-field" style="margin-top:10px">
                  <label class="cr-label" for="esc_kit_conductor">Código TRICO Conductor</label>
                  <input type="text" id="esc_kit_conductor" name="esc_kit_conductor" placeholder="Ej: 10707" autocomplete="off" class="cr-input" value="<%= _kitCon %>">
                </div>
                <div class="cr-field" style="margin-top:10px">
                  <label class="cr-label" for="esc_kit_acompanante">Código TRICO Acompañante</label>
                  <input type="text" id="esc_kit_acompanante" name="esc_kit_acompanante" placeholder="Ej: 10708" autocomplete="off" class="cr-input" value="<%= _kitAco %>">
                </div>
              </div>
            </div>

            <!-- Marca / Modelo -->
            <div class="cr-field">
              <label class="cr-label" for="marca">Marca</label>
              <select id="marca" name="marca" class="cr-select">
                <option value="" <%= !producto || !producto.marca_id ? 'selected' : '' %>>Seleccioná una marca</option>
                <% marcas.forEach(function(marca) { %>
                  <option value="<%= marca.id %>" <%= producto && producto.marca_id == marca.id ? 'selected' : '' %>><%= marca.nombre %></option>
                <% }); %>
              </select>
            </div>

            <div class="cr-field">
              <label class="cr-label" for="modelo_id">Modelo</label>
              <select id="modelo_id" name="modelo_id" class="cr-select" data-selected="<%= producto ? producto.modelo_id : '' %>">
                <option value="" <%= !producto || !producto.modelo_id ? 'selected' : '' %>>Seleccioná un modelo</option>
                <% modelos.forEach(function(modelo) { %>
                  <option value="<%= modelo.id %>" <%= producto && producto.modelo_id == modelo.id ? 'selected' : '' %>><%= modelo.nombre %></option>
                <% }); %>
              </select>
            </div>

          </div>
        </div>

        <!-- ══════════════════════════════
             COLUMNA 2: PROVEEDORES
        ══════════════════════════════ -->
        <div class="cr-panel">
          <div class="cr-panel__hd">
            <i class="fa-solid fa-truck"></i>
            <strong>Proveedores y costos</strong>
          </div>
          <div class="cr-panel__bd">

            <!-- Calidades + Oferta -->
            <div class="cr-calidades-group">
              <span class="cr-label cr-calidades-group__title">Calidades y estado</span>
              <p class="cr-hint" style="margin:0 0 4px;">Solo una calidad puede estar activa a la vez.</p>

              <%
                const _calActiva =
                  producto.calidad_original         === 1 ? 'fitam'   :
                  producto.calidad_vic              === 1 ? 'vic'     :
                  producto.calidad_mm               === 1 ? 'mm'      :
                  producto.calidad_original_premium === 1 ? 'premium' : '';
              %>

              <div class="cr-field cr-field--inline">
                <label class="cr-label" for="calidad_original">Calidad FITAM</label>
                <label class="cr-toggle cr-toggle--fitam">
                  <input type="radio" id="calidad_original" name="calidad_grupo" value="fitam" class="cr-toggle__input"
                    <%= _calActiva === 'fitam' ? 'checked' : '' %>>
                  <span class="cr-toggle__slider"></span>
                </label>
              </div>

              <div class="cr-field cr-field--inline">
                <label class="cr-label" for="calidad_vic">Calidad VIC</label>
                <label class="cr-toggle cr-toggle--vic">
                  <input type="radio" id="calidad_vic" name="calidad_grupo" value="vic" class="cr-toggle__input"
                    <%= _calActiva === 'vic' ? 'checked' : '' %>>
                  <span class="cr-toggle__slider"></span>
                </label>
              </div>

              <div class="cr-field cr-field--inline">
                <label class="cr-label" for="calidad_mm">Magnetti Marelli</label>
                <label class="cr-toggle cr-toggle--mm">
                  <input type="radio" id="calidad_mm" name="calidad_grupo" value="mm" class="cr-toggle__input"
                    <%= _calActiva === 'mm' ? 'checked' : '' %>>
                  <span class="cr-toggle__slider"></span>
                </label>
              </div>

              <div class="cr-field cr-field--inline">
                <label class="cr-label" for="calidad_original_premium">Original</label>
                <label class="cr-toggle cr-toggle--premium">
                  <input type="radio" id="calidad_original_premium" name="calidad_grupo" value="premium" class="cr-toggle__input"
                    <%= _calActiva === 'premium' ? 'checked' : '' %>>
                  <span class="cr-toggle__slider"></span>
                </label>
              </div>

              <!-- Hiddens para el backend -->
              <input type="hidden" id="h_calidad_original"         name="calidad_original"         value="<%= _calActiva === 'fitam'   ? '1' : '0' %>">
              <input type="hidden" id="h_calidad_vic"              name="calidad_vic"              value="<%= _calActiva === 'vic'     ? '1' : '0' %>">
              <input type="hidden" id="h_calidad_mm"               name="calidad_mm"               value="<%= _calActiva === 'mm'      ? '1' : '0' %>">
              <input type="hidden" id="h_calidad_original_premium" name="calidad_original_premium" value="<%= _calActiva === 'premium' ? '1' : '0' %>">

              <div class="cr-sep" style="margin:8px 0"></div>

              <div class="cr-field cr-field--inline">
                <label class="cr-label" for="oferta">En oferta</label>
                <label class="cr-toggle cr-toggle--oferta">
                  <input type="hidden" name="oferta" value="0">
                  <input type="checkbox" id="oferta" name="oferta" value="1" class="cr-toggle__input"
                    <%= producto.oferta ? 'checked' : '' %>>
                  <span class="cr-toggle__slider"></span>
                </label>
              </div>
            </div>

            <!-- Proveedor asignado -->
            <div class="cr-field">
              <label class="cr-label">Proveedor asignado <span class="cr-hint-inline">(costo IVA más bajo)</span></label>
              <div id="proveedorAsignado" class="cr-input cr-input--readonly"></div>
            </div>

            <div class="cr-sep"></div>

            <!-- Bloques de proveedores existentes -->
            <div id="proveedoresContainer">

              <% if (productoProveedores && productoProveedores.length > 0) { %>
                <% productoProveedores.forEach(function(productoProveedor) {
                   const _ivaProv = Number(String(productoProveedor.iva ?? producto.IVA ?? 21).replace(',', '.')) || 21;
                   const _pres    = (productoProveedor.presentacion || 'unidad').toLowerCase();
                   const _factor  = _pres === 'juego' ? 0.5 : 1;
                   const _civaSrv = (typeof productoProveedor.costo_iva === 'number'
                                     ? productoProveedor.costo_iva
                                     : parseFloat(productoProveedor.costo_iva || 0));
                %>
                  <div class="proveedor cr-prov-card" data-proveedor-id="<%= productoProveedor.proveedor_id %>">

                    <!-- Radio proveedor designado -->
                    <div class="form-group-crear cr-field cr-field--inline">
                      <label class="cr-label">Usar este proveedor</label>
                      <label class="cr-toggle">
                        <input type="radio" name="proveedor_designado_radio" class="proveedor-designado-radio cr-toggle__input"
                          value="<%= productoProveedor.proveedor_id %>"
                          <%= (producto.proveedor_id === productoProveedor.proveedor_id) ? 'checked' : '' %> />
                        <span class="cr-toggle__slider"></span>
                      </label>
                    </div>

                    <div class="form-group-crear cr-field">
                      <label class="label-proveedor cr-label">Proveedor <span class="nombre_proveedor cr-prov-nombre"></span></label>
                      <select class="proveedores cr-select form-control" name="proveedores[]">
                        <% proveedores.forEach(function(proveedor) { %>
                          <option value="<%= proveedor.id %>"
                                  data-descuento="<%= proveedor.descuento %>"
                                  <%= productoProveedor.proveedor_id === proveedor.id ? 'selected' : '' %>>
                            <%= proveedor.nombre %>
                          </option>
                        <% }); %>
                      </select>
                    </div>

                    <div class="form-group-crear cr-field">
                      <label class="label-codigo cr-label">Código proveedor</label>
                      <input class="codigo cr-input form-control" type="text" name="codigo[]" value="<%= productoProveedor.codigo %>">
                    </div>

                    <div class="cr-prov-grid">
                      <div class="form-group-crear cr-field">
                        <label class="label-precio-lista cr-label">Precio de lista</label>
                        <input class="precio_lista cr-input form-control" type="number" step="0.01" name="precio_lista[]" value="<%= productoProveedor.precio_lista %>">
                      </div>
                      <div class="form-group-crear cr-field">
                        <label class="label-descuento cr-label">Descuento prov.</label>
                        <input class="descuentos_proveedor_id cr-input cr-input--readonly form-control" type="text" name="descuentos_proveedor_id[]" value="<%= productoProveedor.descuento %>" readonly>
                      </div>
                    </div>

                    <div class="form-group-crear cr-field">
                      <label class="cr-label">Precio de costo (Neto)</label>
                      <input class="costo_neto cr-input cr-input--readonly form-control" type="number" name="costo_neto[]" value="<%= productoProveedor.costo_neto %>" readonly>
                    </div>

                    <div class="cr-prov-grid">
                      <div class="form-group-crear cr-field">
                        <label class="cr-label">Presentación</label>
                        <select class="presentacion cr-select form-control" name="presentacion[]">
                          <option value="unidad" <%= _pres === 'unidad' ? 'selected' : '' %>>Unidad</option>
                          <option value="juego"  <%= _pres === 'juego'  ? 'selected' : '' %>>Juego (par)</option>
                        </select>
                        <input type="hidden" class="factor_unidad" name="factor_unidad[]" value="<%= _factor %>">
                      </div>
                      <div class="form-group-crear cr-field">
                        <label class="cr-label">IVA</label>
                        <select class="IVA cr-select form-control" name="IVA[]">
                          <option value="21"   <%= _ivaProv === 21   ? 'selected' : '' %>>21%</option>
                          <option value="10.5" <%= _ivaProv === 10.5 ? 'selected' : '' %>>10.5%</option>
                        </select>
                      </div>
                    </div>

                    <div class="form-group-crear cr-field campo-costo-iva">
                      <label class="cr-label">Costo con IVA (por unidad)</label>
                      <input class="costo_iva_vis cr-input cr-input--readonly form-control" type="number" step="0.01" value="" readonly>
                      <input class="costo_iva" type="hidden" name="costo_iva[]" value="<%= isFinite(_civaSrv) ? _civaSrv.toFixed(2) : '0.00' %>">
                    </div>

                    <button class="eliminar-proveedor cr-btn cr-btn--danger cr-btn--sm" type="button" data-proveedor-id="<%= productoProveedor.proveedor_id %>">
                      <i class="fa-solid fa-trash"></i> Eliminar proveedor
                    </button>
                  </div>
                <% }); %>
              <% } else { %>
                <%
                  const _ivaProv0 = Number(String(producto.IVA ?? 21).replace(',', '.')) || 21;
                  const _pres0    = 'unidad';
                  const _factor0  = 1;
                  const _civaSrv0 = 0;
                %>
                <div class="proveedor cr-prov-card" data-proveedor-id="">
                  <div class="form-group-crear cr-field cr-field--inline">
                    <label class="cr-label">Usar este proveedor</label>
                    <label class="cr-toggle">
                      <input type="radio" name="proveedor_designado_radio" class="proveedor-designado-radio cr-toggle__input" value="">
                      <span class="cr-toggle__slider"></span>
                    </label>
                  </div>

                  <div class="form-group-crear cr-field">
                    <label class="label-proveedor cr-label">Proveedor <span class="nombre_proveedor cr-prov-nombre"></span></label>
                    <select class="proveedores cr-select form-control" name="proveedores[]">
                      <option value="">Seleccioná proveedor...</option>
                      <% proveedores.forEach(function(proveedor) { %>
                        <option value="<%= proveedor.id %>" data-descuento="<%= proveedor.descuento %>"><%= proveedor.nombre %></option>
                      <% }); %>
                    </select>
                  </div>

                  <div class="form-group-crear cr-field">
                    <label class="label-codigo cr-label">Código proveedor</label>
                    <input class="codigo cr-input form-control" type="text" name="codigo[]" value="">
                  </div>

                  <div class="cr-prov-grid">
                    <div class="form-group-crear cr-field">
                      <label class="label-precio-lista cr-label">Precio de lista</label>
                      <input class="precio_lista cr-input form-control" type="number" step="0.01" name="precio_lista[]" value="">
                    </div>
                    <div class="form-group-crear cr-field">
                      <label class="label-descuento cr-label">Descuento prov.</label>
                      <input class="descuentos_proveedor_id cr-input cr-input--readonly form-control" type="text" name="descuentos_proveedor_id[]" value="0" readonly>
                    </div>
                  </div>

                  <div class="form-group-crear cr-field">
                    <label class="cr-label">Precio de costo (Neto)</label>
                    <input class="costo_neto cr-input cr-input--readonly form-control" type="number" name="costo_neto[]" value="0" readonly>
                  </div>

                  <div class="cr-prov-grid">
                    <div class="form-group-crear cr-field">
                      <label class="cr-label">Presentación</label>
                      <select class="presentacion cr-select form-control" name="presentacion[]">
                        <option value="unidad">Unidad</option>
                        <option value="juego">Juego (par)</option>
                      </select>
                      <input type="hidden" class="factor_unidad" name="factor_unidad[]" value="1">
                    </div>
                    <div class="form-group-crear cr-field">
                      <label class="cr-label">IVA</label>
                      <select class="IVA cr-select form-control" name="IVA[]">
                        <option value="21"   <%= _ivaProv0 === 21   ? 'selected' : '' %>>21%</option>
                        <option value="10.5" <%= _ivaProv0 === 10.5 ? 'selected' : '' %>>10.5%</option>
                      </select>
                    </div>
                  </div>

                  <div class="form-group-crear cr-field campo-costo-iva">
                    <label class="cr-label">Costo con IVA (por unidad)</label>
                    <input class="costo_iva_vis cr-input cr-input--readonly form-control" type="number" step="0.01" value="" readonly>
                    <input class="costo_iva" type="hidden" name="costo_iva[]" value="<%= _civaSrv0.toFixed(2) %>">
                  </div>

                  <button class="eliminar-proveedor cr-btn cr-btn--danger cr-btn--sm" type="button">
                    <i class="fa-solid fa-trash"></i> Eliminar proveedor
                  </button>
                </div>
              <% } %>

            </div>

            <button id="addProveedor" type="button" class="cr-btn cr-btn--outline cr-btn--full">
              <i class="fa-solid fa-plus"></i> Agregar proveedor
            </button>

          </div>
        </div>

        <!-- ══════════════════════════════
             COLUMNA 3: PRECIO Y STOCK
        ══════════════════════════════ -->
        <div class="cr-panel">
          <div class="cr-panel__hd">
            <i class="fa-solid fa-chart-pie"></i>
            <strong>Precio y stock</strong>
          </div>
          <div class="cr-panel__bd">

            <div class="cr-field">
              <label class="cr-label" for="utilidad">Utilidad (%)</label>
              <input id="utilidad" type="number" name="utilidad" class="cr-input"
                value="<%= producto ? producto.utilidad : '' %>">
            </div>

            <div class="cr-field">
              <label class="cr-label" for="precio_venta">Precio de venta</label>
              <div class="cr-input-prefix-wrap">
                <span class="cr-input-prefix">$</span>
                <input id="precio_venta" type="number" name="precio_venta" class="cr-input cr-input--prefixed"
                  data-manual="false"
                  value="<%= producto ? producto.precio_venta : '' %>">
              </div>
            </div>

            <div class="cr-sep"></div>

            <div class="cr-field">
              <label class="cr-label" for="estado">Estado</label>
              <select id="estado" name="estado" class="cr-select">
                <option value="" <%= !producto || !producto.estado ? 'selected' : '' %>>Seleccioná un estado...</option>
                <option value="activo"   <%= producto && producto.estado == 'activo'   ? 'selected' : '' %>>Activo</option>
                <option value="inactivo" <%= producto && producto.estado == 'inactivo' ? 'selected' : '' %>>Inactivo</option>
              </select>
            </div>

            <div class="cr-field">
              <label class="cr-label" for="stock_minimo">Stock mínimo</label>
              <input type="number" id="stock_minimo" name="stock_minimo" min="0" required class="cr-input"
                value="<%= stock.stock_minimo %>">
            </div>

            <div class="cr-field">
              <label class="cr-label" for="stock_actual">Stock actual</label>
              <input type="number" id="stock_actual" name="stock_actual" min="0" required class="cr-input"
                value="<%= stock.stock_actual %>">
            </div>

            <div class="cr-sep"></div>

            <div class="cr-actions">
              <button type="submit" class="cr-btn cr-btn--primary cr-btn--full">
                <i class="fa-solid fa-floppy-disk"></i> Guardar cambios
              </button>
              <a href="/productos/panelControl?pagina=<%= producto.paginaActual %>&busqueda=<%= encodeURIComponent(producto.busqueda || '') %>" class="cr-btn cr-btn--outline cr-btn--full">
                Cancelar
              </a>
            </div>

          </div>
        </div>

      </div>
    </form>
  </div>
</main>

