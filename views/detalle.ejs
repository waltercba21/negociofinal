<%
  // ── Limpieza de descripción ──────────────────────────────
  const _raw = (producto.descripcion || '').toString();
  const _cleanDescripcion = _raw
    .replace(/\\t/g, ' ').replace(/\t/g, ' ')
    .replace(/\\n/g, '\n').replace(/\r/g, '')
    .replace(/<br\s*\/?\s*>/gi, '\n')
    .replace(/<\/?[^>]+>/g, '')
    .replace(/"\s*>/g, '')
    .replace(/\u00A0/g, ' ')
    .replace(/[ ]{2,}/g, ' ')
    .trim();

  // ── Aplicaciones (escobillas) ────────────────────────────
  const esEscobilla = /escobill/i.test(producto.categoria_nombre || '') || /escobill/i.test(producto.nombre || '');
  const tieneAplic  = esEscobilla && _cleanDescripcion.length > 0;

  function normalizeAplicaciones(raw){
    let s = String(raw ?? '').trim();
    if (!s) return { subtitle:'', lines:[] };
    if (!s.includes('\n')) {
      const m = s.match(/\b[A-ZÁÉÍÓÚÑ]{2,}\b/);
      if (m && typeof m.index === 'number' && m.index > 0) {
        const subtitle = s.slice(0, m.index).trim();
        const rest = s.slice(m.index).trim().replace(/\s+(?=[A-ZÁÉÍÓÚÑ]{2,}\b)/g, '\n');
        s = subtitle + '\n' + rest;
      } else {
        s = s.replace(/\s{2,}/g, '\n');
      }
    }
    const lines = s.split('\n').map(x => x.trim()).filter(Boolean);
    let subtitle = '';
    if (lines.length >= 2 && /^(escobilla|kit|rear)/i.test(lines[0])) subtitle = lines.shift();
    return { subtitle, lines };
  }

  const appsData = normalizeAplicaciones(_cleanDescripcion);
  const preview  = (appsData.lines || []).slice(0, 5);

  // ── Label de calidad ─────────────────────────────────────
  const label = producto.oferta
    ? 'OFERTA'
    : (producto.calidad_original ? 'FITAM' : (producto.calidad_vic ? 'VIC' : ''));

  // ── URL para compartir ───────────────────────────────────
  const _shareText  = encodeURIComponent(producto.nombre || '');
  const _shareUrl   = encodeURIComponent(typeof currentUrl !== 'undefined' ? currentUrl : '');
%>

<% var pageCss = '/css/pages/detalle.css' %>
<!DOCTYPE html>
<html lang="es">
<%- include('./layouts/head.ejs') %>
<link rel="stylesheet" href="/css/pages/detalle.css" />

<body class="det-page" data-is-admin-user="<%= isAdminUser %>" data-is-user-logged-in="<%= isUserLoggedIn %>">

<%- include('./layouts/header.ejs') %>

<div class="det-page">

  <!-- BREADCRUMB -->
  <nav class="det-breadcrumb" aria-label="Ubicación">
    <a href="/"><i class="fa-solid fa-house"></i>&nbsp;Inicio</a>
    <i class="fa-solid fa-chevron-right"></i>
    <a href="/productos">Productos</a>
    <% if (producto.categoria_nombre) { %>
      <i class="fa-solid fa-chevron-right"></i>
      <a href="/productos?categoria=<%= encodeURIComponent(producto.categoria_nombre) %>"><%= producto.categoria_nombre %></a>
    <% } %>
    <i class="fa-solid fa-chevron-right"></i>
    <span style="color:#7aaee8"><%= producto.nombre %></span>
  </nav>

  <!-- SHELL: GALERÍA + INFO -->
  <div class="det-shell">

    <!-- ═══ GALERÍA ═══ -->
    <div class="det-gallery">

      <div class="det-gallery__main" id="det-gallery-main">

        <div class="det-gallery__main-track" id="carousel-detalle">
          <% if (producto.imagenes && producto.imagenes.length > 0) { %>
            <% producto.imagenes.forEach((imgObj, i) => {
                 const file = (imgObj && (imgObj.imagen || imgObj.archivo || imgObj.url))
                   ? (imgObj.imagen || imgObj.archivo || imgObj.url)
                   : imgObj;
            %>
              <img
                class="det-gallery__img<%= i !== 0 ? ' hidden' : '' %>"
                src="/uploads/productos/<%= file %>"
                alt="<%= producto.nombre %> — imagen <%= i + 1 %>"
                onerror="this.src='/images/noEncontrado.png'"
              >
            <% }) %>
          <% } else { %>
            <img
              class="det-gallery__img"
              src="/images/noEncontrado.png"
              alt="<%= producto.nombre %>"
            >
          <% } %>
        </div>

        <% if (producto.imagenes && producto.imagenes.length > 1) { %>
          <button class="det-gallery__arrow det-gallery__arrow--prev" id="det-prev" aria-label="Imagen anterior">
            <i class="fa-solid fa-chevron-left"></i>
          </button>
          <button class="det-gallery__arrow det-gallery__arrow--next" id="det-next" aria-label="Imagen siguiente">
            <i class="fa-solid fa-chevron-right"></i>
          </button>
        <% } %>

        <span class="det-gallery__zoom-hint"><i class="fa-solid fa-magnifying-glass-plus"></i>&nbsp;Click para ampliar</span>
      </div>

      <!-- Thumbnails -->
      <% if (producto.imagenes && producto.imagenes.length > 1) { %>
        <div class="det-gallery__thumbs" id="det-thumbs">
          <% producto.imagenes.forEach((imgObj, i) => {
               const file = (imgObj && (imgObj.imagen || imgObj.archivo || imgObj.url))
                 ? (imgObj.imagen || imgObj.archivo || imgObj.url)
                 : imgObj;
          %>
            <button
              type="button"
              class="det-gallery__thumb<%= i === 0 ? ' is-active' : '' %>"
              data-idx="<%= i %>"
              aria-label="Ver imagen <%= i + 1 %>"
            >
              <img
                src="/uploads/productos/<%= file %>"
                alt="Miniatura <%= i + 1 %>"
                onerror="this.src='/images/noEncontrado.png'"
              >
            </button>
          <% }) %>
        </div>
      <% } %>

    </div>
    <!-- /galería -->


    <!-- ═══ INFO ═══ -->
    <div class="det-info">

      <!-- Badges -->
      <div class="det-badges">
        <% if (producto.categoria_nombre) { %>
          <span class="det-badge det-badge--categoria">
            <i class="fa-solid fa-tag"></i>
            <%= producto.categoria_nombre %>
          </span>
        <% } %>

        <% if (producto.oferta) { %>
          <span class="det-badge det-badge--oferta">
            <i class="fa-solid fa-bolt"></i>
            Oferta
          </span>
        <% } %>

        <% if (producto.calidad_original) { %>
          <span class="det-badge det-badge--fitam">
            <i class="fa-solid fa-shield-halved"></i>
            Calidad FITAM
          </span>
        <% } else if (producto.calidad_vic) { %>
          <span class="det-badge det-badge--vic">
            <i class="fa-solid fa-star"></i>
            Calidad VIC
          </span>
        <% } %>
      </div>

      <!-- Título -->
      <h1 class="det-title"><%= producto.nombre %></h1>

      <!-- Precio -->
      <div class="det-price-block">
        <div class="det-price">
          <%= new Intl.NumberFormat('es-AR', { style:'currency', currency:'ARS', maximumFractionDigits:0 }).format(producto.precio_venta || 0) %>
        </div>
        <% if (producto.oferta) { %>
          <div class="det-price-oferta-tag">
            <i class="fa-solid fa-fire-flame-curved"></i>
            PRECIO ESPECIAL
          </div>
        <% } %>
      </div>

      <div class="det-sep"></div>

      <!-- Stock -->
      <% if (isUserLoggedIn) { %>
        <% if (isAdminUser) { %>
          <div class="det-stock-admin">
            <i class="fa-solid fa-boxes-stacked"></i>
            Stock disponible:&nbsp;<strong><%= producto.stock_actual %></strong>&nbsp;unidades
            <% if (producto.stock_actual < producto.stock_minimo) { %>
              &nbsp;<span style="color:#f87171;font-size:.75rem">(bajo mínimo)</span>
            <% } %>
          </div>
        <% } else { %>
          <% const stockOk = producto.stock_actual >= producto.stock_minimo; %>
          <div class="det-stock <%= stockOk ? 'det-stock--ok' : 'det-stock--bajo' %>">
            <span class="det-stock__dot"></span>
            <span class="det-stock__text">
              <%= stockOk ? 'Disponible para entrega inmediata' : 'Pendiente de ingreso · A pedido' %>
            </span>
          </div>
        <% } %>
      <% } %>

      <!-- Aplicaciones (escobillas) -->
      <% if (tieneAplic) { %>
        <div class="det-apps">
          <div class="det-apps__head">
            <div class="det-apps__title">
              <i class="fa-solid fa-car"></i>
              <span>Aplicaciones</span>
            </div>
            <button
              type="button"
              class="det-apps__btn"
              id="btnAppsDetalle"
              data-titulo="<%= producto.nombre %>"
              data-aplicaciones="<%= encodeURIComponent(_cleanDescripcion) %>"
            >
              <i class="fa-solid fa-list-ul"></i>
              Ver todas
            </button>
          </div>

          <% if (appsData.subtitle) { %>
            <div style="padding:10px 18px 0;font-size:.75rem;font-weight:700;color:#4d6380;letter-spacing:.04em">
              <i class="fa-solid fa-circle-info" style="margin-right:6px"></i><%= appsData.subtitle %>
            </div>
          <% } %>

          <ul class="det-apps__list">
            <% if (preview.length) { %>
              <% preview.forEach(l => { %>
                <li class="det-apps__item">
                  <i class="fa-solid fa-car-side"></i>
                  <span><%= l %></span>
                </li>
              <% }) %>
            <% } else { %>
              <li class="det-apps__item">
                <i class="fa-solid fa-car-side"></i>
                <span>Sin aplicaciones cargadas.</span>
              </li>
            <% } %>
          </ul>

          <% if ((appsData.lines || []).length > preview.length) { %>
            <div class="det-apps__more" id="btnAppsDetalle2"
              data-titulo="<%= producto.nombre %>"
              data-aplicaciones="<%= encodeURIComponent(_cleanDescripcion) %>"
            >
              <i class="fa-solid fa-ellipsis"></i>
              y <%= appsData.lines.length - preview.length %> compatibilidades más — ver lista completa
            </div>
          <% } %>
        </div>

      <!-- Descripción normal -->
      <% } else if (_cleanDescripcion) { %>
        <div class="det-desc">
          <div class="det-desc__label"><i class="fa-solid fa-align-left" style="margin-right:6px;opacity:.6"></i>Descripción</div>
          <div class="det-desc__text"><%= _cleanDescripcion %></div>
        </div>
      <% } %>

      <div class="det-sep"></div>

      <!-- Acciones (solo usuarios no admin) -->
      <% if (!isAdminUser) { %>
        <div class="det-actions">
          <div class="det-qty-row">
            <button class="det-qty-btn" id="det-qty-minus" aria-label="Disminuir cantidad">
              <i class="fa-solid fa-minus"></i>
            </button>
            <input
              type="number"
              class="det-qty-input"
              id="det-qty"
              value="1"
              min="1"
              max="99"
              aria-label="Cantidad"
            >
            <button class="det-qty-btn" id="det-qty-plus" aria-label="Aumentar cantidad">
              <i class="fa-solid fa-plus"></i>
            </button>
          </div>

          <button
            class="det-btn-agregar"
            id="det-btn-cart"
            data-id="<%= producto.id_producto %>"
          >
            <i class="fa-solid fa-cart-plus"></i>
            Agregar al carrito
          </button>
        </div>
      <% } %>

      <!-- Share -->
      <div class="det-share">
        <span class="det-share__label">Compartir</span>
        <a class="det-share__btn det-share__btn--wa"
           href="https://api.whatsapp.com/send?text=<%= _shareText %>%20<%= _shareUrl %>"
           target="_blank" rel="noopener" aria-label="WhatsApp">
          <i class="fa-brands fa-whatsapp"></i>
        </a>
        <a class="det-share__btn det-share__btn--fb"
           href="https://www.facebook.com/sharer/sharer.php?u=<%= _shareUrl %>"
           target="_blank" rel="noopener" aria-label="Facebook">
          <i class="fa-brands fa-facebook-f"></i>
        </a>
        <a class="det-share__btn det-share__btn--ig"
           href="https://www.instagram.com/"
           target="_blank" rel="noopener" aria-label="Instagram">
          <i class="fa-brands fa-instagram"></i>
        </a>
      </div>

    </div>
    <!-- /info -->

  </div>
  <!-- /det-shell -->

</div>
<!-- /det-page -->

<%- include('./layouts/footer.ejs') %>

<script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
<script src="/js/pages/detalle.js" defer></script>

</body>
</html>
