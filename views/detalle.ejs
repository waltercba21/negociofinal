<!DOCTYPE html>
<html lang="es">
<%- include('./layouts/head.ejs') %>
<link rel="stylesheet" href="/css/pages/detalle.css" />
<style>
/* ── Det-Apps buscador interactivo ─────────────────────── */
.det-apps {
  background: rgba(15, 25, 46, 0.7);
  border: 1px solid rgba(31, 72, 126, 0.35);
  border-radius: 16px;
  overflow: hidden;
  margin-bottom: 4px;
}

.det-apps__head {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 14px 18px 10px;
}

.det-apps__title {
  display: flex;
  align-items: center;
  gap: 8px;
  font-family: 'Barlow Condensed', sans-serif;
  font-size: 14px;
  font-weight: 800;
  letter-spacing: 1.5px;
  text-transform: uppercase;
  color: rgba(240,244,255,0.55);
}

.det-apps__title i { color: #1F487E; font-size: 13px; }

.det-apps__count {
  background: rgba(31, 72, 126, 0.25);
  border: 1px solid rgba(31, 72, 126, 0.4);
  color: #7aaee8;
  font-family: 'DM Sans', sans-serif;
  font-size: 11px;
  font-weight: 700;
  padding: 2px 8px;
  border-radius: 20px;
  letter-spacing: 0;
  transition: all 0.2s;
}

.det-apps__count--filtered {
  background: rgba(217, 4, 41, 0.15);
  border-color: rgba(217, 4, 41, 0.4);
  color: #f87171;
}

/* Buscador */
.det-apps__search-wrap {
  position: relative;
  margin: 0 14px 12px;
  display: flex;
  align-items: center;
}

.det-apps__search-ico {
  position: absolute;
  left: 13px;
  color: rgba(240,244,255,0.3);
  font-size: 13px;
  pointer-events: none;
}

.det-apps__search-input {
  width: 100%;
  background: rgba(255,255,255,0.05);
  border: 1.5px solid rgba(31, 72, 126, 0.3);
  border-radius: 10px;
  padding: 9px 36px 9px 36px;
  color: #f0f4ff;
  font-family: 'DM Sans', sans-serif;
  font-size: 13px;
  outline: none;
  transition: border-color 0.2s, background 0.2s;
}

.det-apps__search-input::placeholder { color: rgba(240,244,255,0.3); }

.det-apps__search-input:focus {
  border-color: #1F487E;
  background: rgba(31, 72, 126, 0.08);
}

.det-apps__search-clear {
  position: absolute;
  right: 10px;
  display: none;
  align-items: center;
  justify-content: center;
  width: 22px;
  height: 22px;
  border-radius: 50%;
  border: none;
  background: rgba(255,255,255,0.1);
  color: rgba(240,244,255,0.5);
  cursor: pointer;
  font-size: 11px;
  transition: background 0.15s;
}

.det-apps__search-clear:hover { background: rgba(217,4,41,0.25); color: #f87171; }

/* Lista */
.det-apps__list {
  list-style: none;
  padding: 0 0 8px;
  margin: 0;
  max-height: 320px;
  overflow-y: auto;
  scrollbar-width: thin;
  scrollbar-color: rgba(31,72,126,0.4) transparent;
}

.det-apps__list::-webkit-scrollbar { width: 4px; }
.det-apps__list::-webkit-scrollbar-track { background: transparent; }
.det-apps__list::-webkit-scrollbar-thumb { background: rgba(31,72,126,0.4); border-radius: 2px; }

.det-apps__item {
  display: flex;
  align-items: flex-start;
  gap: 10px;
  padding: 8px 18px;
  font-family: 'DM Sans', sans-serif;
  font-size: 13px;
  font-weight: 500;
  color: rgba(240,244,255,0.8);
  line-height: 1.4;
  transition: background 0.12s;
}

.det-apps__item:nth-child(odd) { background: rgba(31,72,126,0.07); }
.det-apps__item:hover { background: rgba(31,72,126,0.16); }

.det-apps__item i {
  color: #1F487E;
  font-size: 12px;
  margin-top: 2px;
  flex-shrink: 0;
}

.det-apps__item--in {
  animation: appItemIn 0.15s ease both;
}

@keyframes appItemIn {
  from { opacity: 0; transform: translateY(4px); }
  to   { opacity: 1; transform: translateY(0); }
}

/* Highlight búsqueda */
mark.apps-hl {
  background: rgba(217, 4, 41, 0.25);
  color: #f87171;
  border-radius: 3px;
  padding: 0 2px;
}

/* Empty state */
.det-apps__empty {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 8px;
  padding: 28px 16px;
  color: rgba(240,244,255,0.35);
  font-family: 'DM Sans', sans-serif;
  font-size: 13px;
}

.det-apps__empty i { font-size: 28px; color: rgba(217,4,41,0.4); }
</style>

<body class="det-page" data-is-admin-user="<%= isAdminUser %>" data-is-user-logged-in="<%= isUserLoggedIn %>">

<%- include('./layouts/header.ejs') %>

<div class="det-page">

  <!-- BREADCRUMB -->
  <nav class="det-breadcrumb" aria-label="Ubicación">
    <a href="/"><i class="fa-solid fa-house"></i>&nbsp;Inicio</a>
    <i class="fa-solid fa-chevron-right"></i>
    <a href="/productos">Productos</a>
    <% if (producto.categoria_nombre) { %>
      <i class="fa-solid fa-chevron-right"></i>
      <a href="/productos?categoria=<%= encodeURIComponent(producto.categoria_nombre) %>"><%= producto.categoria_nombre %></a>
    <% } %>
    <i class="fa-solid fa-chevron-right"></i>
    <span style="color:#7aaee8"><%= producto.nombre %></span>
  </nav>

  <!-- SHELL: GALERÍA + INFO -->
  <div class="det-shell">

    <!-- ═══ GALERÍA ═══ -->
    <div class="det-gallery">

      <div class="det-gallery__main" id="det-gallery-main">

        <div class="det-gallery__main-track" id="carousel-detalle">
          <% if (producto.imagenes && producto.imagenes.length > 0) { %>
            <% producto.imagenes.forEach((imgObj, i) => {
                 const file = (imgObj && (imgObj.imagen || imgObj.archivo || imgObj.url))
                   ? (imgObj.imagen || imgObj.archivo || imgObj.url)
                   : imgObj;
            %>
              <img
                class="det-gallery__img<%= i !== 0 ? ' hidden' : '' %>"
                src="/uploads/productos/<%= file %>"
                alt="<%= producto.nombre %> — imagen <%= i + 1 %>"
                onerror="this.src='/images/noEncontrado.png'"
              >
            <% }) %>
          <% } else { %>
            <img
              class="det-gallery__img"
              src="/images/noEncontrado.png"
              alt="<%= producto.nombre %>"
            >
          <% } %>
        </div>

        <% if (producto.imagenes && producto.imagenes.length > 1) { %>
          <button class="det-gallery__arrow det-gallery__arrow--prev" id="det-prev" aria-label="Imagen anterior">
            <i class="fa-solid fa-chevron-left"></i>
          </button>
          <button class="det-gallery__arrow det-gallery__arrow--next" id="det-next" aria-label="Imagen siguiente">
            <i class="fa-solid fa-chevron-right"></i>
          </button>
        <% } %>

        <span class="det-gallery__zoom-hint"><i class="fa-solid fa-magnifying-glass-plus"></i>&nbsp;Click para ampliar</span>
      </div>

      <!-- Thumbnails -->
      <% if (producto.imagenes && producto.imagenes.length > 1) { %>
        <div class="det-gallery__thumbs" id="det-thumbs">
          <% producto.imagenes.forEach((imgObj, i) => {
               const file = (imgObj && (imgObj.imagen || imgObj.archivo || imgObj.url))
                 ? (imgObj.imagen || imgObj.archivo || imgObj.url)
                 : imgObj;
          %>
            <button
              type="button"
              class="det-gallery__thumb<%= i === 0 ? ' is-active' : '' %>"
              data-idx="<%= i %>"
              aria-label="Ver imagen <%= i + 1 %>"
            >
              <img
                src="/uploads/productos/<%= file %>"
                alt="Miniatura <%= i + 1 %>"
                onerror="this.src='/images/noEncontrado.png'"
              >
            </button>
          <% }) %>
        </div>
      <% } %>

    </div>
    <!-- /galería -->


    <!-- ═══ INFO ═══ -->
    <div class="det-info">

      <!-- Badges -->
      <div class="det-badges">
        <% if (producto.categoria_nombre) { %>
          <span class="det-badge det-badge--categoria">
            <i class="fa-solid fa-tag"></i>
            <%= producto.categoria_nombre %>
          </span>
        <% } %>

        <% if (producto.oferta) { %>
          <span class="det-badge det-badge--oferta">
            <i class="fa-solid fa-bolt"></i>
            Oferta
          </span>
        <% } %>

        <% if (producto.calidad_original) { %>
          <span class="det-badge det-badge--fitam">
            <i class="fa-solid fa-shield-halved"></i>
            Calidad FITAM
          </span>
        <% } else if (producto.calidad_vic) { %>
          <span class="det-badge det-badge--vic">
            <i class="fa-solid fa-star"></i>
            Calidad VIC
          </span>
        <% } %>
      </div>

      <!-- Título -->
      <h1 class="det-title"><%= producto.nombre %></h1>

      <!-- Precio -->
      <div class="det-price-block">
        <div class="det-price">
          <%= new Intl.NumberFormat('es-AR', { style:'currency', currency:'ARS', maximumFractionDigits:0 }).format(producto.precio_venta || 0) %>
        </div>
        <% if (producto.oferta) { %>
          <div class="det-price-oferta-tag">
            <i class="fa-solid fa-fire-flame-curved"></i>
            PRECIO ESPECIAL
          </div>
        <% } %>
      </div>

      <div class="det-sep"></div>

      <!-- Stock -->
      <% if (isUserLoggedIn) { %>
        <% if (isAdminUser) { %>
          <div class="det-stock-admin">
            <i class="fa-solid fa-boxes-stacked"></i>
            Stock disponible:&nbsp;<strong><%= producto.stock_actual %></strong>&nbsp;unidades
            <% if (producto.stock_actual < producto.stock_minimo) { %>
              &nbsp;<span style="color:#f87171;font-size:.75rem">(bajo mínimo)</span>
            <% } %>
          </div>
        <% } else { %>
          <% const stockOk = producto.stock_actual >= producto.stock_minimo; %>
          <div class="det-stock <%= stockOk ? 'det-stock--ok' : 'det-stock--bajo' %>">
            <span class="det-stock__dot"></span>
            <span class="det-stock__text">
              <%= stockOk ? 'Disponible para entrega inmediata' : 'Pendiente de ingreso · A pedido' %>
            </span>
          </div>
        <% } %>
      <% } %>

      <!-- Aplicaciones (escobillas) — buscador interactivo -->
      <% if (tieneAplic) { %>
        <div class="det-apps" id="det-apps-widget">

          <div class="det-apps__head">
            <div class="det-apps__title">
              <i class="fa-solid fa-car"></i>
              <span>Compatibilidades</span>
              <span class="det-apps__count" id="appsCount"><%= appsData.lines.length %></span>
            </div>
          </div>

          <!-- Buscador inline -->
          <div class="det-apps__search-wrap">
            <i class="fa-solid fa-magnifying-glass det-apps__search-ico"></i>
            <input
              type="text"
              id="appsSearch"
              class="det-apps__search-input"
              placeholder="Buscá tu vehículo… ej: Ford, Gol, Civic"
              autocomplete="off"
            />
            <button type="button" class="det-apps__search-clear" id="appsClear" aria-label="Limpiar">
              <i class="fa-solid fa-xmark"></i>
            </button>
          </div>

          <!-- Lista filtrable -->
          <ul class="det-apps__list" id="appsList"
            data-items="<%- JSON.stringify(appsData.lines).replace(/'/g, '&#39;') %>">
            <% appsData.lines.forEach(l => { %>
              <li class="det-apps__item">
                <i class="fa-solid fa-car-side"></i>
                <span><%= l %></span>
              </li>
            <% }) %>
          </ul>

          <div class="det-apps__empty" id="appsEmpty" style="display:none;">
            <i class="fa-solid fa-circle-xmark"></i>
            <span>Sin resultados para tu búsqueda</span>
          </div>

        </div>

      <!-- Descripción normal -->
      <% } else if (_cleanDescripcion) { %>
        <div class="det-desc">
          <div class="det-desc__label"><i class="fa-solid fa-align-left" style="margin-right:6px;opacity:.6"></i>Descripción</div>
          <div class="det-desc__text"><%= _cleanDescripcion %></div>
        </div>
      <% } %>

      <div class="det-sep"></div>

      <!-- Acciones (solo usuarios no admin) -->
      <% if (!isAdminUser) { %>
        <div class="det-actions">
          <div class="det-qty-row">
            <button class="det-qty-btn" id="det-qty-minus" aria-label="Disminuir cantidad">
              <i class="fa-solid fa-minus"></i>
            </button>
            <input
              type="number"
              class="det-qty-input"
              id="det-qty"
              value="1"
              min="1"
              max="99"
              aria-label="Cantidad"
            >
            <button class="det-qty-btn" id="det-qty-plus" aria-label="Aumentar cantidad">
              <i class="fa-solid fa-plus"></i>
            </button>
          </div>

          <button
            class="det-btn-agregar"
            id="det-btn-cart"
            data-id="<%= producto.id_producto %>"
          >
            <i class="fa-solid fa-cart-plus"></i>
            Agregar al carrito
          </button>
        </div>
      <% } %>

      <!-- Share -->
      <div class="det-share">
        <span class="det-share__label">Compartir</span>
        <a class="det-share__btn det-share__btn--wa"
           href="https://api.whatsapp.com/send?text=<%= _shareText %>%20<%= _shareUrl %>"
           target="_blank" rel="noopener" aria-label="WhatsApp">
          <i class="fa-brands fa-whatsapp"></i>
        </a>
        <a class="det-share__btn det-share__btn--fb"
           href="https://www.facebook.com/sharer/sharer.php?u=<%= _shareUrl %>"
           target="_blank" rel="noopener" aria-label="Facebook">
          <i class="fa-brands fa-facebook-f"></i>
        </a>
        <a class="det-share__btn det-share__btn--ig"
           href="https://www.instagram.com/"
           target="_blank" rel="noopener" aria-label="Instagram">
          <i class="fa-brands fa-instagram"></i>
        </a>
      </div>

    </div>
    <!-- /info -->

  </div>
  <!-- /det-shell -->

</div>
<!-- /det-page -->

<%- include('./layouts/footer.ejs') %>

<script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
<script src="/js/pages/detalle.js" defer></script>

</body>
</html>
