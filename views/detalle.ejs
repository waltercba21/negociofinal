<%
  // ── Limpieza de descripción ──────────────────────────────
  const _raw = (producto.descripcion || '').toString();
  const _cleanDescripcion = _raw
    .replace(/\\t/g, ' ').replace(/\t/g, ' ')
    .replace(/\\n/g, '\n').replace(/\r/g, '')
    .replace(/<br\s*\/?\s*>/gi, '\n')
    .replace(/<\/?[^>]+>/g, '')
    .replace(/"\s*>/g, '')
    .replace(/\u00A0/g, ' ')
    .replace(/[ ]{2,}/g, ' ')
    .trim();

  // ── Aplicaciones (escobillas) ────────────────────────────
  const esEscobilla = /escobill/i.test(producto.categoria_nombre || '') || /escobill/i.test(producto.nombre || '');
  const tieneAplic  = esEscobilla && _cleanDescripcion.length > 0;

  function normalizeAplicaciones(raw){
    let s = String(raw ?? '').trim();
    if (!s) return { subtitle:'', lines:[] };
    // Separar por 2+ espacios/tabs consecutivos (formato real de la DB)
    s = s.replace(/<br\s*\/?>\s*/gi, ' ').replace(/\r?\n/g, ' ');
    const partes = s.split(/[ \t]{2,}/).map(x => x.trim()).filter(Boolean);
    let subtitle = '';
    const lines = [...partes];
    if (lines.length >= 2 && /^(escobilla|kit|rear)/i.test(lines[0])) subtitle = lines.shift();
    return { subtitle, lines };
  }

  const appsData = normalizeAplicaciones(_cleanDescripcion);
  const preview  = (appsData.lines || []).slice(0, 5);

  // ── Label de calidad ─────────────────────────────────────
  const label = producto.oferta
    ? 'OFERTA'
    : (producto.calidad_original ? 'FITAM' : (producto.calidad_vic ? 'VIC' : ''));

  // ── URL para compartir ───────────────────────────────────
  const _shareText  = encodeURIComponent(producto.nombre || '');
  const _shareUrl   = encodeURIComponent(typeof currentUrl !== 'undefined' ? currentUrl : '');
%>

