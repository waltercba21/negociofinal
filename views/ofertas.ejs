<% var pageCss = '/css/pages/lista.css' %>
<!DOCTYPE html>
<html lang="es">
<%- include('./layouts/head.ejs') %>
<link rel="stylesheet" href="/css/pages/lista.css" />
<body data-is-admin-user="<%= isAdminUser %>" data-is-user-logged-in="<%= isUserLoggedIn %>">

  <%- include('./layouts/header.ejs') %>

  <main class="lista-main">

    <!-- ══════════════════════════════════════
         HERO BUSCADOR
    ══════════════════════════════════════ -->
    <section class="busqueda-hero">
      <div class="busqueda-hero__inner">
        <div class="busqueda-hero__copy">
          <span class="busqueda-hero__eyebrow">
            <i class="fa-solid fa-bolt"></i> Ofertas especiales
          </span>
          <h1 class="busqueda-hero__title">Productos en<br><em>oferta</em></h1>
        </div>

        <!-- Filtros -->
        <form id="filtroOfertas" method="GET" action="/productos/ofertas" class="filtros-grid">

          <div class="filtro-item">
            <label class="filtro-label" for="categoria_id">
              <i class="fa-solid fa-tag"></i> Categoría
            </label>
            <div class="select-wrap">
              <select name="categoria_id" id="categoria_id" class="filtro-select" onchange="document.getElementById('filtroOfertas').submit()">
                <option value="">Todas las categorías</option>
                <% categorias.forEach(categoria => { %>
                  <option value="<%= categoria.id %>" <%= categoria.id == categoriaSeleccionada ? 'selected' : '' %>>
                    <%= categoria.nombre %>
                  </option>
                <% }) %>
              </select>
              <i class="fa-solid fa-chevron-down select-arrow"></i>
            </div>
          </div>

          <div class="filtro-item">
            <label class="filtro-label" for="marca_id">
              <i class="fa-solid fa-car"></i> Marca
            </label>
            <div class="select-wrap">
              <select name="marca_id" id="marca_id" class="filtro-select" onchange="document.getElementById('filtroOfertas').submit()">
                <option value="">Todas las marcas</option>
                <% marcas.forEach(marca => { %>
                  <option value="<%= marca.id %>" <%= marca.id == marcaSeleccionada ? 'selected' : '' %>>
                    <%= marca.nombre %>
                  </option>
                <% }) %>
              </select>
              <i class="fa-solid fa-chevron-down select-arrow"></i>
            </div>
          </div>

        </form>
      </div>
    </section>

    <!-- ══════════════════════════════════════
         GRID PRODUCTOS
    ══════════════════════════════════════ -->
    <section class="productos-section">
      <div id="contenedor-productos" class="productos-grid">

        <% if (productos && productos.length > 0) { %>
          <% productos.forEach(function(producto, index) { %>

            <%
              const puedeComprar = (producto.stock_actual >= producto.stock_minimo) && (producto.stock_actual > 0);
            %>

            <article class="pcard pcard--oferta">

              <!-- Badge OFERTA -->
              <div class="pcard__badges">
                <span class="pcard__badge badge--oferta">OFERTA</span>
              </div>

              <!-- Imagen / Carousel -->
              <div class="pcard__media">
                <% if (producto.imagenes && producto.imagenes.length > 0) { %>
                  <div class="pcard__carousel" id="carousel-<%= index %>">
                    <% producto.imagenes.forEach(function(imagen, i) { %>
                      <img
                        class="pcard__img <%= i !== 0 ? 'hidden' : '' %>"
                        src="/uploads/productos/<%= imagen.imagen %>"
                        alt="<%= producto.nombre %>"
                        loading="lazy"
                      />
                    <% }); %>
                  </div>
                  <% if (producto.imagenes.length > 1) { %>
                    <button class="pcard__carousel-btn pcard__carousel-btn--prev" onclick="moverCarrusel('<%= index %>', -1)" aria-label="Imagen anterior">
                      <i class="fas fa-chevron-left"></i>
                    </button>
                    <button class="pcard__carousel-btn pcard__carousel-btn--next" onclick="moverCarrusel('<%= index %>', 1)" aria-label="Siguiente imagen">
                      <i class="fas fa-chevron-right"></i>
                    </button>
                    <div class="pcard__dots" id="dots-<%= index %>">
                      <% producto.imagenes.forEach(function(_, i) { %>
                        <span class="pcard__dot <%= i === 0 ? 'pcard__dot--active' : '' %>"></span>
                      <% }); %>
                    </div>
                  <% } %>
                <% } else { %>
                  <div class="pcard__carousel">
                    <img class="pcard__img" src="/images/noEncontrado.png" alt="<%= producto.nombre %>" />
                  </div>
                <% } %>
              </div>

              <!-- Info -->
              <div class="pcard__body">
                <span class="pcard__categoria"><%= producto.categoria_nombre || 'Sin categoría' %></span>
                <h3 class="pcard__nombre"><%= producto.nombre %></h3>

                <div class="pcard__precio-row">
                  <span class="pcard__precio">
                    $<%= new Intl.NumberFormat('es-AR').format(Math.floor(producto.precio_venta || 0)) %>
                  </span>
                  <span class="pcard__precio-tag">
                    <i class="fa-solid fa-bolt"></i> Oferta
                  </span>
                </div>

                <!-- Admin: Stock -->
                <% if (isAdminUser) { %>
                  <div class="pcard__admin">
                    <div class="pcard__admin-row">
                      <span class="pcard__admin-label">Stock</span>
                      <span class="pcard__admin-val <%= producto.stock_actual < producto.stock_minimo ? 'stock--bajo' : 'stock--ok' %>">
                        <%= producto.stock_actual %>
                        <% if (producto.stock_actual < producto.stock_minimo) { %>
                          <i class="fa-solid fa-triangle-exclamation"></i>
                        <% } %>
                      </span>
                    </div>
                  </div>
                <% } %>

                <!-- Stock semáforo (usuarios normales logueados) -->
                <% if (isUserLoggedIn && !isAdminUser) { %>
                  <div class="pcard__stock <%= puedeComprar ? 'pcard__stock--ok' : 'pcard__stock--bajo' %>">
                    <i class="fa-solid fa-circle pcard__stock-dot"></i>
                    <span class="pcard__stock-txt">
                      <%= puedeComprar ? 'Disponible para entrega inmediata' : 'A pedido / pendiente de ingreso' %>
                    </span>
                  </div>
                <% } %>

                <!-- Acciones -->
                <div class="pcard__actions">
                  <% if (isUserLoggedIn && !isAdminUser) { %>
                    <div class="pcard__qty-row">
                      <button type="button" class="qty-btn qty-btn--minus" aria-label="Restar">
                        <i class="fa-solid fa-minus"></i>
                      </button>
                      <input
                        type="number"
                        class="cantidad-input"
                        value="<%= puedeComprar ? 1 : 0 %>"
                        min="<%= puedeComprar ? 1 : 0 %>"
                        max="<%= producto.stock_actual %>"
                        step="1"
                        <%= puedeComprar ? '' : 'disabled' %>
                        aria-label="Cantidad"
                      />
                      <button type="button" class="qty-btn qty-btn--plus" aria-label="Sumar">
                        <i class="fa-solid fa-plus"></i>
                      </button>
                    </div>

                    <button
                      class="btn-agregar agregar-carrito"
                      <%= puedeComprar ? '' : 'disabled' %>
                      data-id="<%= producto.id %>"
                      data-nombre="<%= producto.nombre %>"
                      data-precio="<%= producto.precio_venta %>"
                      data-stock="<%= producto.stock_actual %>"
                      data-stockmin="<%= producto.stock_minimo %>">
                      <i class="fa-solid fa-cart-plus"></i>
                      <span><%= puedeComprar ? 'Agregar al carrito' : 'Sin stock' %></span>
                    </button>
                  <% } %>

                  <a href="/productos/<%= producto.id %>" class="btn-detalle card-link">
                    <i class="fa-solid fa-eye"></i>
                    <span>Ver detalles</span>
                  </a>
                </div>

                <!-- Social share -->
                <div class="pcard__share">
                  <a href="https://wa.me/543513820440?text=¡Hola! QUIERO CONSULTAR POR ESTE PRODUCTO: <%= producto.nombre %> 👉 https://www.autofaros.com.ar/productos/<%= producto.id %>"
                     title="Consultar por WhatsApp" target="_blank" class="pcard__share-btn pcard__share-btn--wa">
                    <i class="fab fa-whatsapp"></i>
                  </a>
                  <a href="https://www.facebook.com/profile.php?id=100063665395970"
                     title="Facebook" target="_blank" class="pcard__share-btn pcard__share-btn--fb">
                    <i class="fab fa-facebook-f"></i>
                  </a>
                  <a href="https://www.instagram.com/autofaros_cordoba"
                     title="Instagram" target="_blank" class="pcard__share-btn pcard__share-btn--ig">
                    <i class="fab fa-instagram"></i>
                  </a>
                </div>

              </div><!-- /pcard__body -->
            </article>

          <% }); %>

        <% } else { %>
          <div class="no-result">
            <img src="/images/noEncontrado.png" alt="Sin resultados" class="no-result__img" />
            <h3 class="no-result__title">Sin ofertas disponibles</h3>
            <p class="no-result__text">No hay productos en oferta con esos filtros.<br>Probá con otras categorías o marcas.</p>
          </div>
        <% } %>

      </div><!-- /productos-grid -->

      <!-- ══════ PAGINACIÓN ══════ -->
      <% if (numeroDePaginas > 1) { %>
        <nav class="paginacion" aria-label="Paginación de ofertas">
          <a
            class="paginacion__btn <%= pagina === 1 ? 'paginacion__btn--disabled' : '' %>"
            href="<%= pagina === 1 ? '#' : '/productos/ofertas?pagina=' + (pagina - 1) + (categoriaSeleccionada ? '&categoria_id=' + categoriaSeleccionada : '') + (marcaSeleccionada ? '&marca_id=' + marcaSeleccionada : '') %>"
            aria-label="Anterior"
          >
            <i class="fa-solid fa-chevron-left"></i>
          </a>

          <div class="paginacion__pages">
            <% for (let i = 1; i <= numeroDePaginas; i++) { %>
              <a
                class="paginacion__page <%= i === pagina ? 'paginacion__page--active' : '' %>"
                href="/productos/ofertas?pagina=<%= i %><%= categoriaSeleccionada ? '&categoria_id=' + categoriaSeleccionada : '' %><%= marcaSeleccionada ? '&marca_id=' + marcaSeleccionada : '' %>"
              ><%= i %></a>
            <% } %>
          </div>

          <a
            class="paginacion__btn <%= pagina === numeroDePaginas ? 'paginacion__btn--disabled' : '' %>"
            href="<%= pagina === numeroDePaginas ? '#' : '/productos/ofertas?pagina=' + (pagina + 1) + (categoriaSeleccionada ? '&categoria_id=' + categoriaSeleccionada : '') + (marcaSeleccionada ? '&marca_id=' + marcaSeleccionada : '') %>"
            aria-label="Siguiente"
          >
            <i class="fa-solid fa-chevron-right"></i>
          </a>
        </nav>
      <% } %>

    </section>
  </main>

  <!-- SweetAlert2 -->
  <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>

  <!-- Scripts -->
  <script src="/js/pages/agregarAlCarrito.js?v=20260309" defer></script>
  <script src="/js/pages/lista.js?v=20260309" defer></script>

  <script>
    function moverCarrusel(index, direccion) {
      const carrusel = document.getElementById('carousel-' + index);
      const imagenes = carrusel.querySelectorAll('.pcard__img');
      const dots     = document.querySelectorAll('#dots-' + index + ' .pcard__dot');
      let activa = Array.from(imagenes).findIndex(img => !img.classList.contains('hidden'));

      imagenes[activa].classList.add('hidden');
      if (dots[activa]) dots[activa].classList.remove('pcard__dot--active');

      activa = (activa + direccion + imagenes.length) % imagenes.length;

      imagenes[activa].classList.remove('hidden');
      if (dots[activa]) dots[activa].classList.add('pcard__dot--active');
    }
  </script>

  <%- include('./layouts/footer.ejs') %>
</body>
</html>
