<% var pageCss = '/css/pages/crear.css' %>
<!DOCTYPE html>
<html lang="es">
<%- include('./layouts/head.ejs') %>
<link rel="stylesheet" href="/css/pages/crear.css?v=1" />
<body>
<%- include('./layouts/header.ejs') %>

<main class="cr-main">
  <div class="cr-wrap">

    <!-- PAGE HEADER -->
    <div class="cr-page-header">
      <div>
        <span class="cr-eyebrow">Productos</span>
        <h1 class="cr-title">Crear Producto</h1>
      </div>
      <a href="/productos" class="cr-btn cr-btn--outline">
        <i class="fa-solid fa-arrow-left"></i> Volver al panel
      </a>
    </div>

    <form class="cr-form" method="POST" action="/productos" enctype="multipart/form-data">

      <div class="cr-grid">

        <!-- ══════════════════════════════
             COLUMNA 1: CARACTERÍSTICAS
        ══════════════════════════════ -->
        <div class="cr-panel">
          <div class="cr-panel__hd">
            <i class="fa-solid fa-tag"></i>
            <strong>Características</strong>
          </div>
          <div class="cr-panel__bd">

            <!-- Imágenes -->
            <div class="cr-field">
              <label class="cr-label">Imágenes</label>
              <label class="cr-file-zone" for="imagen">
                <i class="fa-solid fa-cloud-arrow-up cr-file-zone__icon"></i>
                <span class="cr-file-zone__text">Clic para seleccionar imágenes</span>
                <input id="imagen" type="file" name="archivos[]" multiple class="cr-file-input">
                <input type="hidden" id="portada_index" name="portada_index" value="0">
              </label>
              <p class="cr-hint">• Clic: marcar portada &nbsp;•&nbsp; Doble-clic: eliminar &nbsp;•&nbsp; Arrastrar: reordenar</p>
              <div id="preview" class="imagen-miniatura-contenedor"></div>
            </div>

            <!-- Nombre -->
            <div class="cr-field">
              <label class="cr-label" for="nombre">Nombre</label>
              <input id="nombre" type="text" name="nombre" class="cr-input">
            </div>

            <!-- Descripción -->
            <div class="cr-field">
              <label class="cr-label" for="descripcion">Descripción</label>
              <textarea id="descripcion" name="descripcion" rows="5" class="cr-input cr-textarea"></textarea>
            </div>

            <!-- Categoría -->
            <div class="cr-field">
              <label class="cr-label" for="categoria">Categoría</label>
              <select id="categoria" name="categoria" required class="cr-select">
                <option value="">Seleccioná una categoría</option>
                <% categorias.forEach(function(categoria) { %>
                  <option value="<%= categoria.id %>"><%= categoria.nombre %></option>
                <% }); %>
              </select>
            </div>

            <!-- Escobillas (condicional) -->
            <div id="escobillasSection" class="cr-escobillas" style="display:none">
              <div class="cr-escobillas__hd">
                <i class="fa-solid fa-wiper"></i> Datos de Escobillas (TRICO)
              </div>
              <input type="hidden" id="escobillas_tipo" name="escobillas_tipo" value="">
              <input type="hidden" id="escobillas_codigos_json" name="escobillas_codigos_json" value="">
              <input type="hidden" id="escobillas_kit_json" name="escobillas_kit_json" value="">

              <div class="cr-field">
                <label class="cr-label" for="esc_formato">Formato</label>
                <select id="esc_formato" name="esc_formato" class="cr-select">
                  <option value="unidad">Unidad</option>
                  <option value="kit">Kit (Conductor + Acompañante)</option>
                </select>
              </div>

              <div id="esc_unidad_block">
                <div class="cr-field">
                  <label class="cr-label" for="esc_tecnologia">Tecnología</label>
                  <select id="esc_tecnologia" name="esc_tecnologia" class="cr-select">
                    <option value="FLEX">FLEX</option>
                    <option value="STEEL">STEEL</option>
                    <option value="REAR">REAR (Trasera)</option>
                  </select>
                </div>
                <div class="cr-field">
                  <label class="cr-label" for="esc_codigo">Código TRICO</label>
                  <input type="text" id="esc_codigo" name="esc_codigo" placeholder="Ej: 10707" autocomplete="off" class="cr-input">
                </div>
              </div>

              <div id="esc_kit_block" style="display:none">
                <div class="cr-field">
                  <label class="cr-label" for="esc_kit_tecnologia">Tecnología del kit</label>
                  <select id="esc_kit_tecnologia" name="esc_kit_tecnologia" class="cr-select">
                    <option value="FLEX">FLEX</option>
                    <option value="STEEL">STEEL</option>
                  </select>
                </div>
                <div class="cr-field">
                  <label class="cr-label" for="esc_kit_conductor">Código TRICO Conductor</label>
                  <input type="text" id="esc_kit_conductor" name="esc_kit_conductor" placeholder="Ej: 10707" autocomplete="off" class="cr-input">
                </div>
                <div class="cr-field">
                  <label class="cr-label" for="esc_kit_acompanante">Código TRICO Acompañante</label>
                  <input type="text" id="esc_kit_acompanante" name="esc_kit_acompanante" placeholder="Ej: 10708" autocomplete="off" class="cr-input">
                </div>
              </div>
            </div>

            <!-- Marca / Modelo -->
            <div class="cr-field">
              <label class="cr-label" for="marca">Marca</label>
              <select id="marca" name="marca" class="cr-select">
                <option value="" selected>Seleccioná una marca</option>
                <% marcas.forEach(function(marca) { %>
                  <option value="<%= marca.id %>"><%= marca.nombre %></option>
                <% }); %>
              </select>
            </div>

            <div class="cr-field">
              <label class="cr-label" for="modelo_id">Modelo</label>
              <select id="modelo_id" name="modelo_id" class="cr-select">
                <option value="" <% if (!producto || !producto.modelo_id) { %>selected<% } %>>Seleccioná un modelo</option>
                <% modelos.forEach(function(modelo) { %>
                  <option value="<%= modelo.id %>" <% if (producto && producto.modelo_id == modelo.id) { %>selected<% } %>><%= modelo.nombre %></option>
                <% }); %>
              </select>
            </div>

          </div>
        </div>

        <!-- ══════════════════════════════
             COLUMNA 2: PROVEEDORES
        ══════════════════════════════ -->
        <div class="cr-panel">
          <div class="cr-panel__hd">
            <i class="fa-solid fa-truck"></i>
            <strong>Proveedores y costos</strong>
          </div>
          <div class="cr-panel__bd">

            <!-- Calidades + Oferta -->
            <div class="cr-calidades-group">
              <span class="cr-label cr-calidades-group__title">Calidades y estado</span>

              <div class="cr-field cr-field--inline">
                <label class="cr-label" for="calidad_original">Calidad FITAM</label>
                <label class="cr-toggle cr-toggle--fitam">
                  <input type="checkbox" id="calidad_original" name="calidad_original" value="1" class="cr-toggle__input">
                  <span class="cr-toggle__slider"></span>
                </label>
              </div>

              <div class="cr-field cr-field--inline">
                <label class="cr-label" for="calidad_vic">Calidad VIC</label>
                <label class="cr-toggle cr-toggle--vic">
                  <input type="checkbox" id="calidad_vic" name="calidad_vic" value="1" class="cr-toggle__input">
                  <span class="cr-toggle__slider"></span>
                </label>
              </div>

              <div class="cr-field cr-field--inline">
                <label class="cr-label" for="calidad_mm">Magnetti Marelli</label>
                <label class="cr-toggle cr-toggle--mm">
                  <input type="checkbox" id="calidad_mm" name="calidad_mm" value="1" class="cr-toggle__input">
                  <span class="cr-toggle__slider"></span>
                </label>
              </div>

              <div class="cr-field cr-field--inline">
                <label class="cr-label" for="calidad_original_premium">Original</label>
                <label class="cr-toggle cr-toggle--premium">
                  <input type="checkbox" id="calidad_original_premium" name="calidad_original_premium" value="1" class="cr-toggle__input">
                  <span class="cr-toggle__slider"></span>
                </label>
              </div>

              <div class="cr-field cr-field--inline">
                <label class="cr-label" for="oferta">En oferta</label>
                <label class="cr-toggle cr-toggle--oferta">
                  <input type="hidden" name="oferta" value="0">
                  <input type="checkbox" id="oferta" name="oferta" value="1" class="cr-toggle__input"
                    <%= producto && producto.oferta === 1 ? 'checked' : '' %>>
                  <span class="cr-toggle__slider"></span>
                </label>
              </div>
            </div>

            <!-- Proveedor asignado -->
            <div class="cr-field">
              <label class="cr-label">Proveedor asignado <span class="cr-hint-inline">(costo IVA más bajo)</span></label>
              <div id="proveedorAsignado" class="cr-input cr-input--readonly"></div>
            </div>

            <div class="cr-sep"></div>

            <!-- Contenedor de bloques proveedor -->
            <div id="proveedoresContainer">

              <!-- BLOQUE BASE (se clona con JS) -->
              <div class="proveedor cr-prov-card">
                <div class="form-group-crear cr-field">
                  <label class="label-proveedor cr-label">Proveedor: <span class="nombre_proveedor cr-prov-nombre"></span></label>
                  <select class="proveedores cr-select" name="proveedores[]" required>
                    <option value="" selected>Seleccioná proveedor...</option>
                    <% proveedores.forEach(function(proveedor) { %>
                      <option value="<%= proveedor.id %>" data-descuento="<%= proveedor.descuento %>"><%= proveedor.nombre %></option>
                    <% }); %>
                  </select>
                </div>

                <div class="form-group-crear cr-field">
                  <label class="label-codigo cr-label">Código proveedor</label>
                  <input class="codigo cr-input form-control" type="text" name="codigo[]">
                </div>

                <div class="cr-prov-grid">
                  <div class="form-group-crear cr-field">
                    <label class="label-precio-lista cr-label">Precio de lista</label>
                    <input class="precio_lista cr-input form-control" type="number" step="0.01" name="precio_lista[]">
                  </div>

                  <div class="form-group-crear cr-field">
                    <label class="label-descuento cr-label">Descuento prov.</label>
                    <input class="descuentos_proveedor_id cr-input cr-input--readonly form-control" type="text" name="descuentos_proveedor_id[]" value="0" readonly>
                  </div>
                </div>

                <div class="cr-prov-grid">
                  <div class="form-group-crear cr-field">
                    <label class="cr-label">Presentación</label>
                    <select class="presentacion cr-select form-control" name="presentacion[]">
                      <option value="unidad" selected>Unidad</option>
                      <option value="juego">Juego (par)</option>
                    </select>
                    <input type="hidden" class="factor_unidad" name="factor_unidad[]" value="1">
                    <p class="cr-hint">Si es "juego", toma la mitad por unidad.</p>
                  </div>

                  <div class="form-group-crear cr-field">
                    <label class="cr-label">IVA</label>
                    <select class="IVA cr-select form-control" name="IVA[]">
                      <option value="21" selected>21%</option>
                      <option value="10.5">10.5%</option>
                    </select>
                  </div>
                </div>

                <div class="cr-prov-grid">
                  <div class="form-group-crear cr-field">
                    <label class="cr-label">Costo neto</label>
                    <input class="costo_neto cr-input form-control" type="number" step="0.01" name="costo_neto[]" value="0">
                  </div>

                  <div class="form-group-crear cr-field">
                    <label class="cr-label">Costo con IVA</label>
                    <input class="costo_iva_vis cr-input cr-input--readonly form-control" type="number" step="0.01" readonly>
                    <input class="costo_iva" type="hidden" name="costo_iva[]" value="0">
                  </div>
                </div>

                <button type="button" class="eliminar-proveedor cr-btn cr-btn--danger cr-btn--sm">
                  <i class="fa-solid fa-trash"></i> Eliminar proveedor
                </button>
              </div>

            </div>

            <button id="addProveedor" type="button" class="cr-btn cr-btn--outline cr-btn--full">
              <i class="fa-solid fa-plus"></i> Agregar proveedor
            </button>

          </div>
        </div>

        <!-- ══════════════════════════════
             COLUMNA 3: UTILIDADES
        ══════════════════════════════ -->
        <div class="cr-panel">
          <div class="cr-panel__hd">
            <i class="fa-solid fa-chart-pie"></i>
            <strong>Precio y stock</strong>
          </div>
          <div class="cr-panel__bd">

            <div class="cr-field">
              <label class="cr-label" for="utilidad">Utilidad (%)</label>
              <input id="utilidad" type="number" name="utilidad" class="cr-input">
            </div>

            <div class="cr-field">
              <label class="cr-label" for="precio_venta">Precio de venta</label>
              <div class="cr-input-prefix-wrap">
                <span class="cr-input-prefix">$</span>
                <input id="precio_venta" type="number" name="precio_venta" class="cr-input cr-input--prefixed">
              </div>
            </div>

            <div class="cr-sep"></div>

            <div class="cr-field">
              <label class="cr-label" for="estado">Estado</label>
              <select id="estado" name="estado" class="cr-select">
                <option value="">Seleccioná un estado...</option>
                <option value="activo">Activo</option>
                <option value="inactivo">Inactivo</option>
              </select>
            </div>

            <div class="cr-field">
              <label class="cr-label" for="stock_minimo">Stock mínimo</label>
              <input type="number" id="stock_minimo" name="stock_minimo" min="0" required class="cr-input">
            </div>

            <div class="cr-field">
              <label class="cr-label" for="stock_actual">Stock actual</label>
              <input type="number" id="stock_actual" name="stock_actual" min="0" required class="cr-input">
            </div>

            <div class="cr-sep"></div>

            <div class="cr-actions">
              <button type="submit" class="cr-btn cr-btn--primary cr-btn--full">
                <i class="fa-solid fa-floppy-disk"></i> Guardar producto
              </button>
              <a href="/productos" class="cr-btn cr-btn--outline cr-btn--full">
                Cancelar
              </a>
            </div>

          </div>
        </div>

      </div>
    </form>
  </div>
</main>

<%- include('./layouts/footer.ejs') %>
<script src="https://ajax.googleapis.com/ajax/libs/jquery/3.5.1/jquery.min.js"></script>
<script src="https://cdn.jsdelivr.net/npm/sortablejs@1.10.2/Sortable.min.js"></script>
<script src="/js/pages/crear.js?v=1"></script>
<script>
  // Fix Enter en textarea descripción
  (function () {
    var ta = document.getElementById('descripcion');
    if (!ta) return;
    ta.addEventListener('keydown', function (e) {
      if (e.key !== 'Enter') return;
      e.preventDefault();
      e.stopImmediatePropagation();
      var start = ta.selectionStart, end = ta.selectionEnd;
      ta.value = ta.value.slice(0, start) + "\n" + ta.value.slice(end);
      ta.selectionStart = ta.selectionEnd = start + 1;
      ta.dispatchEvent(new Event('input', { bubbles: true }));
    }, true);
  })();
</script>
</body>
</html>
