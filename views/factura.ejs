<% var pageCss = '/css/pages/factura.css' %>
<!DOCTYPE html>
<html lang="es">
<%- include('./layouts/head.ejs') %>
<link rel="stylesheet" href="/css/pages/factura.css?v=1" />
<body>
  <%- include('./layouts/header.ejs') %>

  <main class="fv-main">

    <!-- PAGE HEADER -->
    <div class="fv-page-header">
      <div class="fv-page-header__left">
        <span class="fv-page-header__eyebrow">Mostrador</span>
        <h1 class="fv-page-header__title">Detalle de Factura <span class="fv-page-header__id">#<%= factura.id %></span></h1>
      </div>
      <form action="/productos/listadoFacturas" method="GET">
        <input type="hidden" name="fechaInicio" value="<%= new Date(factura.creado_en).toISOString().split('T')[0] %>">
        <input type="hidden" name="fechaFin" value="<%= new Date(factura.creado_en).toISOString().split('T')[0] %>">
        <button type="submit" class="fv-btn fv-btn--outline">
          <i class="fa-solid fa-arrow-left"></i> Volver al listado
        </button>
      </form>
    </div>

    <!-- META PANEL -->
    <div class="fv-panel fv-panel--meta">
      <div class="fv-meta-grid">
        <div class="fv-meta-item">
          <span class="fv-meta-item__label">ID Factura</span>
          <span class="fv-meta-item__value fv-meta-item__value--id">#<%= factura.id %></span>
        </div>
        <div class="fv-meta-item">
          <span class="fv-meta-item__label">Fecha</span>
          <span class="fv-meta-item__value">
            <%= new Date(factura.creado_en).toLocaleDateString('es-AR') %>
          </span>
        </div>
        <div class="fv-meta-item">
          <span class="fv-meta-item__label">Hora</span>
          <span class="fv-meta-item__value">
            <%= new Date(factura.creado_en).toLocaleTimeString('es-AR', { hour: '2-digit', minute: '2-digit' }) %>
          </span>
        </div>
        <div class="fv-meta-item">
          <span class="fv-meta-item__label">Vendedor</span>
          <span class="fv-meta-item__value"><%= factura.nombre_cliente %></span>
        </div>
        <% if (factura.metodos_pago) { %>
        <div class="fv-meta-item">
          <span class="fv-meta-item__label">Método de Pago</span>
          <span class="fv-meta-item__value">
            <% const metodo = factura.metodos_pago.toLowerCase(); %>
            <% const claseMetodo = ['efectivo','credito','debito','transferencia','qr'].includes(metodo) ? metodo : 'otro'; %>
            <span class="fv-badge fv-badge--<%= claseMetodo %>"><%= factura.metodos_pago %></span>
          </span>
        </div>
        <% } %>
      </div>
    </div>

    <!-- TABLA ITEMS -->
    <div class="fv-panel fv-panel--tabla">
      <table class="fv-tabla">
        <thead>
          <tr>
            <th>#</th>
            <th>Producto</th>
            <th>Cantidad</th>
            <th>Precio Unitario</th>
            <th>Subtotal</th>
          </tr>
        </thead>
        <tbody>
          <% let total = 0; %>
          <% detalles.forEach((item, index) => {
               const subtotal = item.precio_unitario * item.cantidad;
               total += subtotal;
          %>
            <tr>
              <td class="fv-tabla__num"><%= index + 1 %></td>
              <td class="fv-tabla__producto"><%= item.nombre_producto %></td>
              <td class="fv-tabla__qty"><%= item.cantidad %></td>
              <td class="fv-tabla__precio">$<%= item.precio_unitario.toLocaleString('es-AR', { minimumFractionDigits: 0 }) %></td>
              <td class="fv-tabla__subtotal">$<%= subtotal.toLocaleString('es-AR', { minimumFractionDigits: 0 }) %></td>
            </tr>
          <% }); %>
        </tbody>
        <tfoot>
          <tr>
            <td colspan="4" class="fv-tabla__tfoot-label">Total</td>
            <td class="fv-tabla__tfoot-total">$<%= total.toLocaleString('es-AR', { minimumFractionDigits: 0 }) %></td>
          </tr>
        </tfoot>
      </table>
    </div>

    <!-- ACCIONES -->
    <div class="fv-acciones">
      <button onclick="window.print()" class="fv-btn fv-btn--outline">
        <i class="fa-solid fa-print"></i> Imprimir
      </button>
    </div>

  </main>

  <%- include('./layouts/footer.ejs') %>
</body>
</html>
